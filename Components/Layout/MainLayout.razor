@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" @bind-IsDarkMode="_isDark" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6">RuleForge v2</MudText>
        <MudSpacer />
        <MudIconButton Icon="@(_isDark ? Icons.Material.Filled.DarkMode : Icons.Material.Filled.LightMode)" Color="Color.Inherit" OnClick="ToggleTheme" />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               Elevation="1"
               Variant="DrawerVariant.Persistent"
               ClipMode="DrawerClipMode.Always"
               Width="280px">
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private bool _isDark;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight { Primary = "#5B8DEF", Secondary = "#8C6FF7", Background = "#F6F8FC", Surface = "#FFFFFF" },
        PaletteDark = new PaletteDark { Primary = "#8FB6FF", Secondary = "#B39DFF", Background = "#121826", Surface = "#1B2335", AppbarBackground = "#1B2335" },
        LayoutProperties = new LayoutProperties { DrawerWidthLeft = "280px" }
    };

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
    private void ToggleTheme() => _isDark = !_isDark;
}
