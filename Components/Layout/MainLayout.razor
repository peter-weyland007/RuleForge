@using System.Text.RegularExpressions
@inherits LayoutComponentBase
@inject IJSRuntime JS
@inject IWebHostEnvironment Env
@inject IConfiguration Config
@inject NavigationManager Nav

<MudThemeProvider Theme="_theme" @bind-IsDarkMode="_isDark" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6">RuleForge v2</MudText>
        <MudSpacer />
        @if (Env.IsDevelopment())
        {
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning" Class="mr-1">NAV BUILD: @NavBuildTag</MudChip>
            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info" Class="mr-2">@PageBuildLabel</MudChip>
        }
        <MudIconButton Icon="@(_isDark ? Icons.Material.Filled.DarkMode : Icons.Material.Filled.LightMode)" Color="Color.Inherit" OnClick="ToggleTheme" />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               Elevation="1"
               Variant="DrawerVariant.Persistent"
               ClipMode="DrawerClipMode.Always"
               Width="280px">
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private string NavBuildTag => Config["Build:Tag"]
        ?? Environment.GetEnvironmentVariable("RULEFORGE_BUILD_TAG")
        ?? BuildStampFor("Components/Layout/NavMenu.razor")
        ?? "dev-local";

    private string CurrentPage => string.IsNullOrWhiteSpace(Nav.ToBaseRelativePath(Nav.Uri)) ? "/" : "/" + Nav.ToBaseRelativePath(Nav.Uri);

    private string PageBuildLabel
    {
        get
        {
            var file = ResolvePageFile(CurrentPage);
            var stamp = BuildStampFor(file) ?? "unknown";
            var name = file is null ? "PAGE" : Path.GetFileNameWithoutExtension(file).ToUpperInvariant();
            return $"{name} BUILD: {stamp}";
        }
    }

    private string? BuildStampFor(string? relativePath)
    {
        if (string.IsNullOrWhiteSpace(relativePath)) return null;
        var full = Path.Combine(Env.ContentRootPath, relativePath.Replace('/', Path.DirectorySeparatorChar));
        if (!File.Exists(full)) return null;
        var dt = File.GetLastWriteTime(full);
        return dt.ToString("yyyy-MM-dd-HHmm");
    }

    private string? ResolvePageFile(string currentPage)
    {
        var p = currentPage.Trim('/').ToLowerInvariant();
        if (string.IsNullOrWhiteSpace(p)) return "Components/Pages/Home.razor";
        if (p.StartsWith("quests/") && p.EndsWith("/canvas")) return "Components/Pages/QuestCanvas.razor";
        if (p.StartsWith("quests/") && p.EndsWith("/run")) return "Components/Pages/QuestRun.razor";
        if (Regex.IsMatch(p, @"^quests/\d+$")) return "Components/Pages/QuestBuilder.razor";
        if (p.StartsWith("settings/operations/hard-delete")) return "Components/Pages/HardDelete.razor";
        if (p.StartsWith("settings")) return "Components/Pages/Settings.razor";
        if (p.StartsWith("docs")) return "Components/Pages/Docs.razor";
        if (p.StartsWith("login")) return "Components/Pages/Login.razor";
        if (p.StartsWith("profile")) return "Components/Pages/Profile.razor";

        var first = p.Split('/')[0];
        var file = char.ToUpper(first[0]) + first.Substring(1);
        return $"Components/Pages/{file}.razor";
    }
    private bool _isDark;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight { Primary = "#5B8DEF", Secondary = "#8C6FF7", Background = "#F6F8FC", Surface = "#FFFFFF" },
        PaletteDark = new PaletteDark { Primary = "#8FB6FF", Secondary = "#B39DFF", Background = "#121826", Surface = "#1B2335", AppbarBackground = "#1B2335" },
        LayoutProperties = new LayoutProperties { DrawerWidthLeft = "280px" }
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            var prefs = await JS.InvokeAsync<Prefs?>("ruleforgePrefs.get");
            if (prefs?.theme is not null)
            {
                _isDark = string.Equals(prefs.theme, "dark", StringComparison.OrdinalIgnoreCase);
                StateHasChanged();
            }
        }
        catch { }
    }

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private async Task ToggleTheme()
    {
        _isDark = !_isDark;
        try { await JS.InvokeVoidAsync("ruleforgePrefs.set", new { theme = _isDark ? "dark" : "light" }); } catch { }
    }

    private sealed class Prefs { public string? theme { get; set; } }
}
