@page "/quests"
@inject IHttpClientFactory HttpFactory
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Quests</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h4">Quests</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Structure campaign stories in linear or branching form.</MudText>
        </MudStack>
        <MudStack Row="true" Spacing="1">
            <MudButton Variant="Variant.Outlined" Color="Color.Info" Href="/docs" StartIcon="@Icons.Material.Filled.HelpOutline">Docs</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreate">Add Quest</MudButton>
        </MudStack>
    </MudStack>

    <ApiErrorAlert Message="@error" />

    <MudTable Items="rows" Dense="true" Hover="true" Outlined="true" Elevation="0">
        <HeaderContent>
            <MudTh>Title</MudTh>
            <MudTh>Campaign</MudTh>
            <MudTh>Mode</MudTh>
            <MudTh>Choices</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Title</MudTd>
            <MudTd>@CampaignName(context.CampaignId)</MudTd>
            <MudTd>@ModeLabel(context.Mode)</MudTd>
            <MudTd>@(context.UseChoiceMode ? "On" : "Off")</MudTd>
            <MudTd Style="text-align:right; white-space:nowrap;">
                <MudIconButton Icon="@Icons.Material.Filled.PlayArrow" Color="Color.Success" Size="Size.Small" Href="@($"/quests/{context.QuestId}/run")" />
                <MudIconButton Icon="@Icons.Material.Filled.AccountTree" Color="Color.Success" Size="Size.Small" Href="@($"/quests/{context.QuestId}")" />
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" OnClick="() => OpenEdit(context.QuestId)" />
                <MudIconButton Icon="@Icons.Material.Filled.GroupAdd" Color="Color.Info" Size="Size.Small" OnClick="() => OpenShare(context.QuestId)" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="() => Delete(context.QuestId)" />
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Typo="Typo.body2" Class="pa-4">No quests yet. Add your first one.</MudText>
        </NoRecordsContent>
    </MudTable>


    @if (isShare)
    {
        <MudPaper Class="pa-4" Outlined="true" Elevation="0">
            <MudStack Spacing="2">
                <MudText Typo="Typo.h6">Share Quest</MudText>
                <MudSelect T="int?" @bind-Value="shareUserId" Label="Friend" Variant="Variant.Outlined">
                    @foreach (var f in friends)
                    {
                        <MudSelectItem T="int?" Value="f.AppUserId">@f.Username</MudSelectItem>
                    }
                </MudSelect>
                <MudSelect T="int" @bind-Value="sharePermission" Label="Permission" Variant="Variant.Outlined">
                    <MudSelectItem Value="0">View</MudSelectItem>
                    <MudSelectItem Value="1">Edit</MudSelectItem>
                </MudSelect>
                <MudStack Row="true" Spacing="1">
                    <MudButton Variant="Variant.Filled" Color="Color.Info" OnClick="SaveShare">Share</MudButton>
                    <MudButton Variant="Variant.Outlined" OnClick="() => isShare = false">Cancel</MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>
    }

    @if (isEdit)
    {
        <MudPaper Class="pa-4" Outlined="true" Elevation="0">
            <MudStack Spacing="2">
                <MudText Typo="Typo.h6">@(form.QuestId.HasValue ? "Edit Quest" : "Create Quest")</MudText>
                <MudGrid>
                    <MudItem xs="12" md="5"><MudTextField @bind-Value="form.Title" Label="Title" Variant="Variant.Outlined" Required="true" /></MudItem>
                    <MudItem xs="12" md="3">
                        <MudSelect T="int?" @bind-Value="form.CampaignId" Label="Campaign" Variant="Variant.Outlined" Clearable="true" Disabled="@(!campaigns.Any())">
                            @foreach (var c in campaigns)
                            {
                                <MudSelectItem T="int?" Value="c.CampaignId">@c.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="2">
                        <MudSelect T="int" @bind-Value="form.Mode" Label="Mode" Variant="Variant.Outlined">
                            <MudSelectItem Value="1">Linear</MudSelectItem>
                            <MudSelectItem Value="2">Branching</MudSelectItem>
                            <MudSelectItem Value="3">Hybrid</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="2">
                        <MudCheckBox T="bool" @bind-Value="form.UseChoiceMode" Label="Use Choice Mode" />
                    </MudItem>
                </MudGrid>
                <MudTextField @bind-Value="form.Summary" Label="Summary" Variant="Variant.Outlined" Lines="3" />
                <MudStack Row="true" Spacing="1">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save" Disabled="@isSaving">@(isSaving ? "Saving..." : "Save")</MudButton>
                    <MudButton Variant="Variant.Outlined" OnClick="() => isEdit = false">Cancel</MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>
    }
</MudStack>

@code {
    private List<QuestRow> rows = new();
    private List<CampaignOption> campaigns = new();
    private bool isEdit;
    private string? error;
    private bool isSaving;
    private bool isShare;
    private int? shareId;
    private int? shareUserId;
    private int sharePermission;
    private List<FriendUser> friends = new();
    private QuestForm form = new();

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        try
        {
            error = null;
            var r1 = await JS.InvokeAsync<ApiResult<List<QuestRow>>>("ruleforgeApi.get", "/api/quests");
            var r2 = await JS.InvokeAsync<ApiResult<List<CampaignOption>>>("ruleforgeApi.get", "/api/campaigns");
            var fr = await JS.InvokeAsync<ApiResult<FriendsOverview>>("ruleforgeApi.get", "/api/friends");
            if (!r1.Ok) { error = ApiErrorMessage(r1, "Failed to load quests."); rows = new(); return; }
            rows = r1.Data ?? new();
            campaigns = r2.Data ?? new();
            friends = fr.Data?.Friends ?? new();
        }
        catch (Exception ex)
        {
            error = ex.Message;
            rows = new();
        }
    }

    private void OpenCreate() { form = new QuestForm { Mode = 3, UseChoiceMode = true }; isEdit = true; }

    private async Task OpenEdit(int id)
    {
        var r = await JS.InvokeAsync<ApiResult<QuestRow>>("ruleforgeApi.get", $"/api/quests/{id}");
        if (!r.Ok || r.Data is null) { error = string.IsNullOrWhiteSpace(r.Text) ? "Quest not found." : r.Text; return; }
        var row = r.Data;
        form = new QuestForm { QuestId = row.QuestId, CampaignId = row.CampaignId, Title = row.Title, Summary = row.Summary, Mode = row.Mode, UseChoiceMode = row.UseChoiceMode, StartNodeId = row.StartNodeId };
        isEdit = true;
    }

    private async Task Save()
    {
        if (isSaving) return;
        isSaving = true;
        try
        {
            var req = new { campaignId = form.CampaignId, title = form.Title, summary = form.Summary, mode = form.Mode, useChoiceMode = form.UseChoiceMode, startNodeId = form.StartNodeId };
            var res = form.QuestId.HasValue
                ? await JS.InvokeAsync<ApiResult<object>>("ruleforgeApi.put", $"/api/quests/{form.QuestId.Value}", req)
                : await JS.InvokeAsync<ApiResult<object>>("ruleforgeApi.post", "/api/quests", req);

            if (!res.Ok)
            {
                error = ApiErrorMessage(res, "Save failed.");
                return;
            }

            isEdit = false;
            await Load();
        }
        finally { isSaving = false; }
    }

    private async Task Delete(int id)
    {
        var ok = await JS.InvokeAsync<bool>("confirm", "Delete this quest?");
        if (!ok) return;
        var res = await JS.InvokeAsync<ApiResult<object>>("ruleforgeApi.delete", $"/api/quests/{id}");
        if (!res.Ok) { error = ApiErrorMessage(res, "Delete failed."); return; }
        await Load();
    }

    private void OpenShare(int id) { shareId = id; shareUserId = null; sharePermission = 0; isShare = true; }
    private async Task SaveShare()
    {
        if (!shareId.HasValue || !shareUserId.HasValue) { error = "Pick a friend to share with."; return; }
        var r = await JS.InvokeAsync<ApiResult<object>>("ruleforgeApi.post", $"/api/quests/{shareId.Value}/share", new { userId = shareUserId.Value, permission = sharePermission });
        if (!r.Ok) { error = ApiErrorMessage(r, "Share failed."); return; }
        isShare = false;
    }

    private string CampaignName(int? id) => id is null ? "—" : campaigns.FirstOrDefault(x => x.CampaignId == id)?.Name ?? $"#{id}";
    private static string ModeLabel(int m) => m switch { 1 => "Linear", 2 => "Branching", 3 => "Hybrid", _ => "Hybrid" };

    private sealed class QuestForm
    {
        public int? QuestId { get; set; }
        public int? CampaignId { get; set; }
        public string Title { get; set; } = string.Empty;
        public string? Summary { get; set; }
        public int Mode { get; set; }
        public bool UseChoiceMode { get; set; }
        public int? StartNodeId { get; set; }
    }

    private sealed record QuestRow(int QuestId, int? CampaignId, string Title, string? Summary, int Mode, bool UseChoiceMode, int? StartNodeId);
    private sealed record CampaignOption(int CampaignId, string Name);
    private static string ApiErrorMessage<T>(ApiResult<T> res, string fallback)
    {
        if (!string.IsNullOrWhiteSpace(res.Text)) return NormalizeErrorText(res.Text!);
        var msg = ExtractMessage(res.Data);
        if (!string.IsNullOrWhiteSpace(msg)) return msg!;
        return res.Status > 0 ? $"{fallback} (HTTP {res.Status})" : fallback;
    }

    private static string NormalizeErrorText(string text)
    {
        var t = text.Trim();
        if (t.Length >= 2 && t.StartsWith(""") && t.EndsWith("""))
        {
            try { return System.Text.Json.JsonSerializer.Deserialize<string>(t) ?? t.Trim(new char[] {'"'}); } catch { return t.Trim(new char[] {'"'}); }
        }
        return t;
    }

    private static string? ExtractMessage(object? data)
    {
        if (data is null) return null;
        try
        {
            var json = System.Text.Json.JsonSerializer.Serialize(data);
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            if (doc.RootElement.ValueKind != System.Text.Json.JsonValueKind.Object) return null;
            foreach (var key in new[] { "message", "Message", "title", "error", "detail" })
            {
                if (doc.RootElement.TryGetProperty(key, out var v) && v.ValueKind == System.Text.Json.JsonValueKind.String)
                    return v.GetString();
            }
        }
        catch { }
        return null;
    }

    private sealed class ApiResult<T> { public bool Ok { get; set; } public int Status { get; set; } public T? Data { get; set; } public string? Text { get; set; } }
    private sealed record FriendUser(int AppUserId, string Username, string Email);
    private sealed record FriendsOverview(List<FriendUser> Friends);
}
