@page "/encounters/run/{EncounterId:int}"
@inject IHttpClientFactory HttpFactory
@inject NavigationManager Nav

<PageTitle>Encounter Run</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h4">@encounterName</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Round @round · @typeLabel</MudText>
        </MudStack>
        <MudStack Row="true" Spacing="1">
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ArrowBack" Href="/encounters">Back</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Warning" StartIcon="@Icons.Material.Filled.RestartAlt" OnClick="ResetEncounter">Reset</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.SkipNext" OnClick="NextTurn">Next Turn</MudButton>
        </MudStack>
    </MudStack>

    @if (!string.IsNullOrWhiteSpace(error))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@error</MudAlert>
    }

    <MudPaper Class="pa-3" Outlined="true" Elevation="0">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudChip T="string" Color="Color.Info" Variant="Variant.Outlined">Round @round</MudChip>
            <MudChip T="string" Color="Color.Secondary" Variant="Variant.Outlined">Participants: @participants.Count</MudChip>
            @if (current is not null)
            {
                <MudChip T="string" Color="Color.Success" Variant="Variant.Filled">Current: @current.Name</MudChip>
            }
        </MudStack>
    </MudPaper>

    <MudTable Items="OrderedParticipants()" Dense="true" Hover="true" Outlined="true" Elevation="0" RowClassFunc="RowClass">
        <HeaderContent>
            <MudTh Style="width:52px;">#</MudTh>
            <MudTh>Combatant</MudTh>
            <MudTh Style="width:90px;">Init Mod</MudTh>
            <MudTh Style="width:110px;">Init Roll</MudTh>
            <MudTh Style="width:80px;">Total</MudTh>
            <MudTh Style="width:180px;">HP</MudTh>
            <MudTh>Conditions</MudTh>
            <MudTh Style="width:90px;"></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@Rank(context.LocalId)</MudTd>
            <MudTd>@($"{context.Name} ({ParticipantTypeLabel(context.ParticipantType)})")</MudTd>
            <MudTd>@context.InitMod</MudTd>
            <MudTd>
                <MudNumericField T="int?" Value="context.InitRoll" ValueChanged="(v) => SetInitRoll(context.LocalId, v)" Variant="Variant.Outlined" Margin="Margin.Dense" Class="run-num" />
            </MudTd>
            <MudTd>@InitTotal(context)</MudTd>
            <MudTd>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="0">
                    <MudIconButton Icon="@Icons.Material.Filled.Remove" Size="Size.Small" OnClick="() => AdjustHp(context.LocalId, -1)" />
                    <MudNumericField T="int?" Value="context.Hp" ValueChanged="(v) => SetHp(context.LocalId, v)" Variant="Variant.Outlined" Margin="Margin.Dense" Class="run-num" />
                    <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small" OnClick="() => AdjustHp(context.LocalId, +1)" />
                </MudStack>
            </MudTd>
            <MudTd>
                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Style="flex-wrap: wrap;">
                    @foreach (var c in context.Conditions)
                    {
                        <MudTooltip Text="@ConditionSummary(c)">
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning">@c</MudChip>
                        </MudTooltip>
                    }
                    <MudIconButton Icon="@Icons.Material.Filled.AddCircle" Color="Color.Info" Size="Size.Small" OnClick="() => OpenConditions(context.LocalId)" />
                </MudStack>
            </MudTd>
            <MudTd>
                @if (context.LocalId == activeLocalId)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Success">Active</MudChip>
                }
            </MudTd>
        </RowTemplate>
    </MudTable>
</MudStack>

@if (showConditionsDialog)
{
    <MudOverlay Visible="true" DarkBackground="true" AutoClose="true" OnClosed="CloseConditions" />
    <MudPaper Class="pa-4" Outlined="true" Elevation="8" Style="position: fixed; left: 50%; top: 50%; transform: translate(-50%, -50%); width: min(680px, 92vw); max-height: 80vh; overflow: auto; z-index: 1400;">
        <MudStack Spacing="2">
            <MudText Typo="Typo.h6">Conditions</MudText>
            <MudText Typo="Typo.body2">Select conditions to apply.</MudText>
            <MudGrid>
                @foreach (var condition in DndConditions)
                {
                    <MudItem xs="12" sm="6">
                        <MudCheckBox T="bool" Label="@condition" Value="@ConditionChecked(condition)" ValueChanged="(v) => SetCondition(condition, v)" />
                    </MudItem>
                }
            </MudGrid>
            <MudStack Row="true" Justify="Justify.FlexEnd">
                <MudButton Variant="Variant.Outlined" OnClick="CloseConditions">Close</MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>
}

<style>
    .active-turn { background: rgba(76, 175, 80, 0.12); }
    .run-num { max-width: 84px; }
</style>

@code {
    [Parameter] public int EncounterId { get; set; }

    private string? error;
    private string encounterName = "Encounter";
    private string typeLabel = "Combat";
    private int round = 1;
    private int? activeLocalId;
    private RunParticipant? current;
    private List<RunParticipant> participants = new();
    private bool showConditionsDialog;
    private int? conditionsTargetLocalId;
    private HashSet<string> conditionsSelection = new(StringComparer.OrdinalIgnoreCase);
    private static readonly string[] DndConditions =
    [
        "Blinded","Charmed","Deafened","Exhaustion","Frightened","Grappled","Incapacitated","Invisible","Paralyzed","Petrified","Poisoned","Prone","Restrained","Stunned","Unconscious"
    ];

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        try
        {
            var http = HttpFactory.CreateClient();
            var data = await http.GetFromJsonAsync<EncounterDto>(Nav.ToAbsoluteUri($"/api/encounters/{EncounterId}"));
            if (data is null)
            {
                error = "Encounter not found.";
                return;
            }

            encounterName = data.Name;
            typeLabel = TypeLabel(data.EncounterType);
            participants = data.Participants.Select((p, idx) => new RunParticipant
            {
                LocalId = idx + 1,
                ParticipantType = p.ParticipantType,
                Name = p.NameSnapshot,
                InitMod = p.InitiativeModifierSnapshot,
                Hp = p.HitPointsCurrent
            }).ToList();

            activeLocalId = OrderedParticipants().FirstOrDefault()?.LocalId;
            current = participants.FirstOrDefault(x => x.LocalId == activeLocalId);
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private IEnumerable<RunParticipant> OrderedParticipants() => participants
        .OrderByDescending(InitTotal)
        .ThenBy(x => x.Name);

    private int InitTotal(RunParticipant p) => (p.InitRoll ?? 0) + (p.InitMod ?? 0);

    private void SetInitRoll(int localId, int? v)
    {
        var p = participants.First(x => x.LocalId == localId);
        p.InitRoll = v;

        activeLocalId = OrderedParticipants().FirstOrDefault()?.LocalId;
        current = participants.FirstOrDefault(x => x.LocalId == activeLocalId);
    }

    private void SetHp(int localId, int? v)
    {
        var p = participants.First(x => x.LocalId == localId);
        p.Hp = v;
    }

    private void AdjustHp(int localId, int delta)
    {
        var p = participants.First(x => x.LocalId == localId);
        p.Hp = (p.Hp ?? 0) + delta;
    }

    private string RowClass(RunParticipant item, int rowNumber) => item.LocalId == activeLocalId ? "active-turn" : string.Empty;

    private int Rank(int localId) => OrderedParticipants().Select((x, i) => new { x.LocalId, Rank = i + 1 }).FirstOrDefault(x => x.LocalId == localId)?.Rank ?? 0;

    private string ParticipantTypeLabel(int t) => t switch { 1 => "PC", 2 => "NPC", 3 => "Creature", _ => "—" };

    
    private void OpenConditions(int localId)
    {
        var p = participants.First(x => x.LocalId == localId);
        conditionsTargetLocalId = localId;
        conditionsSelection = new HashSet<string>(p.Conditions, StringComparer.OrdinalIgnoreCase);
        showConditionsDialog = true;
    }

    private bool ConditionChecked(string c) => conditionsSelection.Contains(c);

    private void SetCondition(string c, bool isOn)
    {
        if (isOn) conditionsSelection.Add(c);
        else conditionsSelection.Remove(c);

        if (conditionsTargetLocalId is null) return;
        var p = participants.First(x => x.LocalId == conditionsTargetLocalId.Value);
        p.Conditions = conditionsSelection.OrderBy(x => x).ToList();
    }

    private void CloseConditions()
    {
        showConditionsDialog = false;
        conditionsTargetLocalId = null;
    }

    private void ResetEncounter()
    {
        round = 1;
        activeLocalId = OrderedParticipants().FirstOrDefault()?.LocalId;
        current = participants.FirstOrDefault(x => x.LocalId == activeLocalId);
    }

    private void NextTurn()
    {
        var ordered = OrderedParticipants().ToList();
        if (!ordered.Any()) return;
        if (activeLocalId is null)
        {
            activeLocalId = ordered[0].LocalId;
            current = participants.FirstOrDefault(x => x.LocalId == activeLocalId);
            return;
        }

        var idx = ordered.FindIndex(x => x.LocalId == activeLocalId.Value);
        if (idx < 0 || idx == ordered.Count - 1)
        {
            activeLocalId = ordered[0].LocalId;
            round++;
        }
        else
        {
            activeLocalId = ordered[idx + 1].LocalId;
        }

        current = participants.FirstOrDefault(x => x.LocalId == activeLocalId);
    }

    private string ConditionSummary(string c) => c switch
    {
        "Blinded" => "Can’t see and automatically fails sight checks; attacks against it have advantage, its attacks have disadvantage.",
        "Charmed" => "Can’t attack charmer or target charmer with harmful abilities; charmer has advantage on social checks.",
        "Deafened" => "Can’t hear and automatically fails checks that require hearing.",
        "Exhaustion" => "Cumulative penalties; severe levels reduce speed, impose disadvantages, and can lead to death.",
        "Frightened" => "Disadvantage on checks/attacks while source is visible; can’t willingly move closer to source.",
        "Grappled" => "Speed becomes 0; ends if grappler is incapacitated or target is moved away.",
        "Incapacitated" => "Can’t take actions or reactions.",
        "Invisible" => "Can’t be seen without special senses/magic; attacks against it have disadvantage, its attacks have advantage.",
        "Paralyzed" => "Incapacitated, can’t move/speak, fails STR/DEX saves; attacks have advantage, adjacent hits are critical.",
        "Petrified" => "Transformed into inert substance; incapacitated, unaware, resistant to all damage, immune to poison/disease.",
        "Poisoned" => "Disadvantage on attack rolls and ability checks.",
        "Prone" => "Only crawl unless it stands; attacks against it have advantage if within 5 ft, otherwise disadvantage.",
        "Restrained" => "Speed 0; attacks against it have advantage, its attacks have disadvantage; disadvantage on DEX saves.",
        "Stunned" => "Incapacitated, can’t move, speaks falteringly; fails STR/DEX saves; attacks against it have advantage.",
        "Unconscious" => "Incapacitated, can’t move/speak, unaware, drops prone; fails STR/DEX saves; adjacent hits are critical.",
        _ => "Condition effect summary unavailable."
    };

    private string TypeLabel(int t) => t switch { 1 => "Combat", 2 => "Social", 3 => "Exploration", 4 => "Puzzle", 5 => "Chase", 6 => "Hazard", _ => "Encounter" };

    private sealed class EncounterDto
    {
        public int EncounterId { get; set; }
        public string Name { get; set; } = string.Empty;
        public int EncounterType { get; set; }
        public List<EncounterParticipantDto> Participants { get; set; } = new();
    }

    private sealed class EncounterParticipantDto
    {
        public int ParticipantType { get; set; }
        public string NameSnapshot { get; set; } = string.Empty;
        public int? HitPointsCurrent { get; set; }
        public int? InitiativeModifierSnapshot { get; set; }
    }

    private sealed class RunParticipant
    {
        public int LocalId { get; set; }
        public int ParticipantType { get; set; }
        public string Name { get; set; } = string.Empty;
        public int? InitMod { get; set; }
        public int? InitRoll { get; set; }
        public int? Hp { get; set; }
        public List<string> Conditions { get; set; } = new();
    }
}
