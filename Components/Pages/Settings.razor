@page "/settings"
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.AspNetCore.Authorization

<PageTitle>Settings</PageTitle>

<MudStack Spacing="3">
    <MudText Typo="Typo.h4">Settings</MudText>

    <MudPaper Class="pa-4" Outlined="true" Elevation="0">
        <MudStack Spacing="1">
            <MudText Typo="Typo.h6">User Management</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Manage user accounts and roles.</MudText>
            <MudButton Href="/users" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.ManageAccounts">Open Users</MudButton>
        </MudStack>
    </MudPaper>

    <MudPaper Class="pa-4" Outlined="true" Elevation="0">
        <MudStack Spacing="1">
            <MudText Typo="Typo.h6">Hard Delete Cleanup</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Permanently remove soft-deleted records from the database.</MudText>
            <MudButton Href="/settings/operations/hard-delete" Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.DeleteForever">Open Cleanup Tool</MudButton>
        </MudStack>
    </MudPaper>

    <MudPaper Class="pa-4" Outlined="true" Elevation="0">
        <MudStack Spacing="1">
            <MudText Typo="Typo.h6">Seq Logging</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Configure Seq connection details and send a test event using the saved settings.</MudText>
            <MudButton Href="/settings/logging/seq" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Article">Open Seq Logging</MudButton>
        </MudStack>
    </MudPaper>
</MudStack>
