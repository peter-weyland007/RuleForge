@page "/settings"

<PageTitle>Settings</PageTitle>

<MudStack Spacing="3">
    <MudText Typo="Typo.h4">Settings</MudText>

    <MudPaper Class="pa-4" Outlined="true" Elevation="0">
        <MudStack Spacing="1">
            <MudText Typo="Typo.h6">Operations</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Admin tools and maintenance tasks.</MudText>
            <MudButton Href="/settings/operations" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Build">Open Operations</MudButton>
        </MudStack>
    </MudPaper>
</MudStack>
