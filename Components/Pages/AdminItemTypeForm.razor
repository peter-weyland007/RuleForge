@page "/admin/item-types/new"
@page "/admin/item-types/{ItemTypeDefinitionId:int}/edit"
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Admin Item Type Form</PageTitle>

<MudStack Spacing="3">
    <MudText Typo="Typo.h4">@(_isEdit ? "Edit Item Type" : "Create Item Type")</MudText>

    <MudPaper Class="pa-4" Outlined="true">
        <MudGrid>
            <MudItem xs="12" md="4">
                <MudSelect T="int" @bind-Value="model.GameSystemId" Label="Game System" Variant="Variant.Outlined">
                    @foreach (var gs in systems)
                    {
                        <MudSelectItem Value="@gs.GameSystemId">@gs.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="4"><MudTextField @bind-Value="model.Name" Label="Name" Variant="Variant.Outlined" Required="true" /></MudItem>
            <MudItem xs="12" md="4"><MudTextField @bind-Value="model.Description" Label="Description" Variant="Variant.Outlined" /></MudItem>
                        <MudItem xs="12">
                <MudStack Row="true" Spacing="2">
                    <MudButtonGroup Variant="Variant.Filled" Color="Color.Primary">
                        <MudButton OnClick="Save">Save</MudButton>
                        <MudButton Href="/admin/item-types" Color="Color.Secondary">Cancel</MudButton>
                    </MudButtonGroup>
                </MudStack>
            </MudItem>
        </MudGrid>
    </MudPaper>
</MudStack>

@code {
    [Parameter] public int? ItemTypeDefinitionId { get; set; }
    private bool _isEdit => ItemTypeDefinitionId.HasValue;
    private List<GameSystemDto> systems = new();
    private FormModel model = new();

    protected override async Task OnInitializedAsync()
    {
        systems = await Http.GetFromJsonAsync<List<GameSystemDto>>(Nav.ToAbsoluteUri("/api/game-systems")) ?? new();
        model.GameSystemId = systems.FirstOrDefault()?.GameSystemId ?? 0;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!_isEdit) return;
        var dto = await Http.GetFromJsonAsync<ItemTypeDto>(Nav.ToAbsoluteUri($"/api/admin/item-types/{ItemTypeDefinitionId!.Value}"));
        if (dto is null) { Nav.NavigateTo("/admin/item-types"); return; }
        model = new FormModel { GameSystemId = dto.GameSystemId, Name = dto.Name, Description = dto.Description };
    }

    private async Task Save()
    {
        if (model.GameSystemId <= 0 || string.IsNullOrWhiteSpace(model.Name)) return;
        var req = new UpsertItemTypeRequest(model.GameSystemId, model.Name, model.Description);
        HttpResponseMessage res = _isEdit
            ? await Http.PutAsJsonAsync(Nav.ToAbsoluteUri($"/api/admin/item-types/{ItemTypeDefinitionId!.Value}"), req)
            : await Http.PostAsJsonAsync(Nav.ToAbsoluteUri("/api/admin/item-types"), req);

        if (res.IsSuccessStatusCode)
            Nav.NavigateTo("/admin/item-types");
    }

    private sealed class FormModel
    {
        public int GameSystemId { get; set; }
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
    }

    private sealed record GameSystemDto(int GameSystemId, string Name);
    private sealed record ItemTypeDto(int ItemTypeDefinitionId, int GameSystemId, string Name, string Slug, string? Description);
}
