@page "/change-password"
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Change Password</PageTitle>

<MudStack Spacing="3" Style="max-width:520px; margin: 1rem auto;">
    <MudText Typo="Typo.h4">Change Password</MudText>
    <MudText Typo="Typo.body2">For security, change your password before continuing.</MudText>

    <MudPaper Class="pa-4" Outlined="true">
        <MudStack Spacing="2">
            <MudTextField @bind-Value="currentPassword" Label="Current Password" InputType="InputType.Password" Variant="Variant.Outlined" Required="true" />
            <MudTextField @bind-Value="newPassword" Label="New Password" InputType="InputType.Password" Variant="Variant.Outlined" Required="true" HelperText="Minimum 8 characters" />
            @if (!string.IsNullOrWhiteSpace(error))
            {
                <MudAlert Severity="Severity.Error" Dense="true">@error</MudAlert>
            }
            @if (!string.IsNullOrWhiteSpace(ok))
            {
                <MudAlert Severity="Severity.Success" Dense="true">@ok</MudAlert>
            }
            <MudButton OnClick="DoChange" Variant="Variant.Filled" Color="Color.Primary">Update Password</MudButton>
        </MudStack>
    </MudPaper>
</MudStack>

@code {
    private string currentPassword = string.Empty;
    private string newPassword = string.Empty;
    private string? error;
    private string? ok;

    private async Task DoChange()
    {
        error = null;
        ok = null;

        var res = await Http.PostAsJsonAsync(Nav.ToAbsoluteUri("/api/auth/change-password"), new { CurrentPassword = currentPassword, NewPassword = newPassword });
        if (res.IsSuccessStatusCode)
        {
            ok = "Password updated. Please log in again.";
            await Task.Delay(700);
            Nav.NavigateTo("/login", true);
            return;
        }

        error = await res.Content.ReadAsStringAsync();
    }
}
