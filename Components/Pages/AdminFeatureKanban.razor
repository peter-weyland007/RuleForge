@page "/admin/feature-kanban"
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Admin Feature Kanban</PageTitle>

<MudStack Spacing="3">
    <MudText Typo="Typo.h4">Admin · Feature Kanban</MudText>

    <MudPaper Class="pa-4" Outlined="true">
        <MudGrid>
            <MudItem xs="12" md="4"><MudTextField @bind-Value="newTitle" Label="Title" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" md="2"><MudSelect T="string" @bind-Value="newPriority" Label="Priority" Variant="Variant.Outlined">@foreach (var p in priorityOptions){<MudSelectItem Value="@p">@p</MudSelectItem>}</MudSelect></MudItem>
            <MudItem xs="12" md="3"><MudTextField @bind-Value="newRequestedBy" Label="Requested by" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" md="2"><MudSelect T="string" @bind-Value="newEntity" Label="Entity" Variant="Variant.Outlined">@foreach (var e in entitySelectOptions){<MudSelectItem Value="@e">@e</MudSelectItem>}</MudSelect></MudItem>
            <MudItem xs="12" md="2"><MudSelect T="string" @bind-Value="newStatus" Label="Status" Variant="Variant.Outlined"><MudSelectItem Value="@("Backlog")">Backlog</MudSelectItem><MudSelectItem Value="@("In Progress")">In Progress</MudSelectItem><MudSelectItem Value="@("Done")">Done</MudSelectItem></MudSelect></MudItem>
            <MudItem xs="12"><MudTextField @bind-Value="newDescription" Label="Description" Variant="Variant.Outlined" Lines="2" /></MudItem>
            <MudItem xs="12"><MudButton OnClick="Create" Variant="Variant.Filled" Color="Color.Primary">Add Feature</MudButton></MudItem>
        </MudGrid>
    </MudPaper>

    <MudPaper Class="pa-3" Outlined="true">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudText Typo="Typo.subtitle2">Filter Entity</MudText>
            <MudSelect T="string" @bind-Value="entityFilter" Dense="true" Variant="Variant.Outlined">
                <MudSelectItem Value="@("All")">All</MudSelectItem>
                @foreach (var e in entityOptions)
                {
                    <MudSelectItem Value="@e">@e</MudSelectItem>
                }
            </MudSelect>
        </MudStack>
    </MudPaper>

    @if (!string.IsNullOrWhiteSpace(error))
    {
        <MudAlert Severity="Severity.Error">@error</MudAlert>
    }

    <MudGrid>
        @foreach (var col in Columns)
        {
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-3" Outlined="true" Style="min-height: 300px;">
                    <MudText Typo="Typo.h6">@col</MudText>
                    <MudDivider Class="mb-2" />

                    @foreach (var card in rows.Where(r => r.Status == col && EntityMatches(r)).OrderBy(r => r.SortOrder).ThenBy(r => r.FeatureRequestId))
                    {
                        <MudPaper Class="pa-3 mb-2" Outlined="true">
                            <MudText Typo="Typo.subtitle1">@card.Title</MudText>
                            @if (!string.IsNullOrWhiteSpace(card.Description))
                            {
                                <MudText Typo="Typo.body2" Class="mb-1">@card.Description</MudText>
                            }
                            <MudText Typo="Typo.caption">Entity: @(card.Entity ?? "—") · Priority: @(card.Priority ?? "—") · Requested by: @(card.RequestedBy ?? "—")</MudText>
                            <MudStack Row="true" Spacing="1" Class="mt-2" AlignItems="AlignItems.Center">
                                <MudSelect T="string" Value="@card.Status" ValueChanged="@(v => Move(card, v))" Dense="true" Variant="Variant.Outlined">
                                    <MudSelectItem Value="@("Backlog")">Backlog</MudSelectItem>
                                    <MudSelectItem Value="@("In Progress")">In Progress</MudSelectItem>
                                    <MudSelectItem Value="@("Done")">Done</MudSelectItem>
                                </MudSelect>
                                <MudSelect T="string" Value="@(card.Entity ?? "General")" ValueChanged="@(v => UpdateEntity(card, v))" Dense="true" Variant="Variant.Outlined">
                                    @foreach (var e in entitySelectOptions)
                                    {
                                        <MudSelectItem Value="@e">@e</MudSelectItem>
                                    }
                                </MudSelect>
                                <MudSelect T="string" Value="@(card.Priority ?? "Medium")" ValueChanged="@(v => UpdatePriority(card, v))" Dense="true" Variant="Variant.Outlined">
                                    @foreach (var p in priorityOptions)
                                    {
                                        <MudSelectItem Value="@p">@p</MudSelectItem>
                                    }
                                </MudSelect>
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => Delete(card))" />
                            </MudStack>
                        </MudPaper>
                    }
                </MudPaper>
            </MudItem>
        }
    </MudGrid>
</MudStack>

@code {
    private static readonly string[] Columns = ["Backlog", "In Progress", "Done"];
    private List<FeatureCard> rows = new();
    private string? error;

    private string newTitle = string.Empty;
    private string? newDescription;
    private string newStatus = "Backlog";
    private string newPriority = "Medium";
    private string? newRequestedBy;
    private string newEntity = "Creature";
    private string entityFilter = "All";

    private static readonly string[] baseEntityOptions = ["Creature", "Item", "Campaign", "Auth", "Admin", "UI", "API", "Ops", "General"];
    private static readonly string[] priorityOptions = ["Low", "Medium", "High", "Critical"];
    private IEnumerable<string> entityOptions => rows.Select(r => r.Entity).Where(x => !string.IsNullOrWhiteSpace(x)).Select(x => x!).Distinct().OrderBy(x => x);
    private IEnumerable<string> entitySelectOptions => baseEntityOptions.Concat(entityOptions).Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(x => x);
    private bool EntityMatches(FeatureCard r) => entityFilter == "All" || string.Equals(r.Entity ?? string.Empty, entityFilter, StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        error = null;
        try { rows = await JS.InvokeAsync<List<FeatureCard>>("ruleforgeAuth.featureKanbanList") ?? new(); } catch (Exception ex) { error = ex.Message; rows = new(); }
    }

    private async Task Create()
    {
        error = null;
        if (string.IsNullOrWhiteSpace(newTitle)) { error = "Title is required."; return; }

        try { await JS.InvokeAsync<object>("ruleforgeAuth.featureKanbanCreate", new UpsertFeature(newTitle, newDescription, newStatus, newPriority, newRequestedBy, newEntity, rows.Count + 1)); } catch (Exception ex) { error = ex.Message; return; }

        newTitle = string.Empty;
        newDescription = null;
        newPriority = "Medium";
        newRequestedBy = null;
        newEntity = "Creature";
        newStatus = "Backlog";
        await Load();
    }

    private async Task Move(FeatureCard card, string status)
    {
        try { await JS.InvokeAsync<object>("ruleforgeAuth.featureKanbanUpdate", card.FeatureRequestId, new UpsertFeature(card.Title, card.Description, status, card.Priority, card.RequestedBy, card.Entity, card.SortOrder)); } catch (Exception ex) { error = ex.Message; return; }
        await Load();
    }


    private async Task UpdateEntity(FeatureCard card, string entity)
    {
        try { await JS.InvokeAsync<object>("ruleforgeAuth.featureKanbanUpdate", card.FeatureRequestId, new UpsertFeature(card.Title, card.Description, card.Status, card.Priority, card.RequestedBy, entity, card.SortOrder)); }
        catch (Exception ex) { error = ex.Message; return; }
        await Load();
    }

    private async Task UpdatePriority(FeatureCard card, string priority)
    {
        try { await JS.InvokeAsync<object>("ruleforgeAuth.featureKanbanUpdate", card.FeatureRequestId, new UpsertFeature(card.Title, card.Description, card.Status, priority, card.RequestedBy, card.Entity, card.SortOrder)); }
        catch (Exception ex) { error = ex.Message; return; }
        await Load();
    }

    private async Task Delete(FeatureCard card)
    {
        try { await JS.InvokeAsync<object>("ruleforgeAuth.featureKanbanDelete", card.FeatureRequestId); } catch (Exception ex) { error = ex.Message; return; }
        await Load();
    }

    private sealed record FeatureCard(int FeatureRequestId, string Title, string? Description, string Status, string? Priority, string? RequestedBy, string? Entity, int SortOrder, DateTime DateCreatedUtc, DateTime DateModifiedUtc);
    private sealed record UpsertFeature(string Title, string? Description, string? Status, string? Priority, string? RequestedBy, string? Entity, int? SortOrder);
}
