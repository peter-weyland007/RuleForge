@using Microsoft.AspNetCore.Components.Authorization
@page "/campaigns"
@inject IJSRuntime JS

<PageTitle>Campaigns</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Campaigns</MudText>
        <AuthorizeView Context="auth"><Authorized><MudButton Href="/campaigns/new" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add">New Campaign</MudButton></Authorized></AuthorizeView>
    </MudStack>

    @if (!string.IsNullOrWhiteSpace(error))
    {
        <MudAlert Severity="Severity.Error">@error</MudAlert>
    }

    <MudTable Items="rows" Dense="true" Hover="true">
        <HeaderContent>
            <MudTh>Title</MudTh>
            <MudTh>Description</MudTh><MudTh>Owner</MudTh><MudTh>Collaborators</MudTh><MudTh>Players</MudTh>
            <AuthorizeView Context="auth"><Authorized><MudTh></MudTh></Authorized></AuthorizeView>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Title</MudTd>
            <MudTd>@context.Description</MudTd>
            <MudTd>@if (!string.IsNullOrWhiteSpace(context.OwnerUsername)) { <MudLink Href="@($"/users/{context.OwnerUsername}")">@context.OwnerUsername</MudLink> } else { <MudText Typo="Typo.caption">(none)</MudText> }</MudTd>
            <MudTd>@context.CollaboratorCount</MudTd>
            <MudTd>@context.PlayerCount</MudTd>
            <AuthorizeView Context="auth"><Authorized><MudTd>
                <MudIconButton Href="@($"/campaigns/{context.CampaignId}/edit")" Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" />
            </MudTd></Authorized></AuthorizeView>
        </RowTemplate>
    </MudTable>
</MudStack>

@code {
    private List<CampaignDto> rows = new();
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            rows = await JS.InvokeAsync<List<CampaignDto>>("ruleforgeAuth.campaignsList") ?? new();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private sealed record CampaignDto(int CampaignId, string Title, string? Description, int? OwnerAppUserId, string? OwnerUsername, int CollaboratorCount, int PlayerCount);
}
