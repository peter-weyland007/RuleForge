@page "/campaigns"
@inject IHttpClientFactory HttpFactory
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Campaigns</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h4">Campaigns</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Manage campaign titles and descriptions.</MudText>
        </MudStack>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreate">Add Campaign</MudButton>
    </MudStack>

    @if (!string.IsNullOrWhiteSpace(error))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@error</MudAlert>
    }

    <MudTable Items="rows" Dense="true" Hover="true" Outlined="true" Elevation="0">
        <HeaderContent>
            <MudTh>Title</MudTh>
            <MudTh>Description</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Name</MudTd>
            <MudTd>@(string.IsNullOrWhiteSpace(context.Description) ? "—" : context.Description)</MudTd>
            <MudTd Style="text-align: right; white-space: nowrap;">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" OnClick="() => OpenEdit(context.CampaignId)" />
                <MudIconButton Icon="@Icons.Material.Filled.GroupAdd" Color="Color.Info" Size="Size.Small" OnClick="() => OpenShare(context.CampaignId)" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="() => Delete(context.CampaignId)" />
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Typo="Typo.body2" Class="pa-4">No campaigns yet. Add your first one.</MudText>
        </NoRecordsContent>
    </MudTable>


    @if (isShare)
    {
        <MudPaper Class="pa-4" Outlined="true" Elevation="0">
            <MudStack Spacing="2">
                <MudText Typo="Typo.h6">Share Campaign</MudText>
                <MudSelect T="int?" @bind-Value="shareUserId" Label="Friend" Variant="Variant.Outlined">
                    @foreach (var f in friends)
                    {
                        <MudSelectItem T="int?" Value="f.AppUserId">@f.Username</MudSelectItem>
                    }
                </MudSelect>
                <MudSelect T="int" @bind-Value="sharePermission" Label="Permission" Variant="Variant.Outlined">
                    <MudSelectItem Value="0">View</MudSelectItem>
                    <MudSelectItem Value="1">Edit</MudSelectItem>
                </MudSelect>
                <MudStack Row="true" Spacing="1">
                    <MudButton Variant="Variant.Filled" Color="Color.Info" OnClick="SaveShare">Share</MudButton>
                    <MudButton Variant="Variant.Outlined" OnClick="() => isShare = false">Cancel</MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>
    }

    @if (isCreate)
    {
        <MudPaper Class="pa-4" Outlined="true" Elevation="0">
            <MudStack Spacing="2">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                    <MudText Typo="Typo.h6">@(form.CampaignId.HasValue ? "Edit Campaign" : "Create Campaign")</MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text">Campaign</MudChip>
                </MudStack>

                <MudDivider />

                <MudTextField @bind-Value="form.Name" Label="Title" Placeholder="e.g., Curse of the Crimson Moon" Variant="Variant.Outlined" Required="true" />
                <MudTextField @bind-Value="form.Description" Label="Description" Placeholder="Campaign summary, tone, themes, house rules..." Variant="Variant.Outlined" Lines="4" />

                <MudStack Row="true" Spacing="1" Class="mt-3">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="Save">Save</MudButton>
                    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Close" OnClick="CloseCreate">Cancel</MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>
    }
</MudStack>

@code {
    private List<CampaignRow> rows = new();
    private string? error;
    private bool isShare;
    private int? shareId;
    private int? shareUserId;
    private int sharePermission;
    private List<FriendUser> friends = new();
    private bool isCreate;
    private CampaignForm form = new();

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        try
        {
            error = null;
            var r1 = await JS.InvokeAsync<ApiResult<List<CampaignRow>>>("ruleforgeApi.get", "/api/campaigns");
            var fr = await JS.InvokeAsync<ApiResult<FriendsOverview>>("ruleforgeApi.get", "/api/friends");
            if (!r1.Ok) { error = string.IsNullOrWhiteSpace(r1.Text) ? "Failed to load campaigns." : r1.Text; rows = new(); return; }
            rows = r1.Data ?? new();
            friends = fr.Data?.Friends ?? new();
        }
        catch (Exception ex)
        {
            error = ex.Message;
            rows = new();
        }
    }

    private void OpenCreate()
    {
        form = new CampaignForm();
        isCreate = true;
    }

    private async Task OpenEdit(int campaignId)
    {
        try
        {
            error = null;
            var res = await JS.InvokeAsync<ApiResult<CampaignRow>>("ruleforgeApi.get", $"/api/campaigns/{campaignId}");
            var row = res.Data;
            if (!res.Ok || row is null)
            {
                error = string.IsNullOrWhiteSpace(res.Text) ? "Campaign not found." : res.Text;
                return;
            }

            form = new CampaignForm
            {
                CampaignId = row.CampaignId,
                Name = row.Name,
                Description = row.Description
            };
            isCreate = true;
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private async Task Delete(int campaignId)
    {
        try
        {
            var ok = await JS.InvokeAsync<bool>("confirm", "Delete this campaign?");
            if (!ok) return;

            error = null;
            var res = await JS.InvokeAsync<ApiResult<object>>("ruleforgeApi.delete", $"/api/campaigns/{campaignId}");
            if (!res.Ok)
            {
                error = string.IsNullOrWhiteSpace(res.Text) ? "Delete failed." : res.Text;
                return;
            }

            await Load();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private void CloseCreate() => isCreate = false;

    private void OpenShare(int id) { shareId = id; shareUserId = null; sharePermission = 0; isShare = true; }
    private async Task SaveShare()
    {
        if (!shareId.HasValue || !shareUserId.HasValue) { error = "Pick a friend to share with."; return; }
        var r = await JS.InvokeAsync<ApiResult<object>>("ruleforgeApi.post", $"/api/campaigns/{shareId.Value}/share", new { userId = shareUserId.Value, permission = sharePermission });
        if (!r.Ok) { error = string.IsNullOrWhiteSpace(r.Text) ? "Share failed." : r.Text; return; }
        isShare = false;
    }

    private async Task Save()
    {
        try
        {
            error = null;
            var req = new
            {
                name = form.Name,
                description = form.Description
            };

            ApiResult<object> res;
            if (form.CampaignId.HasValue)
                res = await JS.InvokeAsync<ApiResult<object>>("ruleforgeApi.put", $"/api/campaigns/{form.CampaignId.Value}", req);
            else
                res = await JS.InvokeAsync<ApiResult<object>>("ruleforgeApi.post", "/api/campaigns", req);

            if (!res.Ok)
            {
                error = string.IsNullOrWhiteSpace(res.Text) ? "Save failed." : res.Text;
                return;
            }

            isCreate = false;
            await Load();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private sealed class CampaignForm
    {
        public int? CampaignId { get; set; }
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
    }

    private sealed record CampaignRow(int CampaignId, string Name, string? Description);
    private sealed class ApiResult<T> { public bool Ok { get; set; } public int Status { get; set; } public T? Data { get; set; } public string? Text { get; set; } }
    private sealed record FriendUser(int AppUserId, string Username, string Email);
    private sealed record FriendsOverview(List<FriendUser> Friends);
}
