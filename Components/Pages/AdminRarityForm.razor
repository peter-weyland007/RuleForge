@page "/admin/rarities/new"
@page "/admin/rarities/{RarityDefinitionId:int}/edit"
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Admin Rarity Form</PageTitle>

<MudStack Spacing="3">
    <MudText Typo="Typo.h4">@(_isEdit ? "Edit Rarity" : "Create Rarity")</MudText>
    <MudPaper Class="pa-4" Outlined="true">
        <MudGrid>
            <MudItem xs="12" md="4"><MudSelect T="int" @bind-Value="model.GameSystemId" Label="Game System" Variant="Variant.Outlined">@foreach (var gs in systems){<MudSelectItem Value="@gs.GameSystemId">@gs.Name</MudSelectItem>}</MudSelect></MudItem>
            <MudItem xs="12" md="4"><MudTextField @bind-Value="model.Name" Label="Name" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" md="4"><MudTextField @bind-Value="model.Description" Label="Description" Variant="Variant.Outlined" /></MudItem>
                        <MudItem xs="12">
                <MudStack Row="true" Spacing="2">
                    <MudButtonGroup Variant="Variant.Filled" Color="Color.Primary">
                        <MudButton OnClick="Save">Save</MudButton>
                        <MudButton Href="/admin/rarities" Color="Color.Secondary">Cancel</MudButton>
                    </MudButtonGroup>
                </MudStack>
            </MudItem>
        </MudGrid>
    </MudPaper>
</MudStack>

@code {
    [Parameter] public int? RarityDefinitionId { get; set; }
    private bool _isEdit => RarityDefinitionId.HasValue;
    private List<GameSystemDto> systems = new();
    private FormModel model = new();

    protected override async Task OnInitializedAsync()
    {
        systems = await Http.GetFromJsonAsync<List<GameSystemDto>>("/api/game-systems") ?? new();
        model.GameSystemId = systems.FirstOrDefault()?.GameSystemId ?? 0;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!_isEdit) return;
        var dto = await Http.GetFromJsonAsync<RarityDto>(Nav.ToAbsoluteUri($"/api/admin/rarities/{RarityDefinitionId!.Value}"));
        if (dto is null) { Nav.NavigateTo("/admin/rarities"); return; }
        model = new FormModel { GameSystemId = dto.GameSystemId, Name = dto.Name, Description = dto.Description };
    }

    private async Task Save()
    {
        if (model.GameSystemId <= 0 || string.IsNullOrWhiteSpace(model.Name)) return;
        var req = new UpsertRarityRequest(model.GameSystemId, model.Name, model.Description);
        HttpResponseMessage res = _isEdit
            ? await Http.PutAsJsonAsync(Nav.ToAbsoluteUri($"/api/admin/rarities/{RarityDefinitionId!.Value}"), req)
            : await Http.PostAsJsonAsync(Nav.ToAbsoluteUri("/api/admin/rarities"), req);
        if (res.IsSuccessStatusCode) Nav.NavigateTo("/admin/rarities");
    }

    private sealed class FormModel { public int GameSystemId { get; set; } public string Name { get; set; } = string.Empty; public string? Description { get; set; } }
    private sealed record GameSystemDto(int GameSystemId, string Name);
    private sealed record RarityDto(int RarityDefinitionId, int GameSystemId, string Name, string Slug, string? Description);
}
