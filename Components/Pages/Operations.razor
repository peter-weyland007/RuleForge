@page "/settings/operations"

<PageTitle>Operations</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Operations</MudText>
        <MudButton Variant="Variant.Outlined" Href="/settings" StartIcon="@Icons.Material.Filled.ArrowBack">Back to Settings</MudButton>
    </MudStack>

    <MudGrid>
        <MudItem xs="12" md="6">
            <MudPaper Class="pa-4" Outlined="true" Elevation="0">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.h6">Hard Delete Cleanup</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Permanently remove soft-deleted records from the database.</MudText>
                    <MudButton Href="/settings/operations/hard-delete" Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Filled.DeleteForever">Open Cleanup Tool</MudButton>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudStack>
