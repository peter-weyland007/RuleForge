@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@page "/bestiary"

<style>
    .movement-grid {
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        gap: 16px;
    }

    .rf-statblock {
        background:
            radial-gradient(circle at top left, rgba(255,255,255,0.65), transparent 28%),
            radial-gradient(circle at bottom right, rgba(120,72,28,0.08), transparent 30%),
            linear-gradient(180deg, #f8f1dd 0%, #f3e7c7 100%);
        border: 2px solid #2f2418;
        box-shadow: inset 0 0 0 1px rgba(117, 73, 34, 0.22);
        padding: 18px;
        color: #2a2018;
        font-family: Georgia, "Times New Roman", serif;
    }

    .rf-statblock-header {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        align-items: flex-start;
        border-bottom: 4px solid #9f2d20;
        padding-bottom: 10px;
        margin-bottom: 14px;
    }

    .rf-statblock-name {
        font-size: 2rem;
        font-weight: 700;
        letter-spacing: 0.03em;
        color: #8b2f1c;
        text-transform: uppercase;
        line-height: 1;
    }

    .rf-statblock-subtitle {
        font-style: italic;
        margin-top: 6px;
        font-size: 1rem;
    }

    .rf-statblock-meta {
        text-align: right;
        font-size: 1rem;
        white-space: nowrap;
    }

    .rf-statblock-body {
        display: grid;
        grid-template-columns: minmax(260px, 0.95fr) minmax(320px, 1.05fr);
        gap: 18px;
    }

    .rf-statblock-divider {
        border-top: 3px solid #9f2d20;
        margin: 10px 0 12px;
    }

    .rf-statblock-line {
        margin: 3px 0;
        font-size: 1.02rem;
    }

    .rf-statblock-line strong {
        color: #5e180f;
    }

    .rf-ability-grid {
        display: grid;
        grid-template-columns: repeat(6, minmax(0, 1fr));
        gap: 8px;
        text-align: center;
    }

    .rf-ability-cell {
        padding: 6px 2px;
    }

    .rf-ability-label {
        font-weight: 700;
        color: #5e180f;
        letter-spacing: 0.04em;
    }

    .rf-section-title {
        color: #8b2f1c;
        font-size: 1.15rem;
        font-weight: 700;
        border-bottom: 1px solid rgba(139, 47, 28, 0.55);
        padding-bottom: 4px;
        margin-bottom: 10px;
    }

    .rf-entry {
        margin-bottom: 12px;
        line-height: 1.5;
        font-size: 1rem;
    }

    .rf-entry strong {
        font-style: italic;
        color: #2a2018;
    }

    .rf-description-block {
        margin-top: 18px;
    }

    .rf-description-title {
        font-size: 1.6rem;
        font-weight: 700;
        margin-bottom: 10px;
        color: #201712;
    }

    .rf-modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(20, 16, 12, 0.52);
        z-index: 1400;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
    }

    .rf-modal-shell {
        width: min(1120px, 100%);
        max-height: calc(100vh - 48px);
        overflow: auto;
        background: #fff;
        border-radius: 6px;
        box-shadow: 0 16px 48px rgba(0, 0, 0, 0.28);
        padding: 24px;
    }

    .rf-modal-titlebar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        margin-bottom: 18px;
    }

    .rf-modal-actions {
        display: flex;
        justify-content: flex-end;
        gap: 8px;
        margin-top: 20px;
    }

    @@media (max-width: 1100px) {
        .movement-grid {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .rf-statblock-body {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 700px) {
        .movement-grid {
            grid-template-columns: 1fr;
        }

        .rf-statblock-header {
            flex-direction: column;
        }

        .rf-statblock-meta {
            text-align: left;
            white-space: normal;
        }

        .rf-ability-grid {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }
    }
</style>
@inject IHttpClientFactory HttpFactory
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Bestiary</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h4">Bestiary</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Manage creatures for your worlds and encounters.</MudText>
        </MudStack>
        @if (isAuthenticated)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreate">Add Creature</MudButton>
        }
    </MudStack>

    <ApiErrorAlert Message="@error" />

    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="flex-wrap">
        <MudChip T="string" Color="@(scopeFilter==CreatureScopeFilter.All ? Color.Primary : Color.Default)" Variant="Variant.Outlined" OnClick="() => SetScope(CreatureScopeFilter.All)">All</MudChip>
        <MudChip T="string" Color="@(scopeFilter==CreatureScopeFilter.Official ? Color.Primary : Color.Default)" Variant="Variant.Outlined" OnClick="() => SetScope(CreatureScopeFilter.Official)">Official</MudChip>
        @if (isAuthenticated)
        {
            <MudChip T="string" Color="@(scopeFilter==CreatureScopeFilter.MyVault ? Color.Primary : Color.Default)" Variant="Variant.Outlined" OnClick="() => SetScope(CreatureScopeFilter.MyVault)">My Vault</MudChip>
            <MudChip T="string" Color="@(scopeFilter==CreatureScopeFilter.Shared ? Color.Primary : Color.Default)" Variant="Variant.Outlined" OnClick="() => SetScope(CreatureScopeFilter.Shared)">Shared</MudChip>
        }
        @if (isAdmin)
        {
            <MudSwitch T="bool" Value="showAllAdmin" ValueChanged="OnShowAllChanged" Color="Color.Info" Label="Show All (Admin)" Class="ml-2" />
        }
    </MudStack>

    <MudGrid>
        <MudItem xs="12" md="4">
            <MudTextField @bind-Value="searchText" Label="Search" Placeholder="Name, owner, type, subtype, CR..." Variant="Variant.Outlined" Immediate="true" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Clearable="true" />
        </MudItem>
        <MudItem xs="12" md="4">
            <MudSelect T="string" @bind-Value="typeFilter" Label="Type Filter" Variant="Variant.Outlined">
                <MudSelectItem T="string" Value="@string.Empty">All types</MudSelectItem>
                @foreach (var type in rows.Select(x => x.CreatureType).Where(x => !string.IsNullOrWhiteSpace(x)).Distinct().OrderBy(x => x))
                {
                    <MudSelectItem T="string" Value="@type">@type</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="4">
            <MudSelect T="string" @bind-Value="subtypeFilter" Label="Subtype Filter" Variant="Variant.Outlined">
                <MudSelectItem T="string" Value="@string.Empty">All subtypes</MudSelectItem>
                @foreach (var subtype in rows.SelectMany(x => x.CreatureSubtypes ?? new()).Where(x => !string.IsNullOrWhiteSpace(x)).Distinct().OrderBy(x => x))
                {
                    <MudSelectItem T="string" Value="@subtype">@subtype</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
    </MudGrid>

    <MudTable Items="FilteredRows()" Dense="true" Hover="true" Outlined="true" Elevation="0">
        <HeaderContent>
            <MudTh><MudButton Variant="Variant.Text" Color="Color.Default" OnClick='() => SetSort(BestiarySortColumn.Name)'>Name @SortIndicator(BestiarySortColumn.Name)</MudButton></MudTh>
            <MudTh Style="text-align: center;"><MudButton Variant="Variant.Text" Color="Color.Default" OnClick='() => SetSort(BestiarySortColumn.Owner)'>Owner @SortIndicator(BestiarySortColumn.Owner)</MudButton></MudTh>
            <MudTh Style="text-align: center;"><MudButton Variant="Variant.Text" Color="Color.Default" OnClick='() => SetSort(BestiarySortColumn.ChallengeRating)'>CR @SortIndicator(BestiarySortColumn.ChallengeRating)</MudButton></MudTh>
            <MudTh><MudButton Variant="Variant.Text" Color="Color.Default" OnClick='() => SetSort(BestiarySortColumn.TypeSubtype)'>Type/Subtype @SortIndicator(BestiarySortColumn.TypeSubtype)</MudButton></MudTh>
            <MudTh Style="text-align: center;"><MudButton Variant="Variant.Text" Color="Color.Default" OnClick='() => SetSort(BestiarySortColumn.Size)'>Size @SortIndicator(BestiarySortColumn.Size)</MudButton></MudTh>
            <MudTh Style="text-align: center;"><MudButton Variant="Variant.Text" Color="Color.Default" OnClick='() => SetSort(BestiarySortColumn.Source)'>Source @SortIndicator(BestiarySortColumn.Source)</MudButton></MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Name</MudTd>
            <MudTd Style="text-align: center;">@DisplayOwner(context)</MudTd>
            <MudTd Style="text-align: center;">@(context.ChallengeRating ?? "—")</MudTd>
            <MudTd>@FormatTypeSubtype(context)</MudTd>
            <MudTd Style="text-align: center;">@(context.Size ?? "—")</MudTd>
            <MudTd Style="text-align: center;">@DisplaySource(context)</MudTd>
            <MudTd Style="text-align: right; white-space: nowrap;">
                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Default" Size="Size.Small" OnClick="() => OpenStatblock(context.CreatureId)" />
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" Disabled="@(!CanEdit(context))" OnClick="() => OpenEdit(context.CreatureId)" />
                <MudIconButton Icon="@Icons.Material.Filled.GroupAdd" Color="Color.Info" Size="Size.Small" Disabled="@(!CanShare(context))" OnClick="() => OpenShare(context.CreatureId)" />
                <MudIconButton Icon="@Icons.Material.Filled.Public" Color="Color.Success" Size="Size.Small" Disabled="@(!CanPublish(context))" OnClick="() => PublishCreature(context.CreatureId, context.Name)" />
                <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Color="Color.Warning" Size="Size.Small" Disabled="@(!isAuthenticated)" OnClick="() => CloneCreatureToVault(context.CreatureId)" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" Disabled="@(!CanDelete(context))" OnClick="() => Delete(context.CreatureId)" />
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Typo="Typo.body2" Class="pa-4">No creatures yet. Add your first one.</MudText>
        </NoRecordsContent>
    </MudTable>

    @if (isShare)
    {
        <MudPaper Class="pa-4" Outlined="true" Elevation="0">
            <MudStack Spacing="2">
                <MudText Typo="Typo.h6">Share Creature</MudText>
                <MudSelect T="int?" @bind-Value="shareUserId" Label="Friend" Variant="Variant.Outlined">
                    @foreach (var f in friends)
                    {
                        <MudSelectItem T="int?" Value="f.AppUserId">@f.Username</MudSelectItem>
                    }
                </MudSelect>
                <MudSelect T="int" @bind-Value="sharePermission" Label="Permission" Variant="Variant.Outlined">
                    <MudSelectItem Value="0">View</MudSelectItem>
                    <MudSelectItem Value="1">Edit</MudSelectItem>
                </MudSelect>
                <MudStack Row="true" Spacing="1">
                    <MudButton Variant="Variant.Filled" Color="Color.Info" OnClick="SaveShare">Share</MudButton>
                    <MudButton Variant="Variant.Outlined" OnClick="() => isShare = false">Cancel</MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>
    }

    @if (isStatblock && selectedCreature is not null)
    {
        <div class="rf-modal-backdrop" @onclick="CloseStatblock">
            <div class="rf-modal-shell" @onclick:stopPropagation="true">
                <div class="rf-modal-titlebar">
                    <MudText Typo="Typo.h5">@selectedCreature.Name</MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text">Statblock</MudChip>
                </div>

                <div id="creature-statblock-print">
                    <div class="rf-statblock">
                        <div class="rf-statblock-header">
                            <div>
                                <div class="rf-statblock-name">@selectedCreature.Name</div>
                                <div class="rf-statblock-subtitle">@StatblockSubtitle(selectedCreature)</div>
                            </div>
                            <div class="rf-statblock-meta">
                                <div><strong>Challenge</strong> @(selectedCreature.ChallengeRating ?? "—") @(selectedCreature.ExperiencePoints is int xp ? $"({xp} XP)" : string.Empty)</div>
                                <div><strong>Proficiency Bonus</strong> @FormatProficiencyBonus(selectedCreature.ChallengeRating)</div>
                            </div>
                        </div>

                        <div class="rf-statblock-body">
                            <div>
                                <div class="rf-statblock-line"><strong>Armor Class</strong> @FormatArmorClass(selectedCreature)</div>
                                <div class="rf-statblock-line"><strong>Hit Points</strong> @FormatHitPoints(selectedCreature)</div>
                                <div class="rf-statblock-line"><strong>Speed</strong> @FormatSpeed(selectedCreature)</div>
                                <div class="rf-statblock-divider"></div>

                                <div class="rf-ability-grid">
                                    <div class="rf-ability-cell"><div class="rf-ability-label">STR</div><div>@AbilityScoreDisplay(selectedCreature.Strength)</div></div>
                                    <div class="rf-ability-cell"><div class="rf-ability-label">DEX</div><div>@AbilityScoreDisplay(selectedCreature.Dexterity)</div></div>
                                    <div class="rf-ability-cell"><div class="rf-ability-label">CON</div><div>@AbilityScoreDisplay(selectedCreature.Constitution)</div></div>
                                    <div class="rf-ability-cell"><div class="rf-ability-label">INT</div><div>@AbilityScoreDisplay(selectedCreature.Intelligence)</div></div>
                                    <div class="rf-ability-cell"><div class="rf-ability-label">WIS</div><div>@AbilityScoreDisplay(selectedCreature.Wisdom)</div></div>
                                    <div class="rf-ability-cell"><div class="rf-ability-label">CHA</div><div>@AbilityScoreDisplay(selectedCreature.Charisma)</div></div>
                                </div>

                                <div class="rf-statblock-divider"></div>
                                <div class="rf-statblock-line"><strong>Initiative</strong> @FormatInitiative(selectedCreature)</div>
                                <div class="rf-statblock-line"><strong>Senses</strong> @FormatSenses(selectedCreature)</div>
                                <div class="rf-statblock-line"><strong>Passive Perception</strong> @(selectedCreature.PassivePerception?.ToString() ?? "—")</div>
                                <div class="rf-statblock-line"><strong>Languages</strong> @FormatLanguages(selectedCreature)</div>
                            </div>

                            <div>
                                @if (selectedCreature.Traits?.Any() == true)
                                {
                                    <div class="rf-section-title">Traits</div>
                                    @foreach (var trait in selectedCreature.Traits.OrderBy(x => x.SortOrder))
                                    {
                                        <div class="rf-entry"><strong>@trait.Name.</strong> @trait.Description</div>
                                    }
                                }

                                @if (selectedCreature.Actions?.Any() == true)
                                {
                                    <div class="rf-section-title">Actions</div>
                                    @foreach (var action in selectedCreature.Actions.OrderBy(x => x.SortOrder))
                                    {
                                        <div class="rf-entry"><strong>@action.Name.</strong> @action.Description</div>
                                    }
                                }

                                @if (selectedCreature.BonusActions?.Any() == true)
                                {
                                    <div class="rf-section-title">Bonus Actions</div>
                                    @foreach (var bonusAction in selectedCreature.BonusActions.OrderBy(x => x.SortOrder))
                                    {
                                        <div class="rf-entry"><strong>@bonusAction.Name.</strong> @bonusAction.Description</div>
                                    }
                                }

                                @if (selectedCreature.Reactions?.Any() == true)
                                {
                                    <div class="rf-section-title">Reactions</div>
                                    @foreach (var reaction in selectedCreature.Reactions.OrderBy(x => x.SortOrder))
                                    {
                                        <div class="rf-entry"><strong>@reaction.Name.</strong> @reaction.Description</div>
                                    }
                                }
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(selectedCreature.Description))
                    {
                        <div class="rf-description-block">
                            <div class="rf-description-title">Description</div>
                            <MudText Typo="Typo.body1">@selectedCreature.Description</MudText>
                        </div>
                    }
                </div>

                <div class="rf-modal-actions">
                    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Print" OnClick="PrintStatblock">Print</MudButton>
                    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Close" OnClick="CloseStatblock">Close</MudButton>
                </div>
            </div>
        </div>
    }

</MudStack>

@code {
    private List<CreatureRow> rows = new();
    private string? error;
    private bool isAuthenticated;
    private bool isAdmin;
    private bool showAllAdmin;
    private CreatureScopeFilter scopeFilter = CreatureScopeFilter.All;
    private string searchText = string.Empty;
    private string typeFilter = string.Empty;
    private string subtypeFilter = string.Empty;
    private BestiarySortColumn sortColumn = BestiarySortColumn.Name;
    private bool sortDescending;
    private string? currentUsername;
    private int? currentUserId;
    private string ShowAllQuery => (isAdmin && showAllAdmin) ? "?showAll=true" : string.Empty;
    private bool isShare;
    private int? shareCreatureId;
    private int? shareUserId;
    private int sharePermission;
    private List<FriendUser> friends = new();
    private bool isStatblock;
    private CreatureRow? selectedCreature;

    private bool _loaded;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _loaded) return;
        _loaded = true;
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        isAuthenticated = auth.User.Identity?.IsAuthenticated == true;
        isAdmin = auth.User.IsInRole("Admin");
        currentUsername = auth.User.Identity?.Name;
        var idStr = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        currentUserId = int.TryParse(idStr, out var idv) ? idv : null;
        await Load();
        StateHasChanged();
    }

    private async Task SetScope(CreatureScopeFilter value)
    {
        scopeFilter = value;
        await Load();
        StateHasChanged();
    }

    private async Task OnShowAllChanged(bool value)
    {
        showAllAdmin = value;
        await Load();
        StateHasChanged();
    }

    private async Task Load()
    {
        try
        {
            error = null;
            var r = await JS.InvokeAsync<ApiResult<List<CreatureRow>>>("ruleforgeApi.get", "/api/creatures" + ShowAllQuery);
            if (!r.Ok) { error = ApiErrorMessage(r, "Failed to load creatures."); rows = new(); return; }
            rows = ApplyScope(r.Data ?? new());

            if (isAuthenticated)
            {
                var fr = await JS.InvokeAsync<ApiResult<FriendsOverview>>("ruleforgeApi.get", "/api/friends");
                friends = fr.Data?.Friends ?? new();
            }
            else
            {
                friends = new();
                if (scopeFilter is CreatureScopeFilter.MyVault or CreatureScopeFilter.Shared)
                    scopeFilter = CreatureScopeFilter.Official;
            }
        }
        catch (Exception ex)
        {
            error = ex.Message;
            rows = new();
        }
    }

    private void OpenCreate()
    {
        Nav.NavigateTo("/bestiary/creatures/new");
    }

    private async Task OpenStatblock(int creatureId)
    {
        try
        {
            error = null;
            var res = await JS.InvokeAsync<ApiResult<CreatureRow>>("ruleforgeApi.get", $"/api/creatures/{creatureId}{ShowAllQuery}");
            var row = res.Data;
            if (!res.Ok || row is null)
            {
                error = string.IsNullOrWhiteSpace(res.Text) ? "Creature not found." : res.Text;
                return;
            }

            selectedCreature = row;
            isStatblock = true;
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private Task OpenEdit(int creatureId)
    {
        Nav.NavigateTo($"/bestiary/creatures/{creatureId}/edit");
        return Task.CompletedTask;
    }

    private static string DisplayOwner(CreatureRow row)
    {
        if (row.IsSystem || row.OwnerIsAdmin) return "System";
        if (row.IsPublic && !string.IsNullOrWhiteSpace(row.OwnerUsername)) return $"{row.OwnerUsername} • Public";
        return string.IsNullOrWhiteSpace(row.OwnerUsername) ? "—" : row.OwnerUsername;
    }

    private string DisplaySource(CreatureRow row)
    {
        if (row.IsSystem) return "Official";
        if (currentUserId.HasValue && row.OwnerAppUserId == currentUserId.Value) return "My Vault";
        if (row.IsPublic) return "Public";
        return "Shared";
    }

    private static string FormatTypeSubtype(CreatureRow row)
    {
        var type = row.CreatureType?.Trim();
        var subtype = (row.CreatureSubtypes ?? new()).FirstOrDefault(x => !string.IsNullOrWhiteSpace(x))?.Trim()
            ?? row.CreatureSubtype?.Trim();

        if (string.IsNullOrWhiteSpace(type) && string.IsNullOrWhiteSpace(subtype)) return "—";
        if (string.IsNullOrWhiteSpace(subtype)) return type ?? "—";
        if (string.IsNullOrWhiteSpace(type)) return subtype;
        return $"{type}/{subtype}";
    }

    private bool CanEdit(CreatureRow row)
    {
        if (isAdmin) return true;
        return row.UserCanEdit;
    }

    private bool CanShare(CreatureRow row)
    {
        if (row.IsSystem) return isAdmin;
        if (isAdmin) return true;
        if (string.IsNullOrWhiteSpace(currentUsername)) return false;
        return string.Equals(row.OwnerUsername, currentUsername, StringComparison.OrdinalIgnoreCase);
    }

    private void OpenShare(int id)
    {
        shareCreatureId = id;
        shareUserId = null;
        sharePermission = 0;
        isShare = true;
    }

    private async Task SaveShare()
    {
        if (!shareCreatureId.HasValue || !shareUserId.HasValue) { error = "Pick a friend to share with."; return; }
        var res = await JS.InvokeAsync<ApiResult<object>>("ruleforgeApi.post", $"/api/creatures/{shareCreatureId.Value}/share{ShowAllQuery}", new { userId = shareUserId.Value, permission = sharePermission });
        if (!res.Ok) { error = ApiErrorMessage(res, "Share failed."); return; }
        isShare = false;
    }

    private bool CanPublish(CreatureRow row)
    {
        if (isAdmin) return true;
        return !row.IsSystem;
    }

    private bool CanDelete(CreatureRow row)
    {
        if (isAdmin) return true;
        if (row.IsSystem) return false;
        if (string.IsNullOrWhiteSpace(currentUsername)) return false;
        return string.Equals(row.OwnerUsername, currentUsername, StringComparison.OrdinalIgnoreCase);
    }

    private async Task CloneCreatureToVault(int id)
    {
        var res = await JS.InvokeAsync<ApiResult<object>>("ruleforgeApi.post", $"/api/creatures/{id}/clone", new { });
        if (!res.Ok) { error = ApiErrorMessage(res, "Clone failed."); return; }
        await Load();
    }

    private async Task PublishCreature(int creatureId, string name)
    {
        var title = await JS.InvokeAsync<string?>("prompt", "Marketplace title:", name);
        if (string.IsNullOrWhiteSpace(title)) return;
        var summary = await JS.InvokeAsync<string?>("prompt", "Summary (optional):", "");
        var tags = await JS.InvokeAsync<string?>("prompt", "Tags comma-separated (optional):", "");
        var req = new { assetType = 2, sourceEntityId = creatureId, title = title, summary = summary, tags = string.IsNullOrWhiteSpace(tags) ? null : tags.Split(',').Select(x => x.Trim()).Where(x => x.Length > 0).ToArray() };
        var res = await JS.InvokeAsync<ApiResult<object>>("ruleforgeApi.post", "/api/marketplace/publish", req);
        if (!res.Ok) { error = ApiErrorMessage(res, "Publish failed."); return; }
    }

    private async Task Delete(int creatureId)
    {
        try
        {
            var ok = await JS.InvokeAsync<bool>("confirm", "Delete this creature?");
            if (!ok) return;

            error = null;
            var res = await JS.InvokeAsync<ApiResult<object>>("ruleforgeApi.delete", $"/api/creatures/{creatureId}{ShowAllQuery}");
            if (!res.Ok)
            {
                error = ApiErrorMessage(res, "Delete failed.");
                return;
            }

            await Load();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private async Task PrintStatblock()
    {
        try
        {
            await JS.InvokeVoidAsync("ruleforgePrintElement", "creature-statblock-print", selectedCreature?.Name ?? "Creature Statblock");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private void CloseStatblock()
    {
        isStatblock = false;
        selectedCreature = null;
    }

    private static string ApiErrorMessage<T>(ApiResult<T> res, string fallback)
    {
        if (!string.IsNullOrWhiteSpace(res.Text)) return NormalizeErrorText(res.Text!);
        var msg = ExtractMessage(res.Data);
        if (!string.IsNullOrWhiteSpace(msg)) return msg!;
        return res.Status > 0 ? $"{fallback} (HTTP {res.Status})" : fallback;
    }

    private static string NormalizeErrorText(string text)
    {
        var t = text.Trim();
        if (t.Length >= 2 && t.StartsWith(""") && t.EndsWith("""))
        {
            try { return System.Text.Json.JsonSerializer.Deserialize<string>(t) ?? t.Trim(new char[] {'"'}); } catch { return t.Trim(new char[] {'"'}); }
        }
        return t;
    }

    private static string? ExtractMessage(object? data)
    {
        if (data is null) return null;
        try
        {
            var json = System.Text.Json.JsonSerializer.Serialize(data);
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            if (doc.RootElement.ValueKind != System.Text.Json.JsonValueKind.Object) return null;
            foreach (var key in new[] { "message", "Message", "title", "error", "detail" })
            {
                if (doc.RootElement.TryGetProperty(key, out var v) && v.ValueKind == System.Text.Json.JsonValueKind.String)
                    return v.GetString();
            }
        }
        catch { }
        return null;
    }

    private sealed class ApiResult<T> { public bool Ok { get; set; } public int Status { get; set; } public T? Data { get; set; } public string? Text { get; set; } }

    private List<CreatureRow> ApplyScope(List<CreatureRow> src)
    {
        return scopeFilter switch
        {
            CreatureScopeFilter.Official => src.Where(x => x.IsSystem).ToList(),
            CreatureScopeFilter.MyVault => src.Where(x => !x.IsSystem && x.OwnerAppUserId.HasValue && currentUserId.HasValue && x.OwnerAppUserId == currentUserId.Value).ToList(),
            CreatureScopeFilter.Shared => src.Where(x => !x.IsSystem && !x.IsPublic && (!currentUserId.HasValue || x.OwnerAppUserId != currentUserId.Value)).ToList(),
            _ => src
        };
    }

    private IEnumerable<CreatureRow> FilteredRows()
    {
        var query = rows.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(searchText))
        {
            var term = searchText.Trim();
            query = query.Where(x => MatchesSearch(x, term));
        }

        if (!string.IsNullOrWhiteSpace(typeFilter))
            query = query.Where(x => string.Equals(x.CreatureType, typeFilter, StringComparison.OrdinalIgnoreCase));
        if (!string.IsNullOrWhiteSpace(subtypeFilter))
            query = query.Where(x => (x.CreatureSubtypes ?? new()).Any(s => string.Equals(s, subtypeFilter, StringComparison.OrdinalIgnoreCase)) || string.Equals(x.CreatureSubtype, subtypeFilter, StringComparison.OrdinalIgnoreCase));

        query = ApplySort(query);
        return query;
    }

    private void SetSort(BestiarySortColumn column)
    {
        if (sortColumn == column)
            sortDescending = !sortDescending;
        else
        {
            sortColumn = column;
            sortDescending = false;
        }
    }

    private string SortIndicator(BestiarySortColumn column)
    {
        if (sortColumn != column) return string.Empty;
        return sortDescending ? "↓" : "↑";
    }

    private IEnumerable<CreatureRow> ApplySort(IEnumerable<CreatureRow> query)
    {
        Func<CreatureRow, object?> keySelector = sortColumn switch
        {
            BestiarySortColumn.Owner => x => DisplayOwner(x),
            BestiarySortColumn.ChallengeRating => x => ChallengeRatingSortValue(x.ChallengeRating),
            BestiarySortColumn.TypeSubtype => x => FormatTypeSubtype(x),
            BestiarySortColumn.Size => x => x.Size ?? string.Empty,
            BestiarySortColumn.Source => x => DisplaySource(x),
            _ => x => x.Name
        };

        var ordered = sortDescending
            ? query.OrderByDescending(keySelector).ThenBy(x => x.Name)
            : query.OrderBy(keySelector).ThenBy(x => x.Name);

        return ordered;
    }

    private static bool MatchesSearch(CreatureRow row, string term)
    {
        if (Contains(row.Name, term)) return true;
        if (Contains(DisplayOwner(row), term)) return true;
        if (Contains(row.CreatureType, term)) return true;
        if (Contains(row.CreatureSubtype, term)) return true;
        if ((row.CreatureSubtypes ?? new()).Any(x => Contains(x, term))) return true;
        if (Contains(row.ChallengeRating, term)) return true;
        if (Contains(row.Description, term)) return true;
        if (row.ArmorClass?.ToString().Contains(term, StringComparison.OrdinalIgnoreCase) == true) return true;
        if (row.HitPoints?.ToString().Contains(term, StringComparison.OrdinalIgnoreCase) == true) return true;
        if (row.ExperiencePoints?.ToString().Contains(term, StringComparison.OrdinalIgnoreCase) == true) return true;
        return false;
    }

    private static bool Contains(string? value, string term)
        => !string.IsNullOrWhiteSpace(value) && value.Contains(term, StringComparison.OrdinalIgnoreCase);

    private static decimal ChallengeRatingSortValue(string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) return decimal.MinValue;
        var text = value.Trim();
        if (decimal.TryParse(text, out var numeric)) return numeric;
        var parts = text.Split('/', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length == 2 && decimal.TryParse(parts[0], out var numerator) && decimal.TryParse(parts[1], out var denominator) && denominator != 0)
            return numerator / denominator;
        return decimal.MinValue;
    }

    private static string FormatArmorClass(CreatureRow row)
    {
        var value = row.ArmorClass?.ToString() ?? "—";
        return string.IsNullOrWhiteSpace(row.ArmorClassNotes) ? value : $"{value} ({row.ArmorClassNotes.Trim()})";
    }

    private static string FormatHitPoints(CreatureRow row)
    {
        var value = row.HitPoints?.ToString() ?? "—";
        return string.IsNullOrWhiteSpace(row.HitDice) ? value : $"{value} ({row.HitDice.Trim()})";
    }

    private static int AbilityMod(int? score) => score.HasValue ? (int)Math.Floor((score.Value - 10) / 2.0) : 0;
    private static string ModLabel(int? score) => $"{(AbilityMod(score) >= 0 ? "+" : string.Empty)}{AbilityMod(score)}";
    private static string AbilityScoreDisplay(int? score) => score.HasValue ? $"{score.Value} ({ModLabel(score)})" : "—";
    private static string FormatInitiative(CreatureRow row)
    {
        var value = row.InitiativeModifier ?? (row.Dexterity.HasValue ? AbilityMod(row.Dexterity) : (int?)null);
        return value.HasValue ? $"{(value.Value >= 0 ? "+" : string.Empty)}{value.Value}" : "—";
    }

    private static string StatblockSubtitle(CreatureRow row)
    {
        var parts = new List<string>();
        if (!string.IsNullOrWhiteSpace(row.Size)) parts.Add(row.Size.Trim());
        if (!string.IsNullOrWhiteSpace(row.CreatureType))
        {
            var type = row.CreatureType.Trim().ToLowerInvariant();
            var subtypes = (row.CreatureSubtypes ?? new()).Where(x => !string.IsNullOrWhiteSpace(x)).Select(x => x.Trim().ToLowerInvariant()).ToList();
            if (subtypes.Count == 0 && !string.IsNullOrWhiteSpace(row.CreatureSubtype))
                subtypes.Add(row.CreatureSubtype.Trim().ToLowerInvariant());

            if (subtypes.Count > 0)
                parts.Add($"{type} ({string.Join(", ", subtypes)})");
            else
                parts.Add(type);
        }

        if (!string.IsNullOrWhiteSpace(row.Alignment))
            parts.Add(row.Alignment.Trim().ToLowerInvariant());

        if (parts.Count > 0)
            return string.Join(", ", parts);

        if (row.IsSystem) return "Official creature";
        if (row.IsPublic) return "Public creature";
        return "Private creature";
    }

    private static string FormatProficiencyBonus(string? challengeRating)
    {
        var bonus = ProficiencyBonusFromChallenge(challengeRating);
        return bonus.HasValue ? $"+{bonus.Value}" : "—";
    }

    private static int? ProficiencyBonusFromChallenge(string? challengeRating)
    {
        if (string.IsNullOrWhiteSpace(challengeRating)) return null;
        var cr = challengeRating.Trim();
        double value;
        if (cr.Contains('/'))
        {
            var parts = cr.Split('/', 2, StringSplitOptions.TrimEntries);
            if (parts.Length != 2 || !double.TryParse(parts[0], out var num) || !double.TryParse(parts[1], out var den) || den == 0)
                return null;
            value = num / den;
        }
        else if (!double.TryParse(cr, out value))
        {
            return null;
        }

        if (value <= 4) return 2;
        if (value <= 8) return 3;
        if (value <= 12) return 4;
        if (value <= 16) return 5;
        if (value <= 20) return 6;
        if (value <= 24) return 7;
        if (value <= 28) return 8;
        if (value <= 30) return 9;
        return null;
    }

    private static string FormatSpeed(CreatureRow row)
    {
        var parts = new List<string>();
        if (row.WalkSpeed.HasValue) parts.Add($"{row.WalkSpeed.Value} ft.");
        if (row.FlySpeed.HasValue) parts.Add($"fly {row.FlySpeed.Value} ft.");
        if (row.SwimSpeed.HasValue) parts.Add($"swim {row.SwimSpeed.Value} ft.");
        if (row.ClimbSpeed.HasValue) parts.Add($"climb {row.ClimbSpeed.Value} ft.");
        if (row.BurrowSpeed.HasValue) parts.Add($"burrow {row.BurrowSpeed.Value} ft.");
        if (parts.Count > 0) return string.Join(", ", parts);
        return string.IsNullOrWhiteSpace(row.Speed) ? "—" : row.Speed!;
    }

    private static string FormatSenses(CreatureRow row)
    {
        var parts = new List<string>();
        if (row.BlindsightRange.HasValue) parts.Add($"blindsight {row.BlindsightRange.Value} ft.");
        if (row.DarkvisionRange.HasValue) parts.Add($"darkvision {row.DarkvisionRange.Value} ft.");
        if (row.TremorsenseRange.HasValue) parts.Add($"tremorsense {row.TremorsenseRange.Value} ft.");
        if (row.TruesightRange.HasValue) parts.Add($"truesight {row.TruesightRange.Value} ft.");
        if (!string.IsNullOrWhiteSpace(row.OtherSenses)) parts.Add(row.OtherSenses.Trim());
        return parts.Count == 0 ? "—" : string.Join(", ", parts);
    }

    private static string FormatLanguages(CreatureRow row)
    {
        if (string.IsNullOrWhiteSpace(row.Languages))
            return row.UnderstandsButCannotSpeak ? "Understands languages but can't speak" : "—";

        return row.UnderstandsButCannotSpeak
            ? $"{row.Languages}; understands but can't speak"
            : row.Languages;
    }

