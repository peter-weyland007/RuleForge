@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@page "/bestiary"
@attribute [Authorize]
@inject IHttpClientFactory HttpFactory
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Bestiary</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h4">Bestiary</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Manage creatures for your worlds and encounters.</MudText>
        </MudStack>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreate">Add Creature</MudButton>
    </MudStack>

    <ApiErrorAlert Message="@error" />

    <MudStack Row="true" Spacing="1">
        <MudChip T="string" Color="@(scopeFilter==CreatureScopeFilter.All ? Color.Primary : Color.Default)" Variant="Variant.Outlined" OnClick="() => SetScope(CreatureScopeFilter.All)">All</MudChip>
        <MudChip T="string" Color="@(scopeFilter==CreatureScopeFilter.Official ? Color.Primary : Color.Default)" Variant="Variant.Outlined" OnClick="() => SetScope(CreatureScopeFilter.Official)">Official</MudChip>
        <MudChip T="string" Color="@(scopeFilter==CreatureScopeFilter.MyVault ? Color.Primary : Color.Default)" Variant="Variant.Outlined" OnClick="() => SetScope(CreatureScopeFilter.MyVault)">My Vault</MudChip>
        <MudChip T="string" Color="@(scopeFilter==CreatureScopeFilter.Shared ? Color.Primary : Color.Default)" Variant="Variant.Outlined" OnClick="() => SetScope(CreatureScopeFilter.Shared)">Shared</MudChip>
    </MudStack>

    <MudTable Items="rows" Dense="true" Hover="true" Outlined="true" Elevation="0">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>CR</MudTh>
            <MudTh>AC</MudTh>
            <MudTh>HP</MudTh>
            <MudTh>Init</MudTh>
            <MudTh>XP</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Name</MudTd>
            <MudTd>@(context.ChallengeRating ?? "—")</MudTd>
            <MudTd>@(context.ArmorClass?.ToString() ?? "—")</MudTd>
            <MudTd>@(context.HitPoints?.ToString() ?? "—")</MudTd>
            <MudTd>@(context.InitiativeModifier?.ToString() ?? "—")</MudTd>
            <MudTd>@(context.ExperiencePoints?.ToString() ?? "—")</MudTd>
            <MudTd Style="text-align: right; white-space: nowrap;">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" Disabled="@(!CanEdit(context))" OnClick="() => OpenEdit(context.CreatureId)" />
                <MudIconButton Icon="@Icons.Material.Filled.GroupAdd" Color="Color.Info" Size="Size.Small" Disabled="@(!CanShare(context))" OnClick="() => OpenShare(context.CreatureId)" />
                <MudIconButton Icon="@Icons.Material.Filled.Public" Color="Color.Success" Size="Size.Small" Disabled="@(!CanPublish(context))" OnClick="() => PublishCreature(context.CreatureId, context.Name)" />
                <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Color="Color.Warning" Size="Size.Small" OnClick="() => CloneCreatureToVault(context.CreatureId)" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" Disabled="@(!CanDelete(context))" OnClick="() => Delete(context.CreatureId)" />
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Typo="Typo.body2" Class="pa-4">No creatures yet. Add your first one.</MudText>
        </NoRecordsContent>
    </MudTable>

    @if (isCreate)
    {
        <MudPaper Class="pa-4" Outlined="true" Elevation="0">
            <MudStack Spacing="2">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                    <MudText Typo="Typo.h6">@(form.CreatureId.HasValue ? "Edit Creature" : "Create Creature")</MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text">Bestiary</MudChip>
                </MudStack>

                <MudDivider />

                <MudText Typo="Typo.subtitle2">Identity</MudText>
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="form.Name" Label="Name" Placeholder="e.g., Ancient Red Dragon" Variant="Variant.Outlined" Required="true" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudTextField @bind-Value="form.ChallengeRating" Label="CR" Placeholder="e.g., 5, 1/2, 21" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudNumericField T="int?" @bind-Value="form.ExperiencePoints" Label="XP" Variant="Variant.Outlined" Min="0" />
                    </MudItem>
                </MudGrid>

                <MudText Typo="Typo.subtitle2" Class="mt-2">Combat Stats</MudText>
                <MudGrid>
                    <MudItem xs="12" md="3">
                        <MudNumericField T="int?" @bind-Value="form.ArmorClass" Label="AC" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudNumericField T="int?" @bind-Value="form.HitPoints" Label="HP" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudNumericField T="int?" @bind-Value="form.InitiativeModifier" Label="Initiative Mod" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudNumericField T="int?" @bind-Value="form.PassivePerception" Label="Passive Perception" Variant="Variant.Outlined" />
                    </MudItem>
                </MudGrid>

                <MudTextField @bind-Value="form.Speed" Label="Speed" Placeholder="e.g., 30 ft., fly 60 ft." Variant="Variant.Outlined" />

                <MudText Typo="Typo.subtitle2" Class="mt-2">Ability Scores</MudText>
                <MudGrid>
                    <MudItem xs="6" md="2"><MudNumericField T="int?" @bind-Value="form.Strength" Label='@($"STR ({ModLabel(form.Strength)})")' Variant="Variant.Outlined" /></MudItem>
                    <MudItem xs="6" md="2"><MudNumericField T="int?" @bind-Value="form.Dexterity" Label='@($"DEX ({ModLabel(form.Dexterity)})")' Variant="Variant.Outlined" /></MudItem>
                    <MudItem xs="6" md="2"><MudNumericField T="int?" @bind-Value="form.Constitution" Label='@($"CON ({ModLabel(form.Constitution)})")' Variant="Variant.Outlined" /></MudItem>
                    <MudItem xs="6" md="2"><MudNumericField T="int?" @bind-Value="form.Intelligence" Label='@($"INT ({ModLabel(form.Intelligence)})")' Variant="Variant.Outlined" /></MudItem>
                    <MudItem xs="6" md="2"><MudNumericField T="int?" @bind-Value="form.Wisdom" Label='@($"WIS ({ModLabel(form.Wisdom)})")' Variant="Variant.Outlined" /></MudItem>
                    <MudItem xs="6" md="2"><MudNumericField T="int?" @bind-Value="form.Charisma" Label='@($"CHA ({ModLabel(form.Charisma)})")' Variant="Variant.Outlined" /></MudItem>
                </MudGrid>

                <MudText Typo="Typo.subtitle2" Class="mt-2">Notes</MudText>
                <MudTextField @bind-Value="form.Description" Label="Description" Placeholder="Lore, behavior, abilities, hooks..." Variant="Variant.Outlined" Lines="4" />

                <MudStack Row="true" Spacing="1" Class="mt-3">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="Save" Disabled="@isSaving">@(isSaving ? "Saving..." : "Save")</MudButton>
                    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Close" OnClick="CloseCreate">Cancel</MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>
    }
</MudStack>

@code {
    private List<CreatureRow> rows = new();
    private string? error;
    private bool isSaving;
    private bool isAdmin;
    private CreatureScopeFilter scopeFilter = CreatureScopeFilter.All;
    private string? currentUsername;
    private bool isShare;
    private int? shareCreatureId;
    private int? shareUserId;
    private int sharePermission;
    private List<FriendUser> friends = new();
    private bool isCreate;
    private CreatureForm form = new();

    private bool _loaded;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _loaded) return;
        _loaded = true;
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        isAdmin = auth.User.IsInRole("Admin");
        currentUsername = auth.User.Identity?.Name;
        var idStr = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        currentUserId = int.TryParse(idStr, out var idv) ? idv : null;
        await Load();
        StateHasChanged();
    }

    private async Task SetScope(CreatureScopeFilter value)
    {
        scopeFilter = value;
        await Load();
        StateHasChanged();
    }

    private async Task Load()
    {
        try
        {
            error = null;
            var r = await JS.InvokeAsync<ApiResult<List<CreatureRow>>>("ruleforgeApi.get", "/api/creatures");
            if (!r.Ok) { error = ApiErrorMessage(r, "Failed to load creatures."); rows = new(); return; }
            rows = ApplyScope(r.Data ?? new());
            var fr = await JS.InvokeAsync<ApiResult<FriendsOverview>>("ruleforgeApi.get", "/api/friends");
            friends = fr.Data?.Friends ?? new();
        }
        catch (Exception ex)
        {
            error = ex.Message;
            rows = new();
        }
    }

    private void OpenCreate()
    {
        form = new CreatureForm();
        isCreate = true;
    }

    private async Task OpenEdit(int creatureId)
    {
        try
        {
            error = null;
            var res = await JS.InvokeAsync<ApiResult<CreatureRow>>("ruleforgeApi.get", $"/api/creatures/{creatureId}");
            var row = res.Data;
            if (!res.Ok || row is null)
            {
                error = string.IsNullOrWhiteSpace(res.Text) ? "Creature not found." : res.Text;
                return;
            }

            form = new CreatureForm
            {
                CreatureId = row.CreatureId,
                Name = row.Name,
                Description = row.Description,
                ArmorClass = row.ArmorClass,
                HitPoints = row.HitPoints,
                InitiativeModifier = row.InitiativeModifier,
                Speed = row.Speed,
                ChallengeRating = row.ChallengeRating,
                ExperiencePoints = row.ExperiencePoints,
                PassivePerception = row.PassivePerception,
                Strength = row.Strength,
                Dexterity = row.Dexterity,
                Constitution = row.Constitution,
                Intelligence = row.Intelligence,
                Wisdom = row.Wisdom,
                Charisma = row.Charisma
            };
            isCreate = true;
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private bool CanEdit(CreatureRow row)
    {
        if (isAdmin) return true;
        if (row.IsSystem) return false;
        return true;
    }

    private bool CanShare(CreatureRow row)
    {
        if (isAdmin) return true;
        if (row.IsSystem) return false;
        return true;
    }

    private void OpenShare(int id)
    {
        shareCreatureId = id;
        shareUserId = null;
        sharePermission = 0;
        isShare = true;
    }

    private async Task SaveShare()
    {
        if (!shareCreatureId.HasValue || !shareUserId.HasValue) { error = "Pick a friend to share with."; return; }
        var res = await JS.InvokeAsync<ApiResult<object>>("ruleforgeApi.post", $"/api/creatures/{shareCreatureId.Value}/share", new { userId = shareUserId.Value, permission = sharePermission });
        if (!res.Ok) { error = ApiErrorMessage(res, "Share failed."); return; }
        isShare = false;
    }

    private bool CanPublish(CreatureRow row)
    {
        if (isAdmin) return true;
        return !row.IsSystem;
    }

    private bool CanDelete(CreatureRow row)
    {
        if (isAdmin) return true;
        return !row.IsSystem;
    }

    private async Task CloneCreatureToVault(int id)
    {
        var res = await JS.InvokeAsync<ApiResult<object>>("ruleforgeApi.post", $"/api/creatures/{id}/clone", new { });
        if (!res.Ok) { error = ApiErrorMessage(res, "Clone failed."); return; }
        await Load();
    }

    private async Task PublishCreature(int creatureId, string name)
    {
        var title = await JS.InvokeAsync<string?>("prompt", "Marketplace title:", name);
        if (string.IsNullOrWhiteSpace(title)) return;
        var summary = await JS.InvokeAsync<string?>("prompt", "Summary (optional):", "");
        var tags = await JS.InvokeAsync<string?>("prompt", "Tags comma-separated (optional):", "");
        var req = new { assetType = 2, sourceEntityId = creatureId, title = title, summary = summary, tags = string.IsNullOrWhiteSpace(tags) ? null : tags.Split(',').Select(x => x.Trim()).Where(x => x.Length > 0).ToArray() };
        var res = await JS.InvokeAsync<ApiResult<object>>("ruleforgeApi.post", "/api/marketplace/publish", req);
        if (!res.Ok) { error = ApiErrorMessage(res, "Publish failed."); return; }
    }

    private async Task Delete(int creatureId)
    {
        try
        {
            var ok = await JS.InvokeAsync<bool>("confirm", "Delete this creature?");
            if (!ok) return;

            error = null;
            var res = await JS.InvokeAsync<ApiResult<object>>("ruleforgeApi.delete", $"/api/creatures/{creatureId}");
            if (!res.Ok)
            {
                error = ApiErrorMessage(res, "Delete failed.");
                return;
            }

            await Load();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private void CloseCreate() => isCreate = false;

    private async Task Save()
    {
        if (isSaving) return;
        isSaving = true;
        try
        {
            error = null;
            var req = new
            {
                name = form.Name,
                description = form.Description,
                armorClass = form.ArmorClass,
                hitPoints = form.HitPoints,
                initiativeModifier = form.InitiativeModifier,
                speed = form.Speed,
                challengeRating = form.ChallengeRating,
                experiencePoints = form.ExperiencePoints,
                passivePerception = form.PassivePerception,
                strength = form.Strength,
                dexterity = form.Dexterity,
                constitution = form.Constitution,
                intelligence = form.Intelligence,
                wisdom = form.Wisdom,
                charisma = form.Charisma
            };

            ApiResult<object> res;
            if (form.CreatureId.HasValue)
                res = await JS.InvokeAsync<ApiResult<object>>("ruleforgeApi.put", $"/api/creatures/{form.CreatureId.Value}", req);
            else
                res = await JS.InvokeAsync<ApiResult<object>>("ruleforgeApi.post", "/api/creatures", req);

            if (!res.Ok)
            {
                error = ApiErrorMessage(res, "Save failed.");
                return;
            }

            isCreate = false;
            await Load();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private static string ApiErrorMessage<T>(ApiResult<T> res, string fallback)
    {
        if (!string.IsNullOrWhiteSpace(res.Text)) return NormalizeErrorText(res.Text!);
        var msg = ExtractMessage(res.Data);
        if (!string.IsNullOrWhiteSpace(msg)) return msg!;
        return res.Status > 0 ? $"{fallback} (HTTP {res.Status})" : fallback;
    }

    private static string NormalizeErrorText(string text)
    {
        var t = text.Trim();
        if (t.Length >= 2 && t.StartsWith(""") && t.EndsWith("""))
        {
            try { return System.Text.Json.JsonSerializer.Deserialize<string>(t) ?? t.Trim(new char[] {'"'}); } catch { return t.Trim(new char[] {'"'}); }
        }
        return t;
    }

    private static string? ExtractMessage(object? data)
    {
        if (data is null) return null;
        try
        {
            var json = System.Text.Json.JsonSerializer.Serialize(data);
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            if (doc.RootElement.ValueKind != System.Text.Json.JsonValueKind.Object) return null;
            foreach (var key in new[] { "message", "Message", "title", "error", "detail" })
            {
                if (doc.RootElement.TryGetProperty(key, out var v) && v.ValueKind == System.Text.Json.JsonValueKind.String)
                    return v.GetString();
            }
        }
        catch { }
        return null;
    }

    private sealed class ApiResult<T> { public bool Ok { get; set; } public int Status { get; set; } public T? Data { get; set; } public string? Text { get; set; } }

    private List<CreatureRow> ApplyScope(List<CreatureRow> src)
    {
        return scopeFilter switch
        {
            CreatureScopeFilter.Official => src.Where(x => x.IsSystem).ToList(),
            CreatureScopeFilter.MyVault => src.Where(x => !x.IsSystem && x.OwnerAppUserId.HasValue && x.OwnerAppUserId == currentUserId).ToList(),
            CreatureScopeFilter.Shared => src.Where(x => !x.IsSystem && (!x.OwnerAppUserId.HasValue || x.OwnerAppUserId != currentUserId)).ToList(),
            _ => src
        };
    }

    private int? currentUserId;

    private static int AbilityMod(int? score) => score.HasValue ? (int)Math.Floor((score.Value - 10) / 2.0) : 0;
    private static string ModLabel(int? score) => $"{(AbilityMod(score) >= 0 ? "+" : string.Empty)}{AbilityMod(score)}";
    private static string AbilityLabel(string abbr, int? score) => $"{abbr} ({ModLabel(score)})";

    private sealed class CreatureForm
    {
        public int? CreatureId { get; set; }
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public int? ArmorClass { get; set; }
        public int? HitPoints { get; set; }
        public int? InitiativeModifier { get; set; }
        public string? Speed { get; set; }
        public string? ChallengeRating { get; set; }
        public int? ExperiencePoints { get; set; }
        public int? PassivePerception { get; set; }
        public int? Strength { get; set; }
        public int? Dexterity { get; set; }
        public int? Constitution { get; set; }
        public int? Intelligence { get; set; }
        public int? Wisdom { get; set; }
        public int? Charisma { get; set; }
    }

    private enum CreatureScopeFilter { All, Official, MyVault, Shared }

    private record FriendUser(int AppUserId, string Username, string Email);
    private record FriendsOverview(List<FriendUser> Friends);

    private sealed record CreatureRow(
        int CreatureId,
        string Name,
        string? Description,
        int? ArmorClass,
        int? HitPoints,
        int? InitiativeModifier,
        string? Speed,
        string? ChallengeRating,
        int? ExperiencePoints,
        int? PassivePerception,
        int? Strength,
        int? Dexterity,
        int? Constitution,
        int? Intelligence,
        int? Wisdom,
        int? Charisma, bool IsSystem, int? OwnerAppUserId);
}
