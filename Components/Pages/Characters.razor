@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@page "/characters"
@attribute [Authorize]
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Characters</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h4">Characters</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Track PCs and NPCs for your campaign.</MudText>
        </MudStack>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Href="/characters/new">Add Character</MudButton>
    </MudStack>

    <ApiErrorAlert Message="@error" />

    @if (isAdmin)
    {
        <MudSwitch T="bool" Value="showAllAdmin" ValueChanged="OnShowAllChanged" Color="Color.Info" Label="Show All (Admin)" />
    }

    <MudTable Items="rows" Dense="true" Hover="true" Outlined="true" Elevation="0">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Type</MudTh>
            <MudTh>Class</MudTh>
            <MudTh>Subclass</MudTh>
            <MudTh>Race</MudTh>
            <MudTh>Subrace</MudTh>
            <MudTh>Lvl</MudTh>
            <MudTh>AC</MudTh>
            <MudTh>HP</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@DisplayName(context)</MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Color="@(context.CharacterType == 1 ? Color.Primary : Color.Secondary)" Variant="Variant.Outlined">
                    @(context.CharacterType == 1 ? "PC" : "NPC")
                </MudChip>
            </MudTd>
            <MudTd>@context.ClassName</MudTd>
            <MudTd>@context.SubclassName</MudTd>
            <MudTd>@context.RaceName</MudTd>
            <MudTd>@context.SubraceName</MudTd>
            <MudTd>@context.Level</MudTd>
            <MudTd>@context.ArmorClass</MudTd>
            <MudTd>@($"{context.HitPointsCurrent}/{context.HitPointsMax}")</MudTd>
            <MudTd Style="text-align: right; white-space: nowrap;">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" Href="@($"/characters/{context.CharacterId}/edit")" />
                <MudIconButton Icon="@Icons.Material.Filled.GroupAdd" Color="Color.Info" Size="Size.Small" OnClick="() => OpenShare(context.CharacterId)" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="() => Archive(context.CharacterId)" />
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Typo="Typo.body2" Class="pa-4">No characters yet. Add your first one.</MudText>
        </NoRecordsContent>
    </MudTable>

    @if (isShare)
    {
        <MudPaper Class="pa-4" Outlined="true" Elevation="0">
            <MudStack Spacing="2">
                <MudText Typo="Typo.h6">Share Character</MudText>
                <MudSelect T="int?" @bind-Value="shareUserId" Label="Friend" Variant="Variant.Outlined">
                    @foreach (var f in friends)
                    {
                        <MudSelectItem T="int?" Value="f.AppUserId">@f.Username</MudSelectItem>
                    }
                </MudSelect>
                <MudSelect T="int" @bind-Value="sharePermission" Label="Permission" Variant="Variant.Outlined">
                    <MudSelectItem Value="0">View</MudSelectItem>
                    <MudSelectItem Value="1">Edit</MudSelectItem>
                </MudSelect>
                <MudStack Row="true" Spacing="1">
                    <MudButton Variant="Variant.Filled" Color="Color.Info" OnClick="SaveShare">Share</MudButton>
                    <MudButton Variant="Variant.Outlined" OnClick="CloseShare">Cancel</MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>
    }
</MudStack>

@code {
    private List<CharacterRow> rows = new();
    private string? error;
    private bool isAdmin;
    private bool showAllAdmin;
    private bool isShare;
    private int? shareCharacterId;
    private int? shareUserId;
    private int sharePermission;
    private List<FriendUser> friends = new();
    private bool _loaded;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _loaded) return;
        _loaded = true;
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        isAdmin = auth.User.IsInRole("Admin");
        await Load();
        StateHasChanged();
    }

    private async Task Load()
    {
        try
        {
            error = null;
            var endpoint = showAllAdmin && isAdmin ? "/api/characters?showAll=true" : "/api/characters";
            var rowsResult = await JS.InvokeAsync<ApiResult<List<CharacterRow>>>("ruleforgeApi.get", endpoint);
            var friendsResult = await JS.InvokeAsync<ApiResult<FriendsOverview>>("ruleforgeApi.get", "/api/friends");

            if (!rowsResult.Ok)
            {
                error = ApiErrorMessage(rowsResult, "Failed to load characters.");
                rows = new();
                return;
            }

            rows = rowsResult.Data ?? new();
            friends = friendsResult.Data?.Friends ?? new();
        }
        catch (Exception ex)
        {
            error = ex.Message;
            rows = new();
            friends = new();
        }
    }

    private async Task OnShowAllChanged(bool value)
    {
        showAllAdmin = value;
        await Load();
        StateHasChanged();
    }

    private void OpenShare(int characterId)
    {
        shareCharacterId = characterId;
        shareUserId = null;
        sharePermission = 0;
        isShare = true;
    }

    private void CloseShare()
    {
        isShare = false;
        shareCharacterId = null;
        shareUserId = null;
        sharePermission = 0;
    }

    private async Task SaveShare()
    {
        if (!shareCharacterId.HasValue || !shareUserId.HasValue)
        {
            error = "Pick a friend to share with.";
            return;
        }

        var res = await JS.InvokeAsync<ApiResult<object>>("ruleforgeApi.post", $"/api/characters/{shareCharacterId.Value}/share", new { userId = shareUserId.Value, permission = sharePermission });
        if (!res.Ok)
        {
            error = ApiErrorMessage(res, "Share failed.");
            return;
        }

        CloseShare();
    }

    private async Task Archive(int characterId)
    {
        try
        {
            var ok = await JS.InvokeAsync<bool>("confirm", "Archive this character?");
            if (!ok) return;

            error = null;
            var res = await JS.InvokeAsync<ApiResult<object>>("ruleforgeApi.delete", $"/api/characters/{characterId}");
            if (!res.Ok)
            {
                error = ApiErrorMessage(res, "Archive failed.");
                return;
            }

            await Load();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private static string DisplayName(CharacterRow row) => row.CharacterType == 1 && !string.IsNullOrWhiteSpace(row.PlayerName) ? $"{row.Name} ({row.PlayerName})" : row.Name;

    private static string ApiErrorMessage<T>(ApiResult<T> res, string fallback)
    {
        if (!string.IsNullOrWhiteSpace(res.Text)) return NormalizeErrorText(res.Text!);
        if (res.Data is System.Text.Json.JsonElement el && el.ValueKind == System.Text.Json.JsonValueKind.Object)
        {
            if (el.TryGetProperty("message", out var msg) && msg.ValueKind == System.Text.Json.JsonValueKind.String)
                return msg.GetString() ?? fallback;
            if (el.TryGetProperty("Message", out var msg2) && msg2.ValueKind == System.Text.Json.JsonValueKind.String)
                return msg2.GetString() ?? fallback;
        }
        return res.Status > 0 ? $"{fallback} (HTTP {res.Status})" : fallback;
    }

    private static string NormalizeErrorText(string text)
    {
        var t = text.Trim();
        if (t.Length >= 2 && t.StartsWith("\"") && t.EndsWith("\""))
        {
            try { return System.Text.Json.JsonSerializer.Deserialize<string>(t) ?? t.Trim(new char[] { '"' }); } catch { return t.Trim(new char[] { '"' }); }
        }
        return t;
    }

    private sealed class ApiResult<T>
    {
        public bool Ok { get; set; }
        public int Status { get; set; }
        public T? Data { get; set; }
        public string? Text { get; set; }
    }

    private sealed record CharacterRow(int CharacterId, int? CampaignId, int? PartyId, int CharacterType, string Name, int? OwnerAppUserId, string? OwnerUsername, string? PlayerName, int? ArmorClass, int? HitPointsCurrent, int? HitPointsMax, int? Level, string? ClassName, string? SubclassName, string? RaceName, string? SubraceName);
    private sealed record FriendUser(int AppUserId, string Username, string Email);
    private sealed record FriendsOverview(List<FriendUser> Friends);
}
