@page "/characters"
@inject IHttpClientFactory HttpFactory
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Characters</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h4">Characters</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Track PCs and NPCs for your campaign.</MudText>
        </MudStack>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreate">Add Character</MudButton>
    </MudStack>

    @if (!string.IsNullOrWhiteSpace(error))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@error</MudAlert>
    }

    <MudTable Items="rows" Dense="true" Hover="true" Outlined="true" Elevation="0">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Type</MudTh>
            <MudTh>Class</MudTh>
            <MudTh>Lvl</MudTh>
            <MudTh>AC</MudTh>
            <MudTh>HP</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@DisplayName(context)</MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Color="@(context.CharacterType == 1 ? Color.Primary : Color.Secondary)" Variant="Variant.Outlined">
                    @(context.CharacterType == 1 ? "PC" : "NPC")
                </MudChip>
            </MudTd>
            <MudTd>@context.ClassName</MudTd>
            <MudTd>@context.Level</MudTd>
            <MudTd>@context.ArmorClass</MudTd>
            <MudTd>@($"{context.HitPointsCurrent}/{context.HitPointsMax}")</MudTd>
            <MudTd Style="text-align: right; white-space: nowrap;">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" OnClick="() => OpenEdit(context.CharacterId)" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="() => Archive(context.CharacterId)" />
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Typo="Typo.body2" Class="pa-4">No characters yet. Add your first one.</MudText>
        </NoRecordsContent>
    </MudTable>

    @if (isCreate)
    {
        <MudPaper Class="pa-4" Outlined="true" Elevation="0">
            <MudStack Spacing="2">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                    <MudText Typo="Typo.h6">@(form.CharacterId.HasValue ? "Edit Character / NPC" : "Create Character / NPC")</MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text">Quick Create</MudChip>
                </MudStack>

                <MudDivider />

                <MudText Typo="Typo.subtitle2">Identity</MudText>
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="form.Name" Label="Name" Placeholder="e.g., Sir Rowan" Variant="Variant.Outlined" Required="true" HelperText="Display name in party lists and encounter views." />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudTextField @bind-Value="form.PlayerName" Label="Player Name" Placeholder="e.g., Peter" Variant="Variant.Outlined" Disabled="@(form.CharacterType != "PC")" HelperText="Optional for now; later replaced by user account link." />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudSelect T="string" Value="form.CharacterType" ValueChanged="OnTypeChanged" Label="Type" Variant="Variant.Outlined">
                            <MudSelectItem Value="@("PC")">PC</MudSelectItem>
                            <MudSelectItem Value="@("NPC")">NPC</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudSelect T="int?" @bind-Value="form.CampaignId" Label="Campaign" Variant="Variant.Outlined" Disabled="@(!campaigns.Any())" HelperText="@(campaigns.Any() ? "Optional. Leave blank for no campaign association." : "No campaigns available yet. You can still save without one.")" Clearable="true">
                            @foreach (var campaign in campaigns)
                            {
                                <MudSelectItem T="int?" Value="campaign.CampaignId">@campaign.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudSelect T="int?" @bind-Value="form.PartyId" Label="Party" Variant="Variant.Outlined" Disabled="@(form.CharacterType != "PC" || !parties.Any())" HelperText="@(form.CharacterType != "PC" ? "Only PCs can be assigned to parties." : parties.Any() ? "Optional party assignment." : "No parties yet.")" Clearable="true">
                            @foreach (var party in parties)
                            {
                                <MudSelectItem T="int?" Value="party.PartyId">@party.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                </MudGrid>

                <MudText Typo="Typo.subtitle2" Class="mt-2">Build & Stats</MudText>
                <MudGrid>
                    <MudItem xs="12" md="3">
                        <MudNumericField T="int?" @bind-Value="form.Level" Label="Level" Variant="Variant.Outlined" Min="1" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudTextField @bind-Value="form.ClassName" Label="Class" Placeholder="e.g., Ranger" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="2">
                        <MudNumericField T="int?" @bind-Value="form.ArmorClass" Label="AC" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="2">
                        <MudNumericField T="int?" @bind-Value="form.HitPointsCurrent" Label="HP Current" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="2">
                        <MudNumericField T="int?" @bind-Value="form.HitPointsMax" Label="HP Max" Variant="Variant.Outlined" />
                    </MudItem>
                </MudGrid>

                <MudText Typo="Typo.subtitle2" Class="mt-2">Ability Scores</MudText>
                <MudGrid>
                    <MudItem xs="6" md="2"><MudNumericField T="int?" @bind-Value="form.Strength" Label="STR" Variant="Variant.Outlined" /></MudItem>
                    <MudItem xs="6" md="2"><MudNumericField T="int?" @bind-Value="form.Dexterity" Label="DEX" Variant="Variant.Outlined" /></MudItem>
                    <MudItem xs="6" md="2"><MudNumericField T="int?" @bind-Value="form.Constitution" Label="CON" Variant="Variant.Outlined" /></MudItem>
                    <MudItem xs="6" md="2"><MudNumericField T="int?" @bind-Value="form.Intelligence" Label="INT" Variant="Variant.Outlined" /></MudItem>
                    <MudItem xs="6" md="2"><MudNumericField T="int?" @bind-Value="form.Wisdom" Label="WIS" Variant="Variant.Outlined" /></MudItem>
                    <MudItem xs="6" md="2"><MudNumericField T="int?" @bind-Value="form.Charisma" Label="CHA" Variant="Variant.Outlined" /></MudItem>
                </MudGrid>

                <MudText Typo="Typo.subtitle2" Class="mt-2">Notes</MudText>
                <MudTextField @bind-Value="form.Notes" Label="Notes" Placeholder="Roleplay notes, hooks, quirks..." Variant="Variant.Outlined" Lines="3" />

                <MudStack Row="true" Spacing="1" Class="mt-3">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="Save">Save</MudButton>
                    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Close" OnClick="CloseCreate">Cancel</MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>
    }
</MudStack>

@code {
    private List<CharacterRow> rows = new();
    private List<CampaignOption> campaigns = new();
    private List<PartyOption> parties = new();
    private string? error;
    private bool isCreate;
    private CharacterForm form = new();

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        try
        {
            error = null;
            var http = HttpFactory.CreateClient();
            rows = await http.GetFromJsonAsync<List<CharacterRow>>(Nav.ToAbsoluteUri("/api/characters")) ?? new();
            campaigns = await http.GetFromJsonAsync<List<CampaignOption>>(Nav.ToAbsoluteUri("/api/campaigns")) ?? new();
            parties = await http.GetFromJsonAsync<List<PartyOption>>(Nav.ToAbsoluteUri("/api/parties")) ?? new();
        }
        catch (Exception ex)
        {
            error = ex.Message;
            rows = new();
            campaigns = new();
            parties = new();
        }
    }

    private void OpenCreate()
    {
        form = new CharacterForm { CharacterType = "PC", CampaignId = null };
        isCreate = true;
    }

    private async Task OpenEdit(int characterId)
    {
        try
        {
            error = null;
            var http = HttpFactory.CreateClient();
            var row = await http.GetFromJsonAsync<CharacterDetail>(Nav.ToAbsoluteUri($"/api/characters/{characterId}"));
            if (row is null)
            {
                error = "Character not found.";
                return;
            }

            form = new CharacterForm
            {
                CharacterId = row.CharacterId,
                CampaignId = row.CampaignId,
                PartyId = row.PartyId,
                CharacterType = row.CharacterType == 2 ? "NPC" : "PC",
                Name = row.Name,
                PlayerName = row.PlayerName,
                ArmorClass = row.ArmorClass,
                HitPointsCurrent = row.HitPointsCurrent,
                HitPointsMax = row.HitPointsMax,
                Level = row.Level,
                ClassName = row.ClassName,
                Strength = row.Strength,
                Dexterity = row.Dexterity,
                Constitution = row.Constitution,
                Intelligence = row.Intelligence,
                Wisdom = row.Wisdom,
                Charisma = row.Charisma,
                Notes = row.Notes
            };
            isCreate = true;
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }


    private async Task Archive(int characterId)
    {
        try
        {
            var ok = await JS.InvokeAsync<bool>("confirm", "Archive this character?");
            if (!ok) return;

            error = null;
            var http = HttpFactory.CreateClient();
            var res = await http.DeleteAsync(Nav.ToAbsoluteUri($"/api/characters/{characterId}"));
            if (!res.IsSuccessStatusCode)
            {
                var txt = await res.Content.ReadAsStringAsync();
                error = string.IsNullOrWhiteSpace(txt) ? "Archive failed." : txt;
                return;
            }

            await Load();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private void CloseCreate() => isCreate = false;
    private void OnTypeChanged(string v) { form.CharacterType = v; if (v != "PC") { form.PartyId = null; form.PlayerName = null; } }

    private async Task Save()
    {
        try
        {
            error = null;
            var http = HttpFactory.CreateClient();
            var req = new
            {
                campaignId = form.CampaignId,
                partyId = form.CharacterType == "PC" ? form.PartyId : null,
                characterType = form.CharacterType == "NPC" ? 2 : 1,
                name = form.Name,
                playerName = form.CharacterType == "PC" ? form.PlayerName : null,
                ownerAppUserId = (int?)null,
                armorClass = form.ArmorClass,
                hitPointsCurrent = form.HitPointsCurrent,
                hitPointsMax = form.HitPointsMax,
                level = form.Level,
                className = form.ClassName,
                strength = form.Strength,
                dexterity = form.Dexterity,
                constitution = form.Constitution,
                intelligence = form.Intelligence,
                wisdom = form.Wisdom,
                charisma = form.Charisma,
                notes = form.Notes
            };

            HttpResponseMessage res;
            if (form.CharacterId.HasValue)
            {
                res = await http.PutAsJsonAsync(Nav.ToAbsoluteUri($"/api/characters/{form.CharacterId.Value}"), req);
            }
            else
            {
                res = await http.PostAsJsonAsync(Nav.ToAbsoluteUri("/api/characters"), req);
            }

            var txt = await res.Content.ReadAsStringAsync();
            if (!res.IsSuccessStatusCode) { error = string.IsNullOrWhiteSpace(txt) ? "Save failed." : txt; return; }
            isCreate = false;
            await Load();
        }
        catch (Exception ex) { error = ex.Message; }
    }

    private static string DisplayName(CharacterRow row) => row.CharacterType == 1 && !string.IsNullOrWhiteSpace(row.PlayerName) ? $"{row.Name} ({row.PlayerName})" : row.Name;

    private sealed class CharacterForm
    {
        public int? CharacterId { get; set; }
        public int? CampaignId { get; set; }
        public int? PartyId { get; set; }
        public string CharacterType { get; set; } = "PC";
        public string Name { get; set; } = string.Empty;
        public string? PlayerName { get; set; }
        public int? ArmorClass { get; set; }
        public int? HitPointsCurrent { get; set; }
        public int? HitPointsMax { get; set; }
        public int? Level { get; set; }
        public string? ClassName { get; set; }
        public int? Strength { get; set; }
        public int? Dexterity { get; set; }
        public int? Constitution { get; set; }
        public int? Intelligence { get; set; }
        public int? Wisdom { get; set; }
        public int? Charisma { get; set; }
        public string? Notes { get; set; }
    }

    private sealed record CharacterRow(int CharacterId, int? CampaignId, int? PartyId, int CharacterType, string Name, string? PlayerName, int? ArmorClass, int? HitPointsCurrent, int? HitPointsMax, int? Level, string? ClassName);
    private sealed record CharacterDetail(int CharacterId, int? CampaignId, int? PartyId, int CharacterType, string Name, string? PlayerName, int? ArmorClass, int? HitPointsCurrent, int? HitPointsMax, int? Level, string? ClassName, int? Strength, int? Dexterity, int? Constitution, int? Intelligence, int? Wisdom, int? Charisma, string? Notes);
    private sealed record CampaignOption(int CampaignId, string Name);
    private sealed record PartyOption(int PartyId, string Name);
}
