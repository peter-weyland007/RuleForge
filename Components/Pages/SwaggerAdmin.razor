@page "/admin/swagger"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]

<PageTitle>Admin API Docs</PageTitle>

<MudStack Spacing="2">
    <MudText Typo="Typo.h4">API Docs (Swagger)</MudText>
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
        Admin-only embedded Swagger UI.
    </MudAlert>
    <div style="height: calc(100vh - 260px); border: 1px solid var(--mud-palette-lines-default); border-radius: 6px; overflow: hidden;">
        <iframe src="/swagger/index.html" style="width:100%; height:100%; border:0;"></iframe>
    </div>
</MudStack>
