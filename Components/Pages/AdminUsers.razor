@page "/admin/users"
@inject IJSRuntime JS

<PageTitle>Admin Users</PageTitle>

<MudStack Spacing="3">
    <MudText Typo="Typo.h4">Admin · Users</MudText>
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.body2">Manage user accounts and roles (Admin / Users).</MudText>
        <MudButton Href="/admin/users/new" StartIcon="@Icons.Material.Filled.Add" Color="Color.Primary" Variant="Variant.Filled">Create User</MudButton>
    </MudStack>

    @if (!string.IsNullOrWhiteSpace(error))
    {
        <MudAlert Severity="Severity.Error">@error</MudAlert>
    }

    <MudTable Items="rows" Dense="true" Hover="true">
        <HeaderContent>
            <MudTh>Email</MudTh><MudTh>Username</MudTh><MudTh>Role</MudTh><MudTh>Active</MudTh><MudTh>System</MudTh><MudTh>Must Change Password</MudTh><MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Email</MudTd>
            <MudTd>@context.Username</MudTd>
            <MudTd>@context.Role</MudTd>
            <MudTd>@(context.IsActive ? "Yes" : "No")</MudTd>
            <MudTd>@(context.IsSystemAccount ? "Yes" : "No")</MudTd>
            <MudTd>@(context.MustChangePassword ? "Yes" : "No")</MudTd>
            <MudTd><MudIconButton Href="@($"/admin/users/{context.AppUserId}/edit")" Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" /></MudTd>
        </RowTemplate>
    </MudTable>
</MudStack>

@code {
    private List<UserDto> rows = new();
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            rows = await JS.InvokeAsync<List<UserDto>>("ruleforgeAuth.adminUsers") ?? new();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private sealed record UserDto(int AppUserId, string Email, string Username, string Role, bool IsActive, bool IsSystemAccount, bool MustChangePassword);
}
