@page "/settings/logging/seq"
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.AspNetCore.Authorization
@inject IJSRuntime JS

<PageTitle>Seq Logging</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
        <MudButton Href="/settings" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack">Back to Settings</MudButton>
        <MudText Typo="Typo.h4">Seq Logging</MudText>
    </MudStack>

    <MudPaper Class="pa-4" Outlined="true" Elevation="0">
        <MudStack Spacing="2">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <div>
                    <MudText Typo="Typo.h6">Connection Settings</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Save the Seq server details RuleForge should use for structured logs, then run a test event against the saved configuration.</MudText>
                </div>
                <MudText Typo="Typo.caption" Color="Color.Info">Restart required after save for live sink reconnect</MudText>
            </MudStack>

            <ApiErrorAlert Message="@errorMessage" />
            @if (!string.IsNullOrWhiteSpace(successMessage))
            {
                <MudAlert Severity="Severity.Success" Variant="Variant.Outlined">@successMessage</MudAlert>
            }
            @if (!string.IsNullOrWhiteSpace(testMessage))
            {
                <MudAlert Severity="@(testSucceeded ? Severity.Success : Severity.Warning)" Variant="Variant.Outlined">@testMessage</MudAlert>
            }

            @if (loading)
            {
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            }
            else
            {
                <MudTextField @bind-Value="model.ServerUrl"
                              Label="Seq server URL"
                              Placeholder="http://localhost:5341"
                              HelperText="Enter the Seq base URL. Use http://localhost:5341 for a local Seq install, or https://seq.example.com for a hosted instance."
                              Variant="Variant.Outlined"
                              Immediate="true" />

                <MudTextField @bind-Value="model.AppName"
                              Label="Application name"
                              Placeholder="RuleForge"
                              HelperText="This appears as the Application property in Seq."
                              Variant="Variant.Outlined"
                              Immediate="true" />

                <MudTextField @bind-Value="model.ApiKey"
                              Label="Seq API key"
                              Placeholder="Optional"
                              HelperText="Leave blank if your Seq server does not require an API key. Enter a new value to replace the saved key."
                              Variant="Variant.Outlined"
                              Immediate="true"
                              InputType="InputType.Password" />

                @if (!string.IsNullOrWhiteSpace(localApiKeyMasked))
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">A Seq API key is already saved on this server. Leave the field blank to keep it.</MudText>
                }

                <MudDivider />

                <MudText Typo="Typo.subtitle2">Examples</MudText>
                <MudText Typo="Typo.body2">Local Seq URL: <code>@exampleLocalUrl</code></MudText>
                <MudText Typo="Typo.body2">Hosted Seq URL: <code>@exampleHostedUrl</code></MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">@notes</MudText>

                <MudStack Row="true" Spacing="2">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveSeqSettings" Disabled="busy">Save Seq Settings</MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="TestSeqSettings" Disabled="busy">Test Seq Connection</MudButton>
                    <MudButton Variant="Variant.Text" OnClick="LoadSeqSettings" Disabled="busy">Reload</MudButton>
                </MudStack>

                <MudDivider />

                <MudText Typo="Typo.subtitle2">Current effective settings</MudText>
                <MudText Typo="Typo.body2">Effective server URL: <code>@(string.IsNullOrWhiteSpace(effectiveServerUrl) ? "(not configured)" : effectiveServerUrl)</code></MudText>
                <MudText Typo="Typo.body2">Effective app name: <code>@effectiveAppName</code></MudText>
                <MudText Typo="Typo.body2">Effective API key: <code>@(string.IsNullOrWhiteSpace(effectiveApiKeyMasked) ? "(none)" : effectiveApiKeyMasked)</code></MudText>
            }
        </MudStack>
    </MudPaper>
</MudStack>

@code {
    private bool loading = true;
    private bool saving;
    private bool testing;
    private bool testSucceeded;
    private bool busy => saving || testing;
    private string? errorMessage;
    private string? successMessage;
    private string? testMessage;

    private SeqSettingsModel model = new();
    private string effectiveServerUrl = string.Empty;
    private string effectiveAppName = "RuleForge";
    private string effectiveApiKeyMasked = string.Empty;
    private string localApiKeyMasked = string.Empty;
    private string exampleLocalUrl = "http://localhost:5341";
    private string exampleHostedUrl = "https://seq.example.com";
    private string notes = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await LoadSeqSettings();
        StateHasChanged();
    }

    private async Task LoadSeqSettings()
    {
        loading = true;
        errorMessage = null;
        successMessage = null;
        testMessage = null;

        try
        {
            var result = await JS.InvokeAsync<ApiResult<SeqSettingsResponse>>("ruleforgeApi.get", "/api/admin/logging/seq");
            if (!result.Ok || result.Data is null)
            {
                errorMessage = string.IsNullOrWhiteSpace(result.Text) ? "Failed to load Seq logging settings." : result.Text;
                return;
            }

            var res = result.Data;
            model = new SeqSettingsModel
            {
                ServerUrl = res.LocalServerUrl,
                AppName = string.IsNullOrWhiteSpace(res.LocalAppName) ? res.EffectiveAppName : res.LocalAppName,
                ApiKey = string.Empty
            };

            effectiveServerUrl = res.EffectiveServerUrl;
            effectiveAppName = res.EffectiveAppName;
            effectiveApiKeyMasked = res.EffectiveApiKeyMasked;
            localApiKeyMasked = res.LocalApiKeyMasked;
            exampleLocalUrl = res.ExampleLocalUrl;
            exampleHostedUrl = res.ExampleHostedUrl;
            notes = res.Notes;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            loading = false;
        }
    }

    private async Task SaveSeqSettings()
    {
        saving = true;
        errorMessage = null;
        successMessage = null;
        testMessage = null;

        try
        {
            var payload = new SeqSettingsSaveRequest
            {
                ServerUrl = model.ServerUrl?.Trim(),
                AppName = model.AppName?.Trim(),
                ApiKey = model.ApiKey,
                ApiKeyMode = string.IsNullOrWhiteSpace(model.ApiKey) ? "keep" : "replace"
            };

            var result = await JS.InvokeAsync<ApiResult<MessageResponse>>("ruleforgeApi.post", "/api/admin/logging/seq", payload);
            if (!result.Ok)
            {
                errorMessage = string.IsNullOrWhiteSpace(result.Text) ? "Failed to save Seq settings." : result.Text;
                return;
            }

            successMessage = result.Data?.Message ?? "Seq settings saved. Restart RuleForge to apply the new logging target.";
            model.ApiKey = string.Empty;
            await LoadSeqSettings();
            successMessage = result.Data?.Message ?? successMessage;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            saving = false;
        }
    }

    private async Task TestSeqSettings()
    {
        testing = true;
        errorMessage = null;
        successMessage = null;
        testMessage = null;
        testSucceeded = false;

        try
        {
            var result = await JS.InvokeAsync<ApiResult<SeqTestResponse>>("ruleforgeApi.post", "/api/admin/logging/seq/test", new { });
            if (!result.Ok)
            {
                errorMessage = string.IsNullOrWhiteSpace(result.Text) ? "Failed to test Seq connection." : result.Text;
                return;
            }

            testSucceeded = true;
            testMessage = result.Data?.Message ?? "Seq test event sent successfully.";
            await LoadSeqSettings();
            testMessage = result.Data?.Message ?? testMessage;
            testSucceeded = true;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            testing = false;
        }
    }

    private sealed class SeqSettingsModel
    {
        public string? ServerUrl { get; set; }
        public string? AppName { get; set; }
        public string? ApiKey { get; set; }
    }

    private sealed class SeqSettingsSaveRequest
    {
        public string? ServerUrl { get; set; }
        public string? AppName { get; set; }
        public string? ApiKey { get; set; }
        public string? ApiKeyMode { get; set; }
    }

    private sealed class SeqSettingsResponse
    {
        public string EffectiveServerUrl { get; set; } = string.Empty;
        public string EffectiveApiKeyMasked { get; set; } = string.Empty;
        public string EffectiveAppName { get; set; } = "RuleForge";
        public string LocalServerUrl { get; set; } = string.Empty;
        public string LocalApiKeyMasked { get; set; } = string.Empty;
        public string LocalAppName { get; set; } = string.Empty;
        public string ExampleLocalUrl { get; set; } = "http://localhost:5341";
        public string ExampleHostedUrl { get; set; } = "https://seq.example.com";
        public string Notes { get; set; } = string.Empty;
    }

    private sealed class SeqTestResponse
    {
        public string Message { get; set; } = string.Empty;
        public string ServerUrl { get; set; } = string.Empty;
        public string AppName { get; set; } = string.Empty;
        public int StatusCode { get; set; }
    }

    private sealed class MessageResponse
    {
        public string Message { get; set; } = string.Empty;
    }

    private sealed class ApiResult<T>
    {
        public bool Ok { get; set; }
        public int Status { get; set; }
        public T? Data { get; set; }
        public string? Text { get; set; }
        public string? TraceId { get; set; }
    }
}
