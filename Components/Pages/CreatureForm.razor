@page "/creatures/new"
@page "/creatures/{CreatureId:int}/edit"
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>@(_isEdit ? "Edit Creature" : "Create Creature")</PageTitle>

<MudStack Spacing="3" Style="max-width:1100px; margin: 0 auto;">
    <MudText Typo="Typo.h4">@(_isEdit ? "Edit Creature" : "Create Creature")</MudText>

    <MudPaper Class="pa-4" Outlined="true">
        <MudGrid>
            <MudItem xs="12" md="3"><MudSelect T="int" @bind-Value="model.GameSystemId" Label="Game System" Variant="Variant.Outlined">@foreach (var s in systems){<MudSelectItem Value="@s.GameSystemId">@s.Name</MudSelectItem>}</MudSelect></MudItem>
            <MudItem xs="12" md="3"><MudTextField @bind-Value="model.Name" Label="Name" Variant="Variant.Outlined" Required="true" /></MudItem>
            <MudItem xs="12" md="2"><MudTextField @bind-Value="model.Alias" Label="Alias" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" md="2"><MudTextField @bind-Value="model.CreatureType" Label="Type" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" md="2"><MudTextField @bind-Value="model.Size" Label="Size" Variant="Variant.Outlined" /></MudItem>

            <MudItem xs="12" md="3"><MudTextField @bind-Value="model.Alignment" Label="Alignment" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" md="2"><MudNumericField T="int?" @bind-Value="model.ArmorClass" Label="Armor Class" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" md="2"><MudNumericField T="int?" @bind-Value="model.HitPoints" Label="Hit Points" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" md="2"><MudTextField @bind-Value="model.Speed" Label="Speed" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" md="3"><MudTextField @bind-Value="model.ChallengeRating" Label="Challenge Rating" Variant="Variant.Outlined" /></MudItem>

            <MudItem xs="12" md="2"><MudNumericField T="int?" @bind-Value="model.Strength" Label="STR" HelperText="@ModHint(model.Strength)" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" md="2"><MudNumericField T="int?" @bind-Value="model.Dexterity" Label="DEX" HelperText="@ModHint(model.Dexterity)" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" md="2"><MudNumericField T="int?" @bind-Value="model.Constitution" Label="CON" HelperText="@ModHint(model.Constitution)" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" md="2"><MudNumericField T="int?" @bind-Value="model.Intelligence" Label="INT" HelperText="@ModHint(model.Intelligence)" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" md="2"><MudNumericField T="int?" @bind-Value="model.Wisdom" Label="WIS" HelperText="@ModHint(model.Wisdom)" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" md="2"><MudNumericField T="int?" @bind-Value="model.Charisma" Label="CHA" HelperText="@ModHint(model.Charisma)" Variant="Variant.Outlined" /></MudItem>

            <MudItem xs="12" md="3"><MudText Typo="Typo.caption">Passive Perception (derived): <b>@PassivePerceptionPreview()</b></MudText></MudItem>

            <MudItem xs="12" md="3"><MudSelect T="SourceType" @bind-Value="model.SourceType" Label="Source Type" Variant="Variant.Outlined"><MudSelectItem Value="SourceType.Official">Official</MudSelectItem><MudSelectItem Value="SourceType.ThirdParty">Third Party</MudSelectItem><MudSelectItem Value="SourceType.Homebrew">Homebrew</MudSelectItem></MudSelect></MudItem>
            @if (model.SourceType == SourceType.Official)
            {
                <MudItem xs="12" md="6"><MudSelect T="int?" @bind-Value="model.SourceMaterialId" Label="Official Source Material" Variant="Variant.Outlined"><MudSelectItem Value="@((int?)null)">(select source)</MudSelectItem>@foreach (var sm in sourceMaterials){<MudSelectItem Value="@((int?)sm.SourceMaterialId)">@($"{sm.Code} — {sm.Title}")</MudSelectItem>}</MudSelect></MudItem>
                <MudItem xs="12" md="3"><MudNumericField T="int?" @bind-Value="model.SourcePage" Label="Source Page" Variant="Variant.Outlined" /></MudItem>
            }
            else
            {
                <MudItem xs="12" md="6"><MudSelect T="int?" @bind-Value="model.CampaignId" Label="Campaign Source" Variant="Variant.Outlined"><MudSelectItem Value="@((int?)null)">(none)</MudSelectItem>@foreach (var c in campaigns){<MudSelectItem Value="@((int?)c.CampaignId)">@c.Title</MudSelectItem>}</MudSelect></MudItem>
                <MudItem xs="12" md="3"><MudSelect T="int?" @bind-Value="model.OwnerAppUserId" Label="Owner" Variant="Variant.Outlined"><MudSelectItem Value="@((int?)null)">(auto/current user)</MudSelectItem>@foreach (var o in owners){<MudSelectItem Value="@((int?)o.AppUserId)">@($"{o.Username} ({o.Email})")</MudSelectItem>}</MudSelect></MudItem>
            }

            <MudItem xs="12"><MudTextField @bind-Value="model.Description" Label="Description" Variant="Variant.Outlined" Lines="4" /></MudItem>

            <MudItem xs="12">
                <MudText Typo="Typo.h6">Traits</MudText>
                @for (var i = 0; i < model.TraitsList.Count; i++)
                {
                    var t = model.TraitsList[i];
                    <MudGrid Class="mb-2">
                        <MudItem xs="12" md="3"><MudTextField @bind-Value="t.Name" Label="Name" Variant="Variant.Outlined" /></MudItem>
                        <MudItem xs="12" md="7"><MudTextField @bind-Value="t.Description" Label="Description" Variant="Variant.Outlined" Lines="2" /></MudItem>
                        <MudItem xs="12" md="2">
                            <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowUp" Disabled="@(i==0)" OnClick="@(() => MoveUp(model.TraitsList, i))" />
                            <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowDown" Disabled="@(i==model.TraitsList.Count-1)" OnClick="@(() => MoveDown(model.TraitsList, i))" />
                            <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" OnClick="@(() => Duplicate(model.TraitsList, i))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => RemoveAt(model.TraitsList, i))" />
                        </MudItem>
                    </MudGrid>
                }
                <MudButton Variant="Variant.Outlined" OnClick="@(() => model.TraitsList.Add(new AbilityLine()))">Add Trait</MudButton>
            </MudItem>

            <MudItem xs="12">
                <MudText Typo="Typo.h6">Actions</MudText>
                @for (var i = 0; i < model.ActionsList.Count; i++)
                {
                    var a = model.ActionsList[i];
                    <MudGrid Class="mb-2">
                        <MudItem xs="12" md="3"><MudTextField @bind-Value="a.Name" Label="Name" Variant="Variant.Outlined" /></MudItem>
                        <MudItem xs="12" md="7"><MudTextField @bind-Value="a.Description" Label="Description" Variant="Variant.Outlined" Lines="2" /></MudItem>
                        <MudItem xs="12" md="2">
                            <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowUp" Disabled="@(i==0)" OnClick="@(() => MoveUp(model.ActionsList, i))" />
                            <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowDown" Disabled="@(i==model.ActionsList.Count-1)" OnClick="@(() => MoveDown(model.ActionsList, i))" />
                            <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" OnClick="@(() => Duplicate(model.ActionsList, i))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => RemoveAt(model.ActionsList, i))" />
                        </MudItem>
                    </MudGrid>
                }
                <MudButton Variant="Variant.Outlined" OnClick="@(() => model.ActionsList.Add(new AbilityLine()))">Add Action</MudButton>
            </MudItem>

            <MudItem xs="12">
                <MudText Typo="Typo.h6">Reactions</MudText>
                @for (var i = 0; i < model.ReactionsList.Count; i++)
                {
                    var r = model.ReactionsList[i];
                    <MudGrid Class="mb-2">
                        <MudItem xs="12" md="3"><MudTextField @bind-Value="r.Name" Label="Name" Variant="Variant.Outlined" /></MudItem>
                        <MudItem xs="12" md="7"><MudTextField @bind-Value="r.Description" Label="Description" Variant="Variant.Outlined" Lines="2" /></MudItem>
                        <MudItem xs="12" md="2">
                            <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowUp" Disabled="@(i==0)" OnClick="@(() => MoveUp(model.ReactionsList, i))" />
                            <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowDown" Disabled="@(i==model.ReactionsList.Count-1)" OnClick="@(() => MoveDown(model.ReactionsList, i))" />
                            <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" OnClick="@(() => Duplicate(model.ReactionsList, i))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => RemoveAt(model.ReactionsList, i))" />
                        </MudItem>
                    </MudGrid>
                }
                <MudButton Variant="Variant.Outlined" OnClick="@(() => model.ReactionsList.Add(new AbilityLine()))">Add Reaction</MudButton>
            </MudItem>

            <MudItem xs="12">
                <MudText Typo="Typo.h6">Legendary Actions</MudText>
                @for (var i = 0; i < model.LegendaryActionsList.Count; i++)
                {
                    var l = model.LegendaryActionsList[i];
                    <MudGrid Class="mb-2">
                        <MudItem xs="12" md="3"><MudTextField @bind-Value="l.Name" Label="Name" Variant="Variant.Outlined" /></MudItem>
                        <MudItem xs="12" md="7"><MudTextField @bind-Value="l.Description" Label="Description" Variant="Variant.Outlined" Lines="2" /></MudItem>
                        <MudItem xs="12" md="2">
                            <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowUp" Disabled="@(i==0)" OnClick="@(() => MoveUp(model.LegendaryActionsList, i))" />
                            <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowDown" Disabled="@(i==model.LegendaryActionsList.Count-1)" OnClick="@(() => MoveDown(model.LegendaryActionsList, i))" />
                            <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" OnClick="@(() => Duplicate(model.LegendaryActionsList, i))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => RemoveAt(model.LegendaryActionsList, i))" />
                        </MudItem>
                    </MudGrid>
                }
                <MudButton Variant="Variant.Outlined" OnClick="@(() => model.LegendaryActionsList.Add(new AbilityLine()))">Add Legendary Action</MudButton>
            </MudItem>

            @if (!string.IsNullOrWhiteSpace(saveError))
            {
                <MudItem xs="12"><MudAlert Severity="Severity.Error">@saveError</MudAlert></MudItem>
            }

            <MudItem xs="12">
                <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd">
                    <MudButton Href="/creatures" Variant="Variant.Outlined">Cancel</MudButton>
                    <MudButton OnClick="Save" Variant="Variant.Filled" Color="Color.Primary">Save Creature</MudButton>
                </MudStack>
            </MudItem>
        </MudGrid>
    </MudPaper>
</MudStack>

@code {
    [Parameter] public int? CreatureId { get; set; }
    private bool _isEdit => CreatureId.HasValue;

    private List<GameSystemDto> systems = new();
    private List<SourceMaterialDto> sourceMaterials = new();
    private List<CampaignLiteDto> campaigns = new();
    private List<UserOwnerDto> owners = new();
    private FormModel model = new();
    private string? saveError;

    protected override async Task OnInitializedAsync()
    {
        systems = await Http.GetFromJsonAsync<List<GameSystemDto>>(Nav.ToAbsoluteUri("/api/game-systems")) ?? new();
        model.GameSystemId = systems.FirstOrDefault()?.GameSystemId ?? 0;
        await LoadLookups();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!_isEdit) return;
        var dto = await Http.GetFromJsonAsync<CreatureDto>(Nav.ToAbsoluteUri($"/api/creatures/{CreatureId!.Value}"));
        if (dto is null) { Nav.NavigateTo("/creatures"); return; }

        model = new FormModel
        {
            GameSystemId = dto.GameSystemId,
            Name = dto.Name,
            Alias = dto.Alias,
            CreatureType = dto.CreatureType,
            Size = dto.Size,
            Alignment = dto.Alignment,
            ArmorClass = dto.ArmorClass,
            HitPoints = dto.HitPoints,
            Speed = dto.Speed,
            Strength = dto.Strength,
            Dexterity = dto.Dexterity,
            Constitution = dto.Constitution,
            Intelligence = dto.Intelligence,
            Wisdom = dto.Wisdom,
            Charisma = dto.Charisma,
            ChallengeRating = dto.ChallengeRating,
            ProficiencyBonus = dto.ProficiencyBonus,
            Description = dto.Description,
            SourceType = dto.SourceType,
            OwnerAppUserId = dto.OwnerAppUserId,
            SourceMaterialId = dto.SourceMaterialId,
            CampaignId = dto.CampaignId,
            SourcePage = dto.SourcePage,
            TraitsList = dto.TraitsList?.Select(x => new AbilityLine { Name = x.Name, Description = x.Description, SortOrder = x.SortOrder }).ToList() ?? new(),
            ActionsList = dto.ActionsList?.Select(x => new AbilityLine { Name = x.Name, Description = x.Description, SortOrder = x.SortOrder }).ToList() ?? new(),
            ReactionsList = dto.ReactionsList?.Select(x => new AbilityLine { Name = x.Name, Description = x.Description, SortOrder = x.SortOrder }).ToList() ?? new(),
            LegendaryActionsList = dto.LegendaryActionsList?.Select(x => new AbilityLine { Name = x.Name, Description = x.Description, SortOrder = x.SortOrder }).ToList() ?? new()
        };
        await LoadLookups();
    }

    private async Task LoadLookups()
    {
        sourceMaterials = await Http.GetFromJsonAsync<List<SourceMaterialDto>>(Nav.ToAbsoluteUri($"/api/source-materials?gameSystemId={model.GameSystemId}")) ?? new();
        owners = await Http.GetFromJsonAsync<List<UserOwnerDto>>(Nav.ToAbsoluteUri("/api/users")) ?? new();
        try { campaigns = await JS.InvokeAsync<List<CampaignLiteDto>>("ruleforgeAuth.campaignsAccessible") ?? new(); } catch { campaigns = new(); }
    }

    private void NormalizeSourceByType()
    {
        if (model.SourceType == SourceType.Official)
        {
            model.CampaignId = null;
            model.OwnerAppUserId = null;
        }
        else
        {
            model.SourceMaterialId = null;
            model.SourcePage = null;
        }
    }


    private static int AbilityMod(int? score) => score.HasValue ? (int)Math.Floor((score.Value - 10) / 2.0) : 0;
    private static string ModText(int mod) => mod >= 0 ? $"+{mod}" : mod.ToString();
    private static string ModHint(int? score) => score.HasValue ? $"mod {ModText(AbilityMod(score))}" : "mod —";
    private string PassivePerceptionPreview()
    {
        var wis = model.Wisdom ?? 10;
        var prof = model.ProficiencyBonus ?? 0;
        var total = 10 + AbilityMod(wis) + prof;
        return $"{total} (10 + WIS {ModText(AbilityMod(wis))}{(prof != 0 ? $" + PB {prof}" : string.Empty)})";
    }

    private bool ValidateAbilityRows()
    {
        static string? ValidateList(List<AbilityLine> list, string section)
        {
            for (var i = 0; i < list.Count; i++)
            {
                var row = list[i];
                var hasAny = !string.IsNullOrWhiteSpace(row.Name) || !string.IsNullOrWhiteSpace(row.Description);
                if (!hasAny) continue;
                if (string.IsNullOrWhiteSpace(row.Description))
                    return $"{section} row {i + 1}: Description is required.";
            }
            return null;
        }

        saveError = ValidateList(model.TraitsList, "Traits")
            ?? ValidateList(model.ActionsList, "Actions")
            ?? ValidateList(model.ReactionsList, "Reactions")
            ?? ValidateList(model.LegendaryActionsList, "Legendary Actions");

        return string.IsNullOrWhiteSpace(saveError);
    }

    private async Task Save()
    {
        saveError = null;
        if (string.IsNullOrWhiteSpace(model.Name) || model.GameSystemId <= 0) return;
        if (!ValidateAbilityRows()) return;

        NormalizeSourceByType();

        var req = new
        {
            model.GameSystemId,
            model.Name,
            model.Alias,
            model.CreatureType,
            model.Size,
            model.Alignment,
            model.ArmorClass,
            model.HitPoints,
            model.Speed,
            model.Strength,
            model.Dexterity,
            model.Constitution,
            model.Intelligence,
            model.Wisdom,
            model.Charisma,
            model.ChallengeRating,
            model.ProficiencyBonus,
            model.Description,
            model.SourceType,
            model.OwnerAppUserId,
            model.SourceMaterialId,
            model.CampaignId,
            model.SourcePage,
            TraitsList = model.TraitsList.Where(x => !string.IsNullOrWhiteSpace(x.Description) || !string.IsNullOrWhiteSpace(x.Name)).Select((x, i) => new { x.Name, x.Description, SortOrder = i }).ToList(),
            ActionsList = model.ActionsList.Where(x => !string.IsNullOrWhiteSpace(x.Description) || !string.IsNullOrWhiteSpace(x.Name)).Select((x, i) => new { x.Name, x.Description, SortOrder = i }).ToList(),
            ReactionsList = model.ReactionsList.Where(x => !string.IsNullOrWhiteSpace(x.Description) || !string.IsNullOrWhiteSpace(x.Name)).Select((x, i) => new { x.Name, x.Description, SortOrder = i }).ToList(),
            LegendaryActionsList = model.LegendaryActionsList.Where(x => !string.IsNullOrWhiteSpace(x.Description) || !string.IsNullOrWhiteSpace(x.Name)).Select((x, i) => new { x.Name, x.Description, SortOrder = i }).ToList()
        };

        var res = _isEdit
            ? await Http.PutAsJsonAsync(Nav.ToAbsoluteUri($"/api/creatures/{CreatureId!.Value}"), req)
            : await Http.PostAsJsonAsync(Nav.ToAbsoluteUri("/api/creatures"), req);

        if (res.IsSuccessStatusCode)
        {
            Nav.NavigateTo("/creatures");
            return;
        }

        saveError = await res.Content.ReadAsStringAsync();
        if (string.IsNullOrWhiteSpace(saveError)) saveError = "Save failed.";
    }

    private static void MoveUp(List<AbilityLine> list, int index)
    {
        if (index <= 0 || index >= list.Count) return;
        (list[index - 1], list[index]) = (list[index], list[index - 1]);
    }

    private static void MoveDown(List<AbilityLine> list, int index)
    {
        if (index < 0 || index >= list.Count - 1) return;
        (list[index], list[index + 1]) = (list[index + 1], list[index]);
    }

    private static void Duplicate(List<AbilityLine> list, int index)
    {
        if (index < 0 || index >= list.Count) return;
        var src = list[index];
        list.Insert(index + 1, new AbilityLine { Name = src.Name, Description = src.Description, SortOrder = src.SortOrder });
    }

    private static void RemoveAt(List<AbilityLine> list, int index)
    {
        if (index < 0 || index >= list.Count) return;
        list.RemoveAt(index);
    }

    private sealed class AbilityLine { public string? Name { get; set; } public string Description { get; set; } = string.Empty; public int SortOrder { get; set; } }

    private sealed class FormModel
    {
        public int GameSystemId { get; set; }
        public string Name { get; set; } = string.Empty;
        public string? Alias { get; set; }
        public string? CreatureType { get; set; }
        public string? Size { get; set; }
        public string? Alignment { get; set; }
        public int? ArmorClass { get; set; }
        public int? HitPoints { get; set; }
        public string? Speed { get; set; }
        public int? Strength { get; set; }
        public int? Dexterity { get; set; }
        public int? Constitution { get; set; }
        public int? Intelligence { get; set; }
        public int? Wisdom { get; set; }
        public int? Charisma { get; set; }
        public string? ChallengeRating { get; set; }
        public int? ProficiencyBonus { get; set; }
        public string? Description { get; set; }
        public SourceType SourceType { get; set; } = SourceType.Official;
        public int? OwnerAppUserId { get; set; }
        public int? SourceMaterialId { get; set; }
        public int? CampaignId { get; set; }
        public int? SourcePage { get; set; }
        public List<AbilityLine> TraitsList { get; set; } = new();
        public List<AbilityLine> ActionsList { get; set; } = new();
        public List<AbilityLine> ReactionsList { get; set; } = new();
        public List<AbilityLine> LegendaryActionsList { get; set; } = new();
    }

    private sealed record GameSystemDto(int GameSystemId, string Name);
    private sealed record SourceMaterialDto(int SourceMaterialId, int GameSystemId, string Code, string Title, string? Publisher, bool IsOfficial);
    private sealed record UserOwnerDto(int AppUserId, string Username, string Email);
    private sealed record CampaignLiteDto(int CampaignId, string Title, string? Description);
    private sealed record AbilityDto(string? Name, string Description, int SortOrder);
    private sealed record CreatureDto(int CreatureId, int GameSystemId, string Name, string Slug, string? Alias, string? CreatureType, string? Size, string? Alignment, int? ArmorClass, int? HitPoints, string? Speed, int? Strength, int? Dexterity, int? Constitution, int? Intelligence, int? Wisdom, int? Charisma, string? ChallengeRating, int? ProficiencyBonus, string? Description, SourceType SourceType, int? OwnerAppUserId, int? SourceMaterialId, int? CampaignId, int? SourcePage, List<AbilityDto>? TraitsList, List<AbilityDto>? ActionsList, List<AbilityDto>? ReactionsList, List<AbilityDto>? LegendaryActionsList);
}
