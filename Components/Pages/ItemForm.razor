@page "/items/new"
@page "/items/{ItemId:int}/edit"
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Item Form</PageTitle>

<style>
    .rf-shell { max-width: 1240px; margin: 0 auto; }
    .rf-title-chip { letter-spacing: .02em; font-weight: 700; }
    .rf-section { border-left: 4px solid var(--mud-palette-primary); }
    .rf-section--economy { border-left-color: var(--mud-palette-info); }
    .rf-section--combat { border-left-color: var(--mud-palette-warning); }
    .rf-section--magic { border-left-color: var(--mud-palette-secondary); }
    .rf-section--tags { border-left-color: var(--mud-palette-success); }
</style>

<MudStack Spacing="3" Class="rf-shell">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">@(_isEdit ? "Edit Item" : "Create Item")</MudText>
        <MudChip T="string" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" Class="rf-title-chip">RuleForge Item Builder</MudChip>
    </MudStack>

    <MudPaper Class="pa-4 rf-section" Outlined="true">
        <MudText Typo="Typo.subtitle1" Class="mb-3">Identity & Classification</MudText>
        <MudGrid>
            <MudItem xs="12" md="3">
                <MudSelect T="int" Value="model.GameSystemId" ValueChanged="OnSystemChanged" Label="Game System" Variant="Variant.Outlined">
                    @foreach (var s in systems)
                    {
                        <MudSelectItem Value="@s.GameSystemId">@s.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="3"><MudTextField @bind-Value="model.Name" Label="Name" Variant="Variant.Outlined" Required="true" /></MudItem>
            <MudItem xs="12" md="2"><MudTextField @bind-Value="model.Alias" Label="Alias" Variant="Variant.Outlined" Placeholder="Optional" /></MudItem>
            <MudItem xs="12" md="2">
                <MudSelect T="int?" @bind-Value="model.ItemTypeDefinitionId" Label="Type" Variant="Variant.Outlined">
                    <MudSelectItem Value="@((int?)null)">(none)</MudSelectItem>
                    @foreach (var t in types)
                    {
                        <MudSelectItem Value="@((int?)t.ItemTypeDefinitionId)">@t.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="2">
                <MudSelect T="int?" @bind-Value="model.RarityDefinitionId" Label="Rarity" Variant="Variant.Outlined">
                    <MudSelectItem Value="@((int?)null)">(none)</MudSelectItem>
                    @foreach (var r in rarities)
                    {
                        <MudSelectItem Value="@((int?)r.RarityDefinitionId)">@r.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudPaper Class="pa-3" Outlined="true">
        <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" AlignItems="AlignItems.Center">
            <MudText Typo="Typo.caption">Active profile:</MudText>
            <MudChip T="string" Size="Size.Small" Color="@(IsWeaponType ? Color.Primary : Color.Default)" Variant="Variant.Outlined">Weapon</MudChip>
            <MudChip T="string" Size="Size.Small" Color="@(IsArmorType ? Color.Primary : Color.Default)" Variant="Variant.Outlined">Armor/Shield</MudChip>
            <MudChip T="string" Size="Size.Small" Color="@(IsConsumableType ? Color.Primary : Color.Default)" Variant="Variant.Outlined">Consumable</MudChip>
            <MudChip T="string" Size="Size.Small" Color="@(IsMagicType ? Color.Secondary : Color.Default)" Variant="Variant.Outlined">Magic</MudChip>
            @if (string.IsNullOrWhiteSpace(SelectedTypeName))
            {
                <MudText Typo="Typo.caption" Class="ml-2">Choose an item type to activate tailored statblocks.</MudText>
            }
        </MudStack>
    </MudPaper>

    <MudPaper Class="pa-4 rf-section rf-section--economy" Outlined="true">
        <MudText Typo="Typo.subtitle1" Class="mb-3">Economy & Source</MudText>
        <MudGrid>
            <MudItem xs="12" md="3"><MudNumericField T="decimal?" @bind-Value="model.CostAmount" Label="Cost" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12" md="3"><MudSelect T="int?" @bind-Value="model.CurrencyDefinitionId" Label="Currency" Variant="Variant.Outlined"><MudSelectItem Value="@((int?)null)">(none)</MudSelectItem>@foreach (var c in currencies) { <MudSelectItem Value="@((int?)c.CurrencyDefinitionId)">@c.Code</MudSelectItem> }</MudSelect></MudItem>
            <MudItem xs="12" md="2"><MudNumericField T="decimal?" @bind-Value="model.Weight" Label="Weight (lb)" Variant="Variant.Outlined" Min="0" /></MudItem>
            <MudItem xs="12" md="2"><MudNumericField T="int" @bind-Value="model.Quantity" Label="Qty" Variant="Variant.Outlined" Min="1" /></MudItem>
            <MudItem xs="12" md="2"><MudSelect T="SourceType" @bind-Value="model.SourceType" Label="Source Type" Variant="Variant.Outlined"><MudSelectItem Value="SourceType.Official">Official</MudSelectItem><MudSelectItem Value="SourceType.ThirdParty">Third Party</MudSelectItem><MudSelectItem Value="SourceType.Homebrew">Homebrew</MudSelectItem></MudSelect></MudItem>

            @if (model.SourceType == SourceType.Official)
            {
                <MudItem xs="12" md="8"><MudSelect T="int?" @bind-Value="model.SourceMaterialId" Label="Official Source Material" Variant="Variant.Outlined"><MudSelectItem Value="@((int?)null)">(select source)</MudSelectItem>@foreach (var sm in sourceMaterials){ <MudSelectItem Value="@((int?)sm.SourceMaterialId)">@($"{sm.Code} — {sm.Title}")</MudSelectItem> }</MudSelect></MudItem>
            }
            else
            {
                <MudItem xs="12" md="8"><MudSelect T="int?" @bind-Value="model.CampaignId" Label="Campaign Source" Variant="Variant.Outlined"><MudSelectItem Value="@((int?)null)">(none)</MudSelectItem>@foreach (var c in campaigns){ <MudSelectItem Value="@((int?)c.CampaignId)">@c.Title</MudSelectItem> }</MudSelect></MudItem>
            }
            <MudItem xs="12" md="2"><MudNumericField T="int?" @bind-Value="model.SourcePage" Label="Source Page" Variant="Variant.Outlined" Min="1" /></MudItem>
            <MudItem xs="12" md="2"><MudTextField @bind-Value="model.SourceBook" Label="Legacy Source Text" Variant="Variant.Outlined" Placeholder="optional" /></MudItem>

            @if (model.SourceType != SourceType.Official)
            {
                <MudItem xs="12" md="6">
                    <MudSelect T="int?" @bind-Value="model.OwnerAppUserId" Label="Owner" Variant="Variant.Outlined">
                        <MudSelectItem Value="@((int?)null)">(auto / current user)</MudSelectItem>
                        @foreach (var o in owners)
                        {
                            <MudSelectItem Value="@((int?)o.AppUserId)">@($"{o.Username} ({o.Email})")</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            }
        </MudGrid>
    </MudPaper>

        <MudPaper Class="pa-4 rf-section rf-section--combat" Outlined="true">
        <MudText Typo="Typo.subtitle1" Class="mb-1">Combat Profile</MudText>
        <MudText Typo="Typo.caption" Class="mb-3">Only relevant fields for the selected type are shown.</MudText>
        <MudGrid>
            @if (IsWeaponType)
            {
                <MudItem xs="12" md="3"><MudTextField @bind-Value="model.DamageDice" Label="Damage Dice" Variant="Variant.Outlined" Placeholder="e.g., 1d8" /></MudItem>
                <MudItem xs="12" md="3"><MudTextField @bind-Value="model.DamageType" Label="Damage Type" Variant="Variant.Outlined" Placeholder="e.g., Slashing" /></MudItem>
                <MudItem xs="12" md="3"><MudTextField @bind-Value="model.VersatileDamageDice" Label="Versatile Dice" Variant="Variant.Outlined" Placeholder="e.g., 1d10" /></MudItem>
                <MudItem xs="12" md="3"><MudNumericField T="int?" @bind-Value="model.RangeNormal" Label="Range (Normal)" Variant="Variant.Outlined" Min="0" /></MudItem>
                <MudItem xs="12" md="3"><MudNumericField T="int?" @bind-Value="model.RangeLong" Label="Range (Long)" Variant="Variant.Outlined" Min="0" /></MudItem>

                <MudItem xs="12">
                    <MudText Typo="Typo.caption" Class="mb-1">Weapon Properties</MudText>
                    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2">
                        <MudCheckBox @bind-Value="model.WeaponPropertyLight" Label="Light" />
                        <MudCheckBox @bind-Value="model.WeaponPropertyHeavy" Label="Heavy" />
                        <MudCheckBox @bind-Value="model.WeaponPropertyFinesse" Label="Finesse" />
                        <MudCheckBox @bind-Value="model.WeaponPropertyThrown" Label="Thrown" />
                        <MudCheckBox @bind-Value="model.WeaponPropertyTwoHanded" Label="Two-Handed" />
                        <MudCheckBox @bind-Value="model.WeaponPropertyLoading" Label="Loading" />
                        <MudCheckBox @bind-Value="model.WeaponPropertyReach" Label="Reach" />
                        <MudCheckBox @bind-Value="model.WeaponPropertyAmmunition" Label="Ammunition" />
                    </MudStack>
                </MudItem>
            }

            @if (IsArmorType)
            {
                <MudItem xs="12" md="3"><MudNumericField T="int?" @bind-Value="model.ArmorClass" Label="Armor Class" Variant="Variant.Outlined" Min="0" /></MudItem>
                <MudItem xs="12" md="3">
                    <MudSelect T="string" @bind-Value="model.ArmorCategory" Label="Armor Category" Variant="Variant.Outlined">
                        <MudSelectItem Value="@((string?)null)">(none)</MudSelectItem>
                        <MudSelectItem Value="@("Light")">Light</MudSelectItem>
                        <MudSelectItem Value="@("Medium")">Medium</MudSelectItem>
                        <MudSelectItem Value="@("Heavy")">Heavy</MudSelectItem>
                        <MudSelectItem Value="@("Shield")">Shield</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="3"><MudNumericField T="int?" @bind-Value="model.StrengthRequirement" Label="STR Requirement" Variant="Variant.Outlined" Min="0" /></MudItem>
                <MudItem xs="12" md="3"><MudCheckBox @bind-Value="model.StealthDisadvantage" Label="Stealth Disadvantage" /></MudItem>
            }

            @if (!IsWeaponType && !IsArmorType)
            {
                <MudItem xs="12">
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                        Select an item type like <b>Weapon</b> or <b>Armor/Shield</b> to show profile-specific fields.
                    </MudAlert>
                </MudItem>
            }
        </MudGrid>
    </MudPaper>

    <MudPaper Class="pa-4 rf-section rf-section--magic" Outlined="true">
        <MudText Typo="Typo.subtitle1" Class="mb-1">Magic & Attunement</MudText>
        <MudText Typo="Typo.caption" Class="mb-3">Use for potions, scrolls, rings, wands, rods, staffs, and wondrous items.</MudText>
        <MudGrid>
            @if (IsConsumableType || IsMagicType)
            {
                <MudItem xs="12" md="2"><MudCheckBox @bind-Value="model.IsConsumable" Label="Consumable" /></MudItem>
                <MudItem xs="12" md="2"><MudNumericField T="int?" @bind-Value="model.ChargesCurrent" Label="Charges (Current)" Variant="Variant.Outlined" Min="0" /></MudItem>
                <MudItem xs="12" md="2"><MudNumericField T="int?" @bind-Value="model.ChargesMax" Label="Charges (Max)" Variant="Variant.Outlined" Min="0" /></MudItem>
                <MudItem xs="12" md="3"><MudTextField @bind-Value="model.RechargeRule" Label="Recharge Rule" Variant="Variant.Outlined" Placeholder="e.g., dawn" /></MudItem>
                <MudItem xs="12" md="3"><MudNumericField T="int?" @bind-Value="model.UsesPerDay" Label="Uses / Day" Variant="Variant.Outlined" Min="0" /></MudItem>
            }

            @if (IsMagicType)
            {
                <MudItem xs="12" md="3">
                    <MudCheckBox @bind-Value="model.RequiresAttunement" Label="Requires Attunement" />
                </MudItem>
                @if (model.RequiresAttunement)
                {
                    <MudItem xs="12" md="9">
                        <MudTextField @bind-Value="model.AttunementRequirement"
                                      Label="Attunement Requirement"
                                      Variant="Variant.Outlined"
                                      Placeholder="e.g., by a wizard" />
                    </MudItem>
                }
            }

            @if (!IsConsumableType && !IsMagicType)
            {
                <MudItem xs="12">
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                        Magic/attunement fields are shown for potion/consumable and magic-oriented item types.
                    </MudAlert>
                </MudItem>
            }
        </MudGrid>
    </MudPaper>

    <MudPaper Class="pa-4 rf-section rf-section--tags" Outlined="true">
        <MudText Typo="Typo.subtitle1" Class="mb-3">Tags & Notes</MudText>
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudSelect T="int"
                           MultiSelection="true"
                           @bind-SelectedValues="SelectedTagValues"
                           Label="Tags"
                           Variant="Variant.Outlined"
                           MultiSelectionTextFunc="TagSelectionText">
                    @foreach (var t in tags)
                    {
                        <MudSelectItem Value="@t.TagDefinitionId">@t.Name</MudSelectItem>
                    }
                </MudSelect>
                @if (selectedTagIds.Count > 0)
                {
                    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="mt-2">
                        @foreach (var tag in tags.Where(t => selectedTagIds.Contains(t.TagDefinitionId)).OrderBy(t => t.Name))
                        {
                            <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" OnClose="@(() => RemoveTag(tag.TagDefinitionId))">
                                @tag.Name
                            </MudChip>
                        }
                    </MudStack>
                }
            </MudItem>
            <MudItem xs="12" md="6"><MudTextField @bind-Value="model.Description" Label="Short Description" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="12">
                <MarkdownEditor Value="@model.Effect" ValueChanged="@( (string? v) => model.Effect = v )" Label="Effect (Markdown)" Rows="10" ShowPreview="true" />
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudPaper Class="pa-3" Outlined="true">
        <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd">
            <MudButton Href="/items" Variant="Variant.Text" Color="Color.Secondary">Cancel</MudButton>
            <MudButton OnClick="Save" Variant="Variant.Filled" Color="Color.Primary">Save Item</MudButton>
        </MudStack>
    </MudPaper>
</MudStack>

@code {
    [Parameter] public int? ItemId { get; set; }
    private bool _isEdit => ItemId.HasValue;

    private List<GameSystemDto> systems = new();
    private List<ItemTypeDto> types = new();
    private List<RarityDto> rarities = new();
    private List<CurrencyDto> currencies = new();
    private List<SourceMaterialDto> sourceMaterials = new();
    private List<UserOwnerDto> owners = new();
    private List<CampaignLiteDto> campaigns = new();
    private List<TagDto> tags = new();
    private FormModel model = new();

    protected override async Task OnInitializedAsync()
    {
        systems = await Http.GetFromJsonAsync<List<GameSystemDto>>(Nav.ToAbsoluteUri("/api/game-systems")) ?? new();
        model.GameSystemId = systems.FirstOrDefault()?.GameSystemId ?? 0;
        selectedTagIds = model.TagDefinitionIds.ToHashSet();
        await LoadLookups();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!_isEdit) return;
        var dto = await Http.GetFromJsonAsync<ItemDto>(Nav.ToAbsoluteUri($"/api/items/{ItemId!.Value}"));
        if (dto is null) { Nav.NavigateTo("/items"); return; }

        model = new FormModel
        {
            GameSystemId = dto.GameSystemId,
            Name = dto.Name,
            ItemTypeDefinitionId = dto.ItemTypeDefinitionId,
            RarityDefinitionId = dto.RarityDefinitionId,
            Description = dto.Description,
            CostAmount = dto.CostAmount,
            CurrencyDefinitionId = dto.CurrencyDefinitionId,
            CostCurrency = dto.CostCurrency,
            Weight = dto.Weight,
            Quantity = dto.Quantity,
            Tags = dto.Tags,
            TagDefinitionIds = dto.TagDefinitionIds?.ToList() ?? new List<int>(),
            SourceType = dto.SourceType,
            Alias = dto.Alias,
            Effect = dto.Effect,
            RequiresAttunement = dto.RequiresAttunement,
            AttunementRequirement = dto.AttunementRequirement,
            DamageDice = dto.DamageDice,
            DamageType = dto.DamageType,
            VersatileDamageDice = dto.VersatileDamageDice,
            ArmorClass = dto.ArmorClass,
            StrengthRequirement = dto.StrengthRequirement,
            StealthDisadvantage = dto.StealthDisadvantage,
            RangeNormal = dto.RangeNormal,
            RangeLong = dto.RangeLong,
            SourceMaterialId = dto.SourceMaterialId,
            CampaignId = dto.CampaignId,
            OwnerAppUserId = dto.OwnerAppUserId,
            SourceBook = dto.SourceBook,
            SourcePage = dto.SourcePage,
            IsConsumable = dto.IsConsumable,
            ChargesCurrent = dto.ChargesCurrent,
            ChargesMax = dto.ChargesMax,
            RechargeRule = dto.RechargeRule,
            UsesPerDay = dto.UsesPerDay,
            ArmorCategory = dto.ArmorCategory,
            WeaponPropertyLight = dto.WeaponPropertyLight,
            WeaponPropertyHeavy = dto.WeaponPropertyHeavy,
            WeaponPropertyFinesse = dto.WeaponPropertyFinesse,
            WeaponPropertyThrown = dto.WeaponPropertyThrown,
            WeaponPropertyTwoHanded = dto.WeaponPropertyTwoHanded,
            WeaponPropertyLoading = dto.WeaponPropertyLoading,
            WeaponPropertyReach = dto.WeaponPropertyReach,
            WeaponPropertyAmmunition = dto.WeaponPropertyAmmunition
        };
        selectedTagIds = model.TagDefinitionIds.ToHashSet();

        await LoadLookups();
    }

    private async Task OnSystemChanged(int id)
    {
        model.GameSystemId = id;
        model.ItemTypeDefinitionId = null;
        model.RarityDefinitionId = null;
        model.CurrencyDefinitionId = null;
        model.SourceMaterialId = null;
        model.TagDefinitionIds = new List<int>();
        selectedTagIds.Clear();
        await LoadLookups();
    }

    private async Task LoadLookups()
    {
        if (model.GameSystemId <= 0) return;
        types = await Http.GetFromJsonAsync<List<ItemTypeDto>>(Nav.ToAbsoluteUri($"/api/item-types?gameSystemId={model.GameSystemId}")) ?? new();
        rarities = await Http.GetFromJsonAsync<List<RarityDto>>(Nav.ToAbsoluteUri($"/api/rarities?gameSystemId={model.GameSystemId}")) ?? new();
        currencies = await Http.GetFromJsonAsync<List<CurrencyDto>>(Nav.ToAbsoluteUri($"/api/currencies?gameSystemId={model.GameSystemId}")) ?? new();
        sourceMaterials = await Http.GetFromJsonAsync<List<SourceMaterialDto>>(Nav.ToAbsoluteUri($"/api/source-materials?gameSystemId={model.GameSystemId}")) ?? new();
        owners = await Http.GetFromJsonAsync<List<UserOwnerDto>>(Nav.ToAbsoluteUri("/api/users")) ?? new();
        try { campaigns = await JS.InvokeAsync<List<CampaignLiteDto>>("ruleforgeAuth.campaignsList") ?? new(); } catch { campaigns = new(); }
        tags = await Http.GetFromJsonAsync<List<TagDto>>(Nav.ToAbsoluteUri($"/api/tags?gameSystemId={model.GameSystemId}")) ?? new();
    }

    private HashSet<int> selectedTagIds = new();
    private IEnumerable<int> SelectedTagValues
    {
        get => selectedTagIds;
        set => selectedTagIds = value?.ToHashSet() ?? new HashSet<int>();
    }

    private string TagSelectionText(List<string> _)

    {
        var count = selectedTagIds.Count;
        return count == 0 ? "(none)" : $"{count} selected";
    }

    private void RemoveTag(int tagId)
    {
        selectedTagIds.Remove(tagId);
    }

    private bool IsWeaponType => SelectedTypeName?.Contains("weapon", StringComparison.OrdinalIgnoreCase) == true;
    private bool IsArmorType => SelectedTypeName?.Contains("armor", StringComparison.OrdinalIgnoreCase) == true
                               || SelectedTypeName?.Contains("shield", StringComparison.OrdinalIgnoreCase) == true;
    private bool IsConsumableType => SelectedTypeName?.Contains("potion", StringComparison.OrdinalIgnoreCase) == true
                                  || SelectedTypeName?.Contains("consumable", StringComparison.OrdinalIgnoreCase) == true;
    private bool IsMagicType => SelectedTypeName?.Contains("wondrous", StringComparison.OrdinalIgnoreCase) == true
                             || SelectedTypeName?.Contains("ring", StringComparison.OrdinalIgnoreCase) == true
                             || SelectedTypeName?.Contains("wand", StringComparison.OrdinalIgnoreCase) == true
                             || SelectedTypeName?.Contains("rod", StringComparison.OrdinalIgnoreCase) == true
                             || SelectedTypeName?.Contains("staff", StringComparison.OrdinalIgnoreCase) == true
                             || SelectedTypeName?.Contains("scroll", StringComparison.OrdinalIgnoreCase) == true
                             || IsConsumableType;

    private string? SelectedTypeName => types.FirstOrDefault(t => t.ItemTypeDefinitionId == model.ItemTypeDefinitionId)?.Name;

    private void NormalizeByType()
    {
        if (!IsWeaponType)
        {
            model.DamageDice = null;
            model.DamageType = null;
            model.VersatileDamageDice = null;
            model.RangeNormal = null;
            model.RangeLong = null;
            model.WeaponPropertyLight = false;
            model.WeaponPropertyHeavy = false;
            model.WeaponPropertyFinesse = false;
            model.WeaponPropertyThrown = false;
            model.WeaponPropertyTwoHanded = false;
            model.WeaponPropertyLoading = false;
            model.WeaponPropertyReach = false;
            model.WeaponPropertyAmmunition = false;
        }

        if (!IsArmorType)
        {
            model.ArmorClass = null;
            model.ArmorCategory = null;
            model.StrengthRequirement = null;
            model.StealthDisadvantage = false;
        }

        if (!IsConsumableType && !IsMagicType)
        {
            model.IsConsumable = false;
            model.ChargesCurrent = null;
            model.ChargesMax = null;
            model.RechargeRule = null;
            model.UsesPerDay = null;
            model.RequiresAttunement = false;
            model.AttunementRequirement = null;
        }

        if (!IsMagicType)
        {
            model.RequiresAttunement = false;
            model.AttunementRequirement = null;
        }
    }

    private void NormalizeSourceByType()
    {
        if (model.SourceType == SourceType.Official)
        {
            model.CampaignId = null;
        }
        else
        {
            model.SourceMaterialId = null;
        }
    }

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(model.Name) || model.GameSystemId <= 0) return;

        model.TagDefinitionIds = selectedTagIds.ToList();
        NormalizeByType();
        NormalizeSourceByType();

        var req = new CreateItemRequest(
            model.GameSystemId,
            model.Name,
            model.ItemTypeDefinitionId,
            model.RarityDefinitionId,
            model.Description,
            model.CostAmount,
            model.CurrencyDefinitionId,
            model.CostCurrency,
            model.Weight,
            model.Quantity,
            model.Tags,
            model.Effect,
            model.RequiresAttunement,
            model.AttunementRequirement,
            model.DamageDice,
            model.DamageType,
            model.VersatileDamageDice,
            model.ArmorClass,
            model.StrengthRequirement,
            model.StealthDisadvantage,
            model.RangeNormal,
            model.RangeLong,
            model.SourceMaterialId,
            model.CampaignId,
            model.SourceBook,
            model.SourcePage,
            model.IsConsumable,
            model.ChargesCurrent,
            model.ChargesMax,
            model.RechargeRule,
            model.UsesPerDay,
            model.ArmorCategory,
            model.WeaponPropertyLight,
            model.WeaponPropertyHeavy,
            model.WeaponPropertyFinesse,
            model.WeaponPropertyThrown,
            model.WeaponPropertyTwoHanded,
            model.WeaponPropertyLoading,
            model.WeaponPropertyReach,
            model.WeaponPropertyAmmunition,
            model.OwnerAppUserId,
            model.TagDefinitionIds,
            model.SourceType,
            model.Alias
        );

        HttpResponseMessage res = _isEdit
            ? await Http.PutAsJsonAsync(Nav.ToAbsoluteUri($"/api/items/{ItemId!.Value}"), req)
            : await Http.PostAsJsonAsync(Nav.ToAbsoluteUri("/api/items"), req);

        if (res.IsSuccessStatusCode)
            Nav.NavigateTo("/items");
    }

    private sealed class FormModel
    {
        public int GameSystemId { get; set; }
        public string Name { get; set; } = string.Empty;
        public int? ItemTypeDefinitionId { get; set; }
        public int? RarityDefinitionId { get; set; }
        public string? Description { get; set; }
        public decimal? CostAmount { get; set; }
        public int? CurrencyDefinitionId { get; set; }
        public string? CostCurrency { get; set; }
        public decimal? Weight { get; set; }
        public int Quantity { get; set; } = 1;
        public string? Tags { get; set; }
        public string? Effect { get; set; }
        public bool RequiresAttunement { get; set; }
