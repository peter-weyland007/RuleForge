@page "/game-systems"
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Game Systems</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h4">Game Systems</MudText>
        <MudButton Href="/game-systems/new" StartIcon="@Icons.Material.Filled.Add" Color="Color.Primary" Variant="Variant.Filled">Create</MudButton>
    </MudStack>

    <MudTable Items="rows" Hover="true" Dense="true" Loading="loading">
            <HeaderContent>
                
                <MudTh>Name</MudTh>
                <MudTh>Slug</MudTh>
                <MudTh>Alias</MudTh>
                <MudTh>Source</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                
                <MudTd>@context.Name</MudTd>
                <MudTd>@context.Slug</MudTd>
                <MudTd>@context.Alias</MudTd>
                <MudTd>@context.SourceType</MudTd>
                <MudTd>
                    <MudIconButton Href="@($"/game-systems/{context.GameSystemId}/edit")" Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(()=>ConfirmDelete(context.GameSystemId, context.Name))" />
                </MudTd>
            </RowTemplate>
        </MudTable>
</MudStack>

@code {
    private bool loading;
    private List<GameSystemDto> rows = new();

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        loading = true;
        rows = await Http.GetFromJsonAsync<List<GameSystemDto>>(Nav.ToAbsoluteUri("/api/game-systems")) ?? new();
        loading = false;
    }

    
    
    private async Task ConfirmDelete(int id, string name)
    {
        var confirmed = await DialogService.ShowMessageBox(
            "Delete Game System",
            (MarkupString)$"Are you sure you want to delete <b>{name}</b>?",
            yesText: "Delete",
            cancelText: "Cancel");

        if (confirmed == true)
            await Delete(id);
    }
private async Task Delete(int id)
    {
        var res = await Http.DeleteAsync(Nav.ToAbsoluteUri($"/api/game-systems/{id}"));
        if (res.IsSuccessStatusCode)
        {
            Snackbar.Add("Game system deleted.", Severity.Success);
            await Load();
        }
        else
        {
            Snackbar.Add("Delete failed.", Severity.Error);
        }
    }
public sealed record GameSystemDto(int GameSystemId, string Name, string Slug, string? Alias, string? Description, SourceType SourceType);
}
