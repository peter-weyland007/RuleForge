@page "/admin/users/new"
@page "/admin/users/{AppUserId:int}/edit"
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>@(_isEdit ? "Edit User" : "Create User")</PageTitle>

<MudStack Spacing="3">
    <MudText Typo="Typo.h4">@(_isEdit ? "Edit User" : "Create User")</MudText>

    <MudPaper Class="pa-4" Outlined="true">
        <MudGrid>
            <MudItem xs="12" md="6"><MudTextField @bind-Value="model.Email" Label="Email" Variant="Variant.Outlined" Disabled="@_isEdit" Required="true" /></MudItem>

            @if (!_isEdit)
            {
                <MudItem xs="12" md="6"><MudTextField @bind-Value="model.Password" Label="Temporary Password" InputType="InputType.Password" Variant="Variant.Outlined" Required="true" HelperText="Minimum 8 characters" /></MudItem>
            }

            <MudItem xs="12" md="3">
                <MudSelect T="string" @bind-Value="model.Role" Label="Role" Variant="Variant.Outlined" Disabled="@model.IsSystemAccount">
                    <MudSelectItem Value="@("Admin")">Admin</MudSelectItem>
                    <MudSelectItem Value="@("Users")">Users</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="3"><MudCheckBox @bind-Value="model.IsActive" Label="Active" Disabled="@model.IsSystemAccount" /></MudItem>
            <MudItem xs="12" md="3"><MudCheckBox @bind-Value="model.MustChangePassword" Label="Must Change Password" Disabled="@(_isEdit || model.IsSystemAccount)" /></MudItem>
            <MudItem xs="12" md="3"><MudCheckBox @bind-Value="model.IsSystemAccount" Label="System Account" Disabled="true" /></MudItem>

            <MudItem xs="12">
                <MudStack Row="true" Spacing="2">
                    <MudButtonGroup Variant="Variant.Filled" Color="Color.Primary">
                        <MudButton OnClick="Save">Save</MudButton>
                        <MudButton Href="/admin/users" Color="Color.Secondary">Cancel</MudButton>
                    </MudButtonGroup>
                </MudStack>
            </MudItem>
        </MudGrid>
    </MudPaper>
</MudStack>

@code {
    [Parameter] public int? AppUserId { get; set; }
    private bool _isEdit => AppUserId.HasValue;

    private FormModel model = new();

    protected override async Task OnParametersSetAsync()
    {
        if (!_isEdit) return;

        var dto = await Http.GetFromJsonAsync<UserDto>(Nav.ToAbsoluteUri($"/api/admin/users/{AppUserId!.Value}"));
        if (dto is null) { Nav.NavigateTo("/admin/users"); return; }
        model = new FormModel
        {
            Email = dto.Email,
            Role = dto.Role,
            IsActive = dto.IsActive,
            IsSystemAccount = dto.IsSystemAccount,
            MustChangePassword = dto.MustChangePassword
        };
    }

    private async Task Save()
    {
        HttpResponseMessage res;

        if (_isEdit)
        {
            res = await Http.PutAsJsonAsync(Nav.ToAbsoluteUri($"/api/admin/users/{AppUserId!.Value}"), new { Role = model.Role, IsActive = model.IsActive });
        }
        else
        {
            if (string.IsNullOrWhiteSpace(model.Email) || string.IsNullOrWhiteSpace(model.Password)) return;
            res = await Http.PostAsJsonAsync(Nav.ToAbsoluteUri("/api/admin/users"), new { Email = model.Email, Password = model.Password, Role = model.Role, IsActive = model.IsActive, MustChangePassword = model.MustChangePassword });
        }

        if (res.IsSuccessStatusCode) Nav.NavigateTo("/admin/users");
    }

    private sealed class FormModel
    {
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public string Role { get; set; } = "Users";
        public bool IsActive { get; set; } = true;
        public bool IsSystemAccount { get; set; }
        public bool MustChangePassword { get; set; } = true;
    }

    private sealed record UserDto(int AppUserId, string Email, string Role, bool IsActive, bool IsSystemAccount, bool MustChangePassword);
}
