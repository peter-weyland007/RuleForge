@page "/campaigns/new"
@page "/campaigns/{CampaignId:int}/edit"
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>@(_isEdit ? "Edit Campaign" : "New Campaign")</PageTitle>

<MudStack Spacing="3" Style="max-width:760px;">
    <MudText Typo="Typo.h4">@(_isEdit ? "Edit Campaign" : "New Campaign")</MudText>

    <MudPaper Class="pa-4" Outlined="true">
        <MudGrid>
            <MudItem xs="12"><MudTextField @bind-Value="model.Title" Label="Title" Variant="Variant.Outlined" Required="true" /></MudItem>
            <MudItem xs="12"><MudTextField @bind-Value="model.Description" Label="Description" Variant="Variant.Outlined" Lines="4" /></MudItem>
            <MudItem xs="12" md="6">
                <MudSelect T="int?" @bind-Value="model.OwnerAppUserId" Label="Owner" Variant="Variant.Outlined">
                    <MudSelectItem Value="@((int?)null)">(none)</MudSelectItem>
                    @foreach (var u in users)
                    {
                        <MudSelectItem Value="@((int?)u.AppUserId)">@($"{u.Username} ({u.Email})")</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudSelect T="int" MultiSelection="true" @bind-SelectedValues="SelectedCollaboratorValues" Label="Collaborators" Variant="Variant.Outlined" MultiSelectionTextFunc="@(vals => $"{SelectedCollaboratorValues.Count()} selected")">
                    @foreach (var u in users)
                    {
                        <MudSelectItem Value="@u.AppUserId">@($"{u.Username} ({u.Email})")</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudSelect T="int" MultiSelection="true" @bind-SelectedValues="SelectedPlayerValues" Label="Players" Variant="Variant.Outlined" MultiSelectionTextFunc="@(vals => $"{SelectedPlayerValues.Count()} selected")">
                    @foreach (var u in users)
                    {
                        <MudSelectItem Value="@u.AppUserId">@($"{u.Username} ({u.Email})")</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            @if (!string.IsNullOrWhiteSpace(error))
            {
                <MudItem xs="12"><MudAlert Severity="Severity.Error">@error</MudAlert></MudItem>
            }
            <MudItem xs="12">
                <MudStack Row="true" Spacing="2">
                    <MudButton OnClick="Save" Variant="Variant.Filled" Color="Color.Primary">Save</MudButton>
                    <MudButton Href="/campaigns" Variant="Variant.Outlined">Cancel</MudButton>
                </MudStack>
            </MudItem>
        </MudGrid>
    </MudPaper>
</MudStack>

@code {
    [Parameter] public int? CampaignId { get; set; }
    private bool _isEdit => CampaignId.HasValue;
    private string? error;

    private FormModel model = new();
    private List<UserDto> users = new();
    private HashSet<int> selectedCollaboratorIds = new();
    private HashSet<int> selectedPlayerIds = new();

    private IEnumerable<int> SelectedCollaboratorValues
    {
        get => selectedCollaboratorIds;
        set => selectedCollaboratorIds = value?.ToHashSet() ?? new HashSet<int>();
    }

    private IEnumerable<int> SelectedPlayerValues
    {
        get => selectedPlayerIds;
        set => selectedPlayerIds = value?.ToHashSet() ?? new HashSet<int>();
    }

    protected override async Task OnParametersSetAsync()
    {
        users = await Http.GetFromJsonAsync<List<UserDto>>(Nav.ToAbsoluteUri("/api/users")) ?? new();

        if (!_isEdit) return;
        var dto = await Http.GetFromJsonAsync<CampaignDto>(Nav.ToAbsoluteUri($"/api/campaigns/{CampaignId!.Value}"));
        if (dto is null) { Nav.NavigateTo("/campaigns"); return; }
        model = new FormModel { Title = dto.Title, Description = dto.Description, OwnerAppUserId = dto.OwnerAppUserId };
        selectedCollaboratorIds = (dto.CollaboratorUserIds ?? new List<int>()).ToHashSet();
        selectedPlayerIds = (dto.PlayerUserIds ?? new List<int>()).ToHashSet();
    }

    private async Task Save()
    {
        error = null;
        if (string.IsNullOrWhiteSpace(model.Title)) return;
        var req = new { Title = model.Title, Description = model.Description, OwnerAppUserId = model.OwnerAppUserId, CollaboratorUserIds = selectedCollaboratorIds.ToList(), PlayerUserIds = selectedPlayerIds.ToList() };
        var res = _isEdit
            ? await Http.PutAsJsonAsync(Nav.ToAbsoluteUri($"/api/campaigns/{CampaignId!.Value}"), req)
            : await Http.PostAsJsonAsync(Nav.ToAbsoluteUri("/api/campaigns"), req);

        if (res.IsSuccessStatusCode) Nav.NavigateTo("/campaigns");
        else error = await res.Content.ReadAsStringAsync();
    }

    private sealed class FormModel { public string Title { get; set; } = string.Empty; public string? Description { get; set; } public int? OwnerAppUserId { get; set; } }
    private sealed record CampaignDto(int CampaignId, string Title, string? Description, int? OwnerAppUserId, string? OwnerUsername, List<int>? CollaboratorUserIds, List<int>? PlayerUserIds);
    private sealed record UserDto(int AppUserId, string Username, string Email);
}
