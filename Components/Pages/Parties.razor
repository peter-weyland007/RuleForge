@page "/parties"
@inject IHttpClientFactory HttpFactory
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Parties</PageTitle>

<MudStack Spacing="3">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h4">Parties</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Group PCs into adventuring parties.</MudText>
        </MudStack>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreate">Add Party</MudButton>
    </MudStack>

    @if (!string.IsNullOrWhiteSpace(error))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@error</MudAlert>
    }

    <MudTable Items="rows" Dense="true" Hover="true" Outlined="true" Elevation="0">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Campaign</MudTh>
            <MudTh>Members</MudTh>
            <MudTh>Description</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Name</MudTd>
            <MudTd>@CampaignName(context.CampaignId)</MudTd>
            <MudTd>@context.MemberCount</MudTd>
            <MudTd>@(string.IsNullOrWhiteSpace(context.Description) ? "—" : context.Description)</MudTd>
            <MudTd Style="text-align:right; white-space:nowrap;">
                <MudIconButton Icon="@Icons.Material.Filled.People" Color="Color.Info" Size="Size.Small" OnClick="() => ViewMembers(context.PartyId, context.Name)" />
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" OnClick="() => OpenEdit(context.PartyId)" />
                <MudIconButton Icon="@Icons.Material.Filled.GroupAdd" Color="Color.Info" Size="Size.Small" OnClick="() => OpenShare(context.PartyId)" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="() => Delete(context.PartyId)" />
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Typo="Typo.body2" Class="pa-4">No parties yet. Add your first one.</MudText>
        </NoRecordsContent>
    </MudTable>


    @if (isShare)
    {
        <MudPaper Class="pa-4" Outlined="true" Elevation="0">
            <MudStack Spacing="2">
                <MudText Typo="Typo.h6">Share Party</MudText>
                <MudSelect T="int?" @bind-Value="shareUserId" Label="Friend" Variant="Variant.Outlined">
                    @foreach (var f in friends)
                    {
                        <MudSelectItem T="int?" Value="f.AppUserId">@f.Username</MudSelectItem>
                    }
                </MudSelect>
                <MudSelect T="int" @bind-Value="sharePermission" Label="Permission" Variant="Variant.Outlined">
                    <MudSelectItem Value="0">View</MudSelectItem>
                    <MudSelectItem Value="1">Edit</MudSelectItem>
                </MudSelect>
                <MudStack Row="true" Spacing="1">
                    <MudButton Variant="Variant.Filled" Color="Color.Info" OnClick="SaveShare">Share</MudButton>
                    <MudButton Variant="Variant.Outlined" OnClick="() => isShare = false">Cancel</MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>
    }

    @if (isEdit)
    {
        <MudPaper Class="pa-4" Outlined="true" Elevation="0">
            <MudStack Spacing="2">
                <MudText Typo="Typo.h6">@(form.PartyId.HasValue ? "Edit Party" : "Create Party")</MudText>
                <MudTextField @bind-Value="form.Name" Label="Party Name" Variant="Variant.Outlined" Required="true" />
                <MudSelect T="int?" @bind-Value="form.CampaignId" Label="Campaign (Optional)" Variant="Variant.Outlined" Clearable="true" Disabled="@(!campaigns.Any())">
                    @foreach (var c in campaigns)
                    {
                        <MudSelectItem T="int?" Value="c.CampaignId">@c.Name</MudSelectItem>
                    }
                </MudSelect>
                <MudTextField @bind-Value="form.Description" Label="Description" Variant="Variant.Outlined" Lines="3" />
                <MudStack Row="true" Spacing="1">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save">Save</MudButton>
                    <MudButton Variant="Variant.Outlined" OnClick="() => isEdit=false">Cancel</MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>
    }

    @if (showMembers)
    {
        <MudOverlay Visible="true" DarkBackground="true" AutoClose="true" OnClosed="CloseMembers" />
        <MudPaper Class="pa-4" Outlined="true" Elevation="8" Style="position: fixed; right: 16px; top: 80px; width: 420px; max-height: calc(100vh - 110px); overflow: auto; z-index: 1400;">
            <MudStack Spacing="2">
                <MudText Typo="Typo.h6">@memberDrawerTitle</MudText>

                @if (!partyMembers.Any())
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">No PCs assigned to this party yet.</MudText>
                }
                else
                {
                    <MudTable Items="partyMembers" Dense="true" Hover="true" Outlined="true" Elevation="0">
                        <HeaderContent>
                            <MudTh>Name</MudTh>
                            <MudTh>Class</MudTh>
                            <MudTh>Lvl</MudTh>
                            <MudTh>AC</MudTh>
                            <MudTh>HP</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.Name</MudTd>
                            <MudTd>@context.ClassName</MudTd>
                            <MudTd>@context.Level</MudTd>
                            <MudTd>@context.ArmorClass</MudTd>
                            <MudTd>@($"{context.HitPointsCurrent}/{context.HitPointsMax}")</MudTd>
                        </RowTemplate>
                        <NoRecordsContent>
                            <MudText Typo="Typo.body2" Class="pa-4">No members yet. Add PCs to this party from Characters.</MudText>
                        </NoRecordsContent>
                    </MudTable>
                }

                <MudButton Variant="Variant.Outlined" OnClick="CloseMembers">Close</MudButton>
            </MudStack>
        </MudPaper>
    }
</MudStack>

@code {
    private List<PartyRow> rows = new();
    private List<CampaignRow> campaigns = new();
    private List<PartyMemberRow> partyMembers = new();
    private string? error;
    private bool isShare;
    private int? shareId;
    private int? shareUserId;
    private int sharePermission;
    private List<FriendUser> friends = new();
    private bool isEdit;
    private bool showMembers;
    private string memberDrawerTitle = "Party Members";
    private PartyForm form = new();

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        try
        {
            error = null;
            var r1 = await JS.InvokeAsync<ApiResult<List<PartyRow>>>("ruleforgeApi.get", "/api/parties");
            var r2 = await JS.InvokeAsync<ApiResult<List<CampaignRow>>>("ruleforgeApi.get", "/api/campaigns");
            var fr = await JS.InvokeAsync<ApiResult<FriendsOverview>>("ruleforgeApi.get", "/api/friends");
            if (!r1.Ok) { error = string.IsNullOrWhiteSpace(r1.Text) ? "Failed to load parties." : r1.Text; rows = new(); return; }
            rows = r1.Data ?? new();
            campaigns = r2.Data ?? new();
            friends = fr.Data?.Friends ?? new();
        }
        catch (Exception ex)
        {
            error = ex.Message;
            rows = new();
            campaigns = new();
        }
    }

    private void OpenCreate(){ form=new PartyForm(); isEdit=true; }
    private async Task OpenEdit(int id){ var r=await JS.InvokeAsync<ApiResult<PartyRow>>("ruleforgeApi.get", $"/api/parties/{id}"); if(!r.Ok||r.Data is null){ error = string.IsNullOrWhiteSpace(r.Text)?"Party not found.":r.Text; return;} var d=r.Data; form=new PartyForm{PartyId=d.PartyId,Name=d.Name,Description=d.Description,CampaignId=d.CampaignId}; isEdit=true; }
    private async Task Delete(int id){ var ok = await JS.InvokeAsync<bool>("confirm", "Delete this party?"); if (!ok) return; var r=await JS.InvokeAsync<ApiResult<object>>("ruleforgeApi.delete", $"/api/parties/{id}"); if(!r.Ok){ error=string.IsNullOrWhiteSpace(r.Text)?"Delete failed.":r.Text; return;} await Load(); }
    private async Task Save(){ var req=new{name=form.Name,description=form.Description,campaignId=form.CampaignId}; ApiResult<object> r = form.PartyId.HasValue ? await JS.InvokeAsync<ApiResult<object>>("ruleforgeApi.put", $"/api/parties/{form.PartyId.Value}", req) : await JS.InvokeAsync<ApiResult<object>>("ruleforgeApi.post", "/api/parties", req); if(!r.Ok){ error=string.IsNullOrWhiteSpace(r.Text)?"Save failed.":r.Text; return;} isEdit=false; await Load(); }

    private void CloseMembers() => showMembers = false;

    private void OpenShare(int id) { shareId = id; shareUserId = null; sharePermission = 0; isShare = true; }
    private async Task SaveShare()
    {
        if (!shareId.HasValue || !shareUserId.HasValue) { error = "Pick a friend to share with."; return; }
        var r = await JS.InvokeAsync<ApiResult<object>>("ruleforgeApi.post", $"/api/parties/{shareId.Value}/share", new { userId = shareUserId.Value, permission = sharePermission });
        if (!r.Ok) { error = string.IsNullOrWhiteSpace(r.Text) ? "Share failed." : r.Text; return; }
        isShare = false;
    }

    private async Task ViewMembers(int partyId, string partyName)
    {
        var r = await JS.InvokeAsync<ApiResult<List<PartyMemberRow>>>("ruleforgeApi.get", $"/api/parties/{partyId}/members");
        if(!r.Ok){ error = string.IsNullOrWhiteSpace(r.Text)?"Failed to load members.":r.Text; return; }
        partyMembers = r.Data ?? new();
        memberDrawerTitle = $"{partyName} Members";
        showMembers = true;
    }

    private string CampaignName(int? id) => id is null ? "—" : campaigns.FirstOrDefault(x => x.CampaignId == id)?.Name ?? $"#{id}";

    private sealed class PartyForm { public int? PartyId {get;set;} public string Name {get;set;} = string.Empty; public string? Description {get;set;} public int? CampaignId {get;set;} }
    private sealed record PartyRow(int PartyId, string Name, string? Description, int? CampaignId, int MemberCount);
    private sealed record CampaignRow(int CampaignId, string Name);
    private sealed record PartyMemberRow(int CharacterId, string Name, string? ClassName, int? Level, int? ArmorClass, int? HitPointsCurrent, int? HitPointsMax);
    private sealed class ApiResult<T> { public bool Ok { get; set; } public int Status { get; set; } public T? Data { get; set; } public string? Text { get; set; } }
    private sealed record FriendUser(int AppUserId, string Username, string Email);
    private sealed record FriendsOverview(List<FriendUser> Friends);
}
