@page "/docs"

<PageTitle>Documentation</PageTitle>

<MudStack Spacing="3">
    <MudStack Spacing="0">
        <MudText Typo="Typo.h4">Documentation</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">Internal product documentation for RuleForge. Add new docs here as features evolve.</MudText>
    </MudStack>

    <MudPaper Class="pa-4" Outlined="true" Elevation="0">
        <MudText Typo="Typo.h6">Quest Modes & Use Choice Mode</MudText>

        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-2">
            Quest mode defines how a quest is authored. Use Choice Mode defines how the DM runs it at the table.
        </MudAlert>

        <MudGrid Class="mt-2">
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-3" Outlined="true" Elevation="0">
                    <MudText Typo="Typo.subtitle1">Linear</MudText>
                    <MudText Typo="Typo.body2">Use ordered nodes like a traditional module/chapter flow. Branches are optional and minimal.</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-3" Outlined="true" Elevation="0">
                    <MudText Typo="Typo.subtitle1">Branching</MudText>
                    <MudText Typo="Typo.body2">Use node choices as primary navigation. DM selects branches as players make decisions.</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-3" Outlined="true" Elevation="0">
                    <MudText Typo="Typo.subtitle1">Hybrid</MudText>
                    <MudText Typo="Typo.body2">Best of both. Author linearly while still supporting branch points and optional paths.</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudPaper Class="pa-3 mt-3" Outlined="true" Elevation="0">
            <MudText Typo="Typo.subtitle1">Use Choice Mode (On/Off)</MudText>
            <MudList T="string" Dense="true">
                <MudListItem T="string"><b>On:</b> DM follows branch choices at decision points (choose-your-own-adventure style).</MudListItem>
                <MudListItem T="string"><b>Off:</b> DM can read linearly and manually jump as needed (traditional style).</MudListItem>
            </MudList>
        </MudPaper>

        <MudPaper Class="pa-3 mt-3" Outlined="true" Elevation="0">
            <MudText Typo="Typo.subtitle1">Recommended Use</MudText>
            <MudList T="string" Dense="true">
                <MudListItem T="string">Story-heavy / fixed pacing: <b>Linear + Choice Mode Off</b></MudListItem>
                <MudListItem T="string">Player-agency sessions: <b>Branching + Choice Mode On</b></MudListItem>
                <MudListItem T="string">Most campaigns: <b>Hybrid + toggle per session</b></MudListItem>
            </MudList>
        </MudPaper>
    </MudPaper>
</MudStack>
